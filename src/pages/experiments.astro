---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ModuleCard from '@/components/ui/ModuleCard.astro';
import { execSync } from 'child_process';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const commitHash = execSync('git rev-parse --short HEAD').toString().trim();
const thumbBase = `${base}/images/thumbs`;

const experiments = [
  {
    title: 'Back Control: Control Their Rotation',
    description: 'An interactive essay on the geometry, mechanism, and simulation of back control. Five simultaneous battles, each with its own toolbox.',
    href: `${base}/modules/back-control`,
    status: 'live' as const,
    tag: 'INTERACTIVE ESSAY',
    thumb: `${thumbBase}/back-control.webp`,
  },
  {
    title: 'Belt Dropout',
    description: 'Visualize belt progression and dropout statistics in BJJ.',
    href: `${base}/modules/belt-dropout`,
    status: 'live' as const,
    tag: 'DATA',
    thumb: `${thumbBase}/belt-dropout.webp`,
  },
  {
    title: 'Centroid Game',
    description: 'Estimate the center of mass of a dot cluster. 10 rounds, Chebyshev scoring, timer penalty, lowest score wins.',
    href: `${base}/modules/centroid`,
    status: 'live' as const,
    tag: 'GAME',
    thumb: `${thumbBase}/games-centroid.webp`,
  },
  {
    title: 'Beyond Offense & Defense',
    description: "It's always the same: improve your relative position. Both players, simultaneously.",
    href: `${base}/modules/beyond-offense-defense`,
    status: 'live' as const,
    tag: 'CONCEPTS',
    thumb: `${thumbBase}/beyond-offense-defense.webp`,
  },
  {
    title: 'Grappling Timer',
    description: 'Round timer with configurable duration, rest, and rounds. 3-2-1 countdown, beep cues, auto-cycle.',
    href: `${base}/modules/timer`,
    status: 'live' as const,
    tag: 'TOOLS',
    thumb: `${thumbBase}/timer.webp`,
  },
  {
    title: 'Visual Notes',
    description: 'Hand-drawn diagrams and sketches collected over years of training.',
    href: `${base}/modules/visual-notes`,
    status: 'live' as const,
    tag: 'MEDIA',
    thumb: `${thumbBase}/visual-notes.webp`,
  },
  {
    title: 'Where to Start?',
    description: 'The entry point to grappling isn\'t a position. It\'s a psychological state.',
    href: `${base}/modules/where-to-start`,
    status: 'live' as const,
    tag: 'INTERACTIVE ESSAY',
    thumb: `${thumbBase}/where-to-start.webp`,
  },
  {
    title: 'Breathing',
    description: 'CO\u2082 tolerance, the Bohr Effect, and why the exhale is the universal key. Canvas breathing animation.',
    href: `${base}/modules/breathing`,
    status: 'live' as const,
    tag: 'ARTICLE',
  },
  {
    title: 'Flow & Roll',
    description: 'What does "flow" actually mean in sparring? A practitioner model for intensity, problem density, and the science behind it.',
    href: `${base}/modules/flow-roll`,
    status: 'live' as const,
    tag: 'INTERACTIVE ESSAY',
  },
  {
    title: 'Signal / Noise',
    description: 'The horseshoe model applied to grappling culture. Both extremes are neighbors — and neither knows it.',
    href: `${base}/modules/horseshoe`,
    status: 'live' as const,
    tag: 'INTERACTIVE ESSAY',
    thumb: `${thumbBase}/horseshoe.webp`,
  },
  {
    title: 'Concept Reader',
    description: 'Browse and read all concepts organized by category. Minimalist reading interface.',
    href: `${base}/modules/reader`,
    status: 'live' as const,
    tag: 'READER',
  },
  {
    title: 'Grappling Meta',
    description: 'Interactive competition statistics across BJJ, grappling, and MMA. Attempt rates, finish breakdowns, technique rankings, and meta trends.',
    href: `${base}/modules/grapplingstats`,
    status: 'live' as const,
    tag: 'DATA',
  },
];

const purgatory = [
  {
    title: 'Articles',
    description: 'Long-form writings on grappling concepts, heuristics, training philosophy, and more.',
    href: `${base}/modules/articles-reader`,
    status: 'live' as const,
    tag: 'READER',
    thumb: `${thumbBase}/articles.webp`,
  },
  {
    title: 'Skill Assessment',
    description: 'Rate your confidence across 15 grappling areas. Results as a bar chart.',
    href: `${base}/modules/skill-check`,
    status: 'live' as const,
    tag: 'TOOLS',
    thumb: `${thumbBase}/skill-check.webp`,
  },
  {
    title: 'Weight Classes',
    description: 'Find your division across IBJJF, ADCC, and WNO. Includes kg/lbs conversion.',
    href: `${base}/modules/weight-class`,
    status: 'live' as const,
    tag: 'TOOLS',
    thumb: `${thumbBase}/weight-class.webp`,
  },
  {
    title: 'BJJ Pricing',
    description: 'Monthly memberships and seminar fees worldwide. Interactive maps and box plots.',
    href: `${base}/modules/pricing`,
    status: 'live' as const,
    tag: 'DATA',
    thumb: `${thumbBase}/pricing.webp`,
  },
  {
    title: 'Games Hub',
    description: 'Mini-games: memory match, centroid estimation, and more.',
    href: `${base}/modules/games`,
    status: 'live' as const,
    tag: 'GAMES',
    thumb: `${thumbBase}/games.webp`,
  },
  {
    title: 'Training Partners',
    description: 'Map the 10 archetypal training partners. Self-assess and find your closest match.',
    href: `${base}/modules/training-partner`,
    status: 'live' as const,
    tag: 'TOOLS',
    thumb: `${thumbBase}/training-partner.webp`,
  },
  {
    title: 'Flash Cards',
    description: 'Study and review all concepts with Anki-style flash cards.',
    href: `${base}/modules/cards`,
    status: 'wip' as const,
    tag: 'STUDY',
    thumb: `${thumbBase}/cards.webp`,
  },
];
---

<BaseLayout title="Experiments — Grappling Primitives">
  <div class="max-w-4xl mx-auto px-4 py-12">

    <div class="mb-10 fade-up">
      <p class="text-[length:var(--text-chrome)] tracking-[4px] text-accent uppercase mb-3">Experiments</p>
      <h1 class="font-digital text-text-primary mb-3" style="font-size:clamp(2rem,6vw,3rem);font-weight:700;letter-spacing:0.04em;text-shadow:0 0 18px #00d4ff66,0 0 40px #00d4ff22;">
        Experiments
      </h1>
      <p class="text-sm text-text-muted max-w-xl leading-relaxed">
        Side projects and explorations. Some useful, some just fun. <span class="text-text-dim">[{commitHash}]</span>
      </p>
    </div>

    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
      {experiments.map((m) => (
        <ModuleCard {...m} />
      ))}
    </div>

    <!-- Purgatory toggle -->
    <div class="mt-16 text-center">
      <button
        id="purgatory-toggle"
        class="text-[length:var(--text-chrome)] tracking-[2px] uppercase font-mono text-text-dim/40 hover:text-text-dim/70 transition-colors cursor-pointer border-none bg-none"
        style="background:none;"
      >
        totally not ready for primetime &darr;
      </button>
    </div>

    <div id="purgatory-section" style="display:none;" class="mt-8 pt-8 border-t border-yellow-500/10">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[length:var(--text-chrome)] tracking-[3px] text-yellow-500/50 uppercase font-mono flex-shrink-0">Purgatory</span>
        <div class="flex-1 h-px bg-yellow-500/10" />
      </div>
      <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 opacity-50">
        {purgatory.map((m) => (
          <ModuleCard {...m} />
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('purgatory-toggle');
  const section = document.getElementById('purgatory-section');
  if (btn && section) {
    btn.addEventListener('click', () => {
      const showing = section.style.display !== 'none';
      section.style.display = showing ? 'none' : 'block';
      btn.innerHTML = showing
        ? 'totally not ready for primetime &darr;'
        : 'hide purgatory &uarr;';
    });
  }
</script>
