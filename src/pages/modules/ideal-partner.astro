---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { mdInline } from '@/lib/md-inline';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imgBase = base + '/images/ideal-partner/';
const tldr = await getEntry('module-text', 'ideal-partner-tldr');
---

<BaseLayout title="Ideal Training Partner — Grappling Primitives" fullscreen={true}>

<!-- ── Toolbar ──────────────────────────────────────────────────────────────── -->
<div id="toolbar" style="position:fixed;top:0;left:0;right:0;height:36px;z-index:50;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Courier New',Consolas,Monaco,monospace;">
  <a href={`${base}/`} style="font-size:10px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;text-decoration:none;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'">← Home</a>
  <span style="color:#21262d;">|</span>
  <span style="font-size:11px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;">Ideal Training Partner</span>
  <div style="flex:1;"></div>
  <button id="deeplink-btn" style="font-family:inherit;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;" onmouseover="this.style.borderColor='rgba(0,212,255,0.4)';this.style.color='#00d4ff'" onmouseout="if(this.textContent==='Link'){this.style.borderColor='#21262d';this.style.color='#6b7280'}">Link</button>
  <button id="lang-toggle" style="font-family:inherit;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;">
    <span class="lang-label" data-active="en">EN</span> / <span class="lang-label">JP</span>
  </button>
</div>

<!-- ── Scrolling Content ───────────────────────────────────────────────────── -->
<div style="padding-top:36px;">

<!-- TLDR (from src/content/module-text/) -->
<details class="tldr tldr--top">
  <summary class="tldr__toggle">
    <span lang="en">TL;DR. The whole argument in 30 seconds.</span>
    <span lang="ja">要約。30秒で全体の論点。</span>
  </summary>
  <div class="tldr__body">
    <p>
      <span lang="en"><Fragment set:html={mdInline(tldr.data.en)} /></span>
      <span lang="ja"><Fragment set:html={mdInline(tldr.data.ja)} /></span>
    </p>
  </div>
</details>

<!-- ACT 0 -->
<section id="act-0" class="act" data-act="0">
  <div class="act-inner">
    <div class="body-mind-split">
      <div class="split-panel panel-body">
        <div class="split-icon"><img src={`${imgBase}icon_400x_0000_BodyUnderstimulated.png`} alt="Body — under-stimulated" class="split-icon-img" /></div>
        <h3><span lang="en">Body</span><span lang="ja">身体</span></h3>
        <div id="body-decline" class="body-decline-display">
          <div class="body-decline-label" id="body-decline-label">Under-stimulated</div>
          <canvas id="body-decline-canvas" class="body-decline-canvas"></canvas>
          <div class="body-decline-legend">
            <span class="body-legend-item" style="color:#34D399;">● Mobility</span>
            <span class="body-legend-item" style="color:#4C8DFF;">● Strength</span>
            <span class="body-legend-item" style="color:#F97316;">● Energy</span>
          </div>
        </div>
      </div>
      <div class="split-divider"></div>
      <div class="split-panel panel-mind">
        <div class="split-icon"><img src={`${imgBase}icon_400x_0001_MindOverstimulation162pct.png`} alt="Mind — over-stimulated" class="split-icon-img" /></div>
        <h3><span lang="en">Mind</span><span lang="ja">精神</span></h3>
        <div id="mind-overstim" class="overstim-display">
          <div class="overstim-label" id="overstim-label">Stimulated</div>
          <div class="overstim-pct" id="overstim-pct">0%</div>
          <div class="overstim-bar-track">
            <div class="overstim-bar-fill" id="overstim-fill"></div>
          </div>
          <div class="overstim-blocks" id="overstim-blocks"></div>
        </div>
      </div>
    </div>
    <p class="act-subtitle" style="margin-top:16px;">
      <span lang="en">Training is the antidote. But <em>how</em> you train matters.</span>
      <span lang="ja">トレーニングは解毒剤。しかし<em>どう</em>練習するかが重要。</span>
    </p>
    <blockquote class="hero-quote">
      <p>
        <span lang="en">"Give your partner puzzles to solve, not injuries."</span>
        <span lang="ja">「パートナーには怪我ではなく、解くべきパズルを与えよ。」</span>
      </p>
    </blockquote>
    <p class="thesis" style="margin-top:8px;">
      <span lang="en">Intensity modulation is itself a grappling skill.</span>
      <span lang="ja">強度の調節それ自体がグラップリングのスキルである。</span>
    </p>

  </div>
</section>

<!-- ACT 1 -->
<section id="act-1" class="act" data-act="1">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">01</span><span lang="en">Understanding Intensity</span><span lang="ja">強度を理解する</span></h2>
    <p class="act-lead"><span lang="en">Intensity is not on/off. It's like an analog volume knob, and we don't have to go to 11 all the time. Communicate with your partners, understand resistance levels, risk tolerance and competitive intent.</span><span lang="ja">強度は一つのダイヤルではない。抵抗、生理的負荷、リスク許容度、競技意図という複合的な制約の束である。</span></p>
    <div id="viz-intensity" class="viz-container"></div>
  </div>
</section>

<!-- ACT 2 -->
<section id="act-2" class="act" data-act="2">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">02</span><span lang="en">The Danger of Mismatch</span><span lang="ja">ミスマッチの危険性</span></h2>
    <p class="act-lead"><span lang="en">When partners are at different intensity levels, the result is higher risks of frustration, injury, or wasted training. Matched intensity makes for better learning, safer environment and more enjoyable rolls.</span><span lang="ja">パートナー間の強度が異なると、フラストレーション、怪我、無駄な練習につながる。強度の一致＝安全な成長。</span></p>
    <div id="viz-mismatch" class="viz-container"></div>
  </div>
</section>

<!-- ACT 3 -->
<section id="act-3" class="act" data-act="3">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">03</span><span lang="en">Intensity Drift</span><span lang="ja">強度ドリフト</span></h2>
    <p class="act-lead"><span lang="en">The "flow roll arms race". When the intensity creeps up mid-roll from 20% to 80% as the ego kicks in... 'oh yeah?! *I can go hard TOO'</span><span lang="ja">「フローロール軍拡競争」— エゴが介入すると、ロール中に強度が20%から80%へ徐々に上昇する。ミスマッチの時間的側面。</span></p>
    <div class="drift-ego-icon"><img src={`${imgBase}icon_400x_0009_EgoTrigger.png`} alt="Ego trigger" class="drift-ego-img" /></div>
    <div id="viz-drift" class="viz-container"></div>
    <div style="margin-top:32px;text-align:center;">
      <p class="act-lead" style="margin-bottom:8px;font-style:italic;"><span lang="en">"It's ok to tap in training"</span><span lang="ja">「練習でタップするのは大丈夫」</span></p>
      <p class="act-lead" style="margin-bottom:8px;font-style:italic;"><span lang="en">"Training is training, go compete if you want war"</span><span lang="ja">「トレーニングはトレーニング、戦争がしたいなら試合に出ろ」</span></p>
      <p class="act-lead" style="font-style:italic;"><span lang="en">"Comp training is only safe with trusted partners"</span><span lang="ja">「競技練習は信頼できるパートナーとだけ安全」</span></p>
    </div>
  </div>
</section>

<!-- ACT 4 -->
<section id="act-4" class="act" data-act="4">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">04</span><span lang="en">Know the Trade-offs</span><span lang="ja">トレードオフを知る</span></h2>
    <blockquote class="hero-quote" style="margin-bottom:24px;">
      <p style="font-size:clamp(0.95rem,2.5vw,1.2rem);">
        <span lang="en">"There are no solutions, only trade-offs."</span>
        <span lang="ja">「解決策はない、トレードオフがあるだけだ。」</span>
      </p>
      <cite>— Thomas Sowell</cite>
    </blockquote>
    <p class="act-lead"><span lang="en">Every intensity level gives something and takes something. Tap a card to see both sides.</span><span lang="ja">すべての強度レベルは何かを与え、何かを奪う。カードをタップして両面を見よう。</span></p>
    <div id="viz-tradeoffs" class="viz-container"></div>
  </div>
</section>

<!-- ACT 5 -->
<section id="act-5" class="act" data-act="5">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">05</span><span lang="en">Training Modes</span><span lang="ja">トレーニングモード</span></h2>
    <p class="act-lead"><span lang="en">Structure and intensity define four distinct training modes. Each has a purpose — click to explore.</span><span lang="ja">構造と強度が4つの異なるトレーニングモードを定義する。それぞれに目的がある。クリックして探ろう。</span></p>
    <div id="viz-quadrant" class="viz-container"></div>
  </div>
</section>

<!-- ACT 6 -->
<section id="act-6" class="act" data-act="6">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">06</span><span lang="en">Your Training Week</span><span lang="ja">あなたのトレーニング週間</span></h2>
    <p class="act-lead"><span lang="en">How many sessions? How hard? The 80/20 rule: keep 80% of training at low-to-mid intensity. Push the sliders and watch what happens.</span><span lang="ja">何セッション？どれくらいハード？80/20の法則：トレーニングの80%を低〜中強度に保つ。スライダーを動かして何が起こるか見よう。</span></p>
    <div id="viz-week" class="viz-container"></div>
  </div>
</section>

<!-- ACT 7 -->
<section id="act-7" class="act" data-act="7">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">07</span><span lang="en">Levels of Violence</span><span lang="ja">暴力のレベル</span></h2>
    <p class="act-lead"><span lang="en">Get some perspective as to what you are training for.</span><span lang="ja">あなたが何のためにトレーニングしているのか、視野を広げよう。</span></p>
    <blockquote class="hero-quote" style="margin-bottom:32px;">
      <p style="font-size:clamp(0.85rem,2vw,1.05rem);">
        <span lang="en">"The world is full enough of hurts and mischances without wars to multiply them."<br/><span style="color:var(--text-dim);font-size:0.85em;">[...]</span><br/>"It needs but one foe to breed a war, not two, Master Warden," answered &Eacute;owyn. "And those who have not swords can still die upon them."</span>
        <span lang="ja">「世界には戦争がなくとも傷や災難は十分にある。」<br/><span style="color:var(--text-dim);font-size:0.85em;">[...]</span><br/>「戦争を起こすには敵が一人いれば足りる、二人は要らぬ、管理人殿」とエオウィンは答えた。「剣を持たぬ者も剣に倒れることがある。」</span>
      </p>
      <cite>— J.R.R. Tolkien, The Return of the King</cite>
    </blockquote>
    <div id="viz-violence-spectrum" class="viz-container"></div>
    <p class="act-lead" style="margin-top:32px;"><span lang="en">But a single axis is reductive. Add a second dimension — rules, consent, the ability to stop — and the picture gains nuance.</span><span lang="ja">しかし単一の軸では還元的すぎる。ルール、同意、中断する能力という第二の次元を加えれば、より繊細な全体像が見える。</span></p>
    <blockquote class="hero-quote" style="margin-bottom:32px;">
      <p style="font-size:clamp(0.85rem,2vw,1.05rem);">
        <span lang="en">"The strong do what they can and the weak suffer what they must."</span>
        <span lang="ja">「強者はできることをなし、弱者は耐えねばならぬことに耐える。」</span>
      </p>
      <cite>— Melian Dialogue, 416 BC</cite>
    </blockquote>
    <div id="viz-violence-scatter" class="viz-container"></div>
  </div>
</section>

<!-- ACT 8 — CTA -->
<section id="act-8" class="act act--cta" data-act="8">
  <div class="act-inner">
    <div class="cta-hero-icon"><img src={`${imgBase}BeThePartner_abstract.png`} alt="Be the partner" class="cta-hero-img" /></div>
    <h2 class="cta-hero"><span lang="en">Be the Training Partner<br/>You Wish You Had</span><span lang="ja">あなたが望む<br/>トレーニングパートナーになれ</span></h2>
    <a href={`${base}/modules/training-partner`} class="cta-button"><span lang="en">Explore Training Partner Archetypes &rarr;</span><span lang="ja">トレーニングパートナーのアーキタイプを探る &rarr;</span></a>
  </div>
</section>

</div><!-- end scrolling content -->

</BaseLayout>

<style is:global>
:root {
  --bg:           #050509;
  --surface:      #0E1014;
  --border:       #1C1F26;
  --accent:       #4C8DFF;
  --accent-soft:  #A970FF;
  --cyan:         #00FFFF;
  --cyan-dim:     #00d4ff;
  --green:        #34D399;
  --amber:        #FBBF24;
  --red:          #F87171;
  --text-primary: #E5E7EB;
  --text-muted:   #9CA3AF;
  --text-dim:     #6B7280;
  --font-mono:    'Courier New', Consolas, Monaco, monospace;
  --glow-cyan:    0 0 12px #00FFFF88;
  --glow-blue:    0 0 12px #4C8DFF88;
  --glow-soft:    0 0 8px #A970FF66;
}

/* Hide JP by default */
[lang="ja"] { display: none; }
body.lang-ja [lang="ja"] { display: inline; }
body.lang-ja [lang="en"] { display: none; }

/* Toolbar lang toggle active state */
.lang-label[data-active] { color: #00FFFF; text-shadow: 0 0 12px #00FFFF88; }

/* ─── Acts ─── */
.act {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  border-bottom: 1px solid var(--border);
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}
.act.visible {
  opacity: 1;
  transform: translateY(0);
}
.act-inner {
  max-width: 780px;
  width: 100%;
}

.act-number {
  display: block;
  font-size: 11px;
  letter-spacing: 0.3em;
  color: var(--text-dim);
  margin-bottom: 4px;
}
.act-title {
  font-size: clamp(1.4rem, 4vw, 2rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 16px;
  text-shadow: var(--glow-blue);
}
.act-lead {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 32px;
  max-width: 600px;
}
.act-subtitle {
  color: var(--text-muted);
  font-size: 0.95rem;
  margin-top: 24px;
  text-align: center;
}
.act-subtitle em {
  color: var(--cyan);
  font-style: normal;
  text-shadow: var(--glow-cyan);
}

/* ─── Act 0 — Body/Mind Split ─── */
.body-mind-split {
  display: flex;
  gap: 0;
  margin-bottom: 48px;
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  align-items: stretch;
}
.split-panel {
  flex: 1;
  padding: 40px 24px;
  text-align: center;
  transition: opacity 0.6s;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}
.panel-body {
  background: var(--surface);
  opacity: 0.5;
}
.panel-mind {
  background: linear-gradient(135deg, #0E1014, #1a1025);
  box-shadow: inset 0 0 40px rgba(169,112,255,0.08);
}
.split-divider {
  width: 1px;
  background: var(--border);
}
.split-icon {
  margin-bottom: 12px;
}
.split-icon-img {
  width: 400px;
  max-width: 100%;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 8px rgba(0,212,255,0.15));
  display: block;
  margin: 0 auto;
}
.split-panel h3 {
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: var(--text-primary);
}
.split-panel p {
  font-size: 0.85rem;
  color: var(--text-dim);
}
.split-panel h3,
.split-panel p,
.split-panel .overstim-display,
.split-panel .body-decline-display {
  position: relative;
  z-index: 1;
}

/* ─── Body Decline Animation ─── */
.body-decline-display {
  text-align: center;
}
.body-decline-label {
  font-size: 0.85rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  transition: color 0.5s;
  min-height: 1.4em;
  margin-bottom: 6px;
}
.body-decline-canvas {
  width: 100%;
  max-width: 200px;
  height: 80px;
  display: block;
  margin: 0 auto;
}
.body-decline-legend {
  display: flex;
  justify-content: center;
  gap: 10px;
  font-size: 9px;
  letter-spacing: 0.05em;
  margin-top: 4px;
}
.body-legend-item {
  white-space: nowrap;
}

/* ─── Overstimulation Animation ─── */
.overstim-display {
  text-align: center;
}
.overstim-label {
  font-size: 0.85rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  transition: color 0.3s;
  min-height: 1.4em;
}
.overstim-pct {
  font-family: var(--font-mono);
  font-size: 1.6rem;
  font-weight: 700;
  color: #fff;
  margin: 4px 0;
  transition: color 0.15s;
}
.overstim-bar-track {
  width: 80%;
  max-width: 200px;
  height: 8px;
  background: #1C1F26;
  border-radius: 4px;
  margin: 0 auto 6px;
  overflow: hidden;
}
.overstim-bar-fill {
  height: 100%;
  width: 0%;
  border-radius: 4px;
  background: #fff;
  transition: width 0.08s linear, background 0.3s;
}
.overstim-blocks {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--text-dim);
  min-height: 1.2em;
}
.act.visible .panel-body {
  opacity: 0.6;
}
.act.visible .panel-mind {
  animation: pulse-glow 3s ease-in-out infinite alternate;
}
@keyframes pulse-glow {
  from { box-shadow: inset 0 0 40px rgba(169,112,255,0.08); }
  to   { box-shadow: inset 0 0 60px rgba(169,112,255,0.15); }
}

/* ─── Hero Quote ─── */
.hero-quote {
  text-align: center;
  padding: 32px 16px;
  border-left: none;
}
.hero-quote p {
  font-size: clamp(1.1rem, 3vw, 1.5rem);
  color: var(--text-primary);
  font-style: italic;
  line-height: 1.5;
  text-shadow: var(--glow-soft);
}
.hero-quote cite {
  display: block;
  margin-top: 12px;
  font-size: 0.8rem;
  color: var(--text-dim);
  font-style: normal;
}

/* ─── Viz Containers ─── */
.viz-container {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 24px;
  min-height: 200px;
}

/* ═══════════════════════════════════════════════ */
/* ACT 1 — Intensity Slider                       */
/* ═══════════════════════════════════════════════ */

.intensity-wrap {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.intensity-track-wrap {
  position: relative;
  height: 56px;
}
.intensity-track {
  position: absolute;
  inset: 0;
  border-radius: 4px;
  overflow: hidden;
  display: flex;
}
.intensity-zone-bg {
  transition: opacity 0.3s;
  opacity: 0.25;
}
.intensity-zone-bg.active {
  opacity: 0.6;
}
.intensity-zone-bg[data-zone="low"]  { flex: 5; background: linear-gradient(90deg, #065f46, #34D399); }
.intensity-zone-bg[data-zone="med"]  { flex: 3; background: linear-gradient(90deg, #92400e, #FBBF24); }
.intensity-zone-bg[data-zone="high"] { flex: 2; background: linear-gradient(90deg, #991b1b, #F87171); }

.intensity-slider {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  cursor: pointer;
  z-index: 2;
}
.intensity-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 28px;
  height: 52px;
  border-radius: 4px;
  background: var(--cyan);
  border: 2px solid var(--bg);
  box-shadow: var(--glow-cyan), 0 0 24px #00FFFF44;
  cursor: grab;
}
.intensity-slider::-moz-range-thumb {
  width: 28px;
  height: 52px;
  border-radius: 4px;
  background: var(--cyan);
  border: 2px solid var(--bg);
  box-shadow: var(--glow-cyan);
  cursor: grab;
}

.intensity-labels {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--text-dim);
  text-transform: uppercase;
}

.intensity-value {
  text-align: center;
  font-size: 3rem;
  font-weight: 700;
  color: var(--cyan);
  text-shadow: var(--glow-cyan);
  line-height: 1;
}

.intensity-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 20px;
  transition: border-color 0.3s;
}
.intensity-card[data-zone="low"]  { border-color: #34D39966; }
.intensity-card[data-zone="med"]  { border-color: #FBBF2466; }
.intensity-card[data-zone="high"] { border-color: #F8717166; }

.intensity-card-label {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.intensity-card[data-zone="low"]  .intensity-card-label { color: var(--green); }
.intensity-card[data-zone="med"]  .intensity-card-label { color: var(--amber); }
.intensity-card[data-zone="high"] .intensity-card-label { color: var(--red); }

.intensity-card-row {
  display: flex;
  justify-content: space-between;
  padding: 4px 0;
  font-size: 0.82rem;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
}
.intensity-card-row:last-child { border-bottom: none; }
.intensity-card-row .label { color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; }

.intensity-zone-icon {
  width: 24px;
  height: 24px;
  object-fit: contain;
  vertical-align: middle;
  margin-right: 6px;
}

/* ═══════════════════════════════════════════════ */
/* ACT 2 — Mismatch Grid                          */
/* ═══════════════════════════════════════════════ */

.mismatch-grid-wrap {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.mismatch-axis-label {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-align: center;
}

.mismatch-grid {
  display: grid;
  grid-template-columns: auto repeat(3, 1fr);
  grid-template-rows: auto repeat(3, 1fr);
  gap: 4px;
  max-width: 420px;
  margin: 0 auto;
}
.mismatch-header {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: 6px;
}
.mismatch-corner { }

.mismatch-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 1.3rem;
  min-width: 80px;
  min-height: 80px;
}
.mismatch-cell:hover {
  border-color: var(--accent);
  transform: scale(1.04);
}
.mismatch-cell.matched {
  border-color: #34D39966;
  background: rgba(52,211,153,0.06);
}
.mismatch-cell.mismatched {
  border-color: #F8717133;
  background: rgba(248,113,113,0.04);
}
.mismatch-cell.mild {
  border-color: #FBBF2433;
  background: rgba(251,191,36,0.04);
}

.mismatch-cell-icon {
  width: 40px;
  height: 40px;
  object-fit: contain;
}
.mismatch-cell-label {
  font-size: 9px;
  color: var(--text-dim);
  margin-top: 4px;
  text-align: center;
  line-height: 1.2;
}

.mismatch-detail {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  font-size: 0.85rem;
  color: var(--text-muted);
  min-height: 60px;
  transition: border-color 0.3s;
}
.mismatch-detail.safe   { border-color: #34D39944; }
.mismatch-detail.danger { border-color: #F8717144; }
.mismatch-detail.warn   { border-color: #FBBF2444; }
.mismatch-detail-title {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.mismatch-detail.safe   .mismatch-detail-title { color: var(--green); }
.mismatch-detail.danger .mismatch-detail-title { color: var(--red); }
.mismatch-detail.warn   .mismatch-detail-title { color: var(--amber); }

/* ═══════════════════════════════════════════════ */
/* ACT 4 — Trade-off Cards                        */
/* ═══════════════════════════════════════════════ */

.tradeoff-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
@media (max-width: 640px) {
  .tradeoff-cards { grid-template-columns: 1fr; }
}

.tradeoff-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.3s;
  overflow: hidden;
  position: relative;
}
.tradeoff-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.tradeoff-card[data-level="low"]  { border-color: #34D39933; }
.tradeoff-card[data-level="med"]  { border-color: #FBBF2433; }
.tradeoff-card[data-level="high"] { border-color: #F8717133; }
.tradeoff-card.expanded[data-level="low"]  { border-color: #34D39966; }
.tradeoff-card.expanded[data-level="med"]  { border-color: #FBBF2466; }
.tradeoff-card.expanded[data-level="high"] { border-color: #F8717166; }

.tradeoff-header {
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.tradeoff-header img {
  width: 36px;
  height: 36px;
  object-fit: contain;
}
.tradeoff-header-text {
  flex: 1;
}
.tradeoff-level {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 700;
}
.tradeoff-card[data-level="low"]  .tradeoff-level { color: var(--green); }
.tradeoff-card[data-level="med"]  .tradeoff-level { color: var(--amber); }
.tradeoff-card[data-level="high"] .tradeoff-level { color: var(--red); }
.tradeoff-subtitle {
  font-size: 0.78rem;
  color: var(--text-dim);
  margin-top: 2px;
}
.tradeoff-toggle {
  font-size: 12px;
  color: var(--text-dim);
  transition: transform 0.3s;
}
.tradeoff-card.expanded .tradeoff-toggle {
  transform: rotate(180deg);
}

.tradeoff-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease-out;
  padding: 0 16px;
}
.tradeoff-card.expanded .tradeoff-body {
  max-height: 800px;
  padding: 0 16px 16px;
}

.tradeoff-section {
  margin-bottom: 12px;
}
.tradeoff-section:last-child {
  margin-bottom: 0;
}
.tradeoff-section-label {
  font-size: 9px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.tradeoff-section-label.gains { color: var(--green); }
.tradeoff-section-label.costs { color: var(--red); }
.tradeoff-section-label.best  { color: var(--cyan-dim); }

.tradeoff-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.tradeoff-list li {
  font-size: 0.8rem;
  color: var(--text-muted);
  padding: 3px 0;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.tradeoff-list li:last-child { border-bottom: none; }
.tradeoff-list li::before {
  content: '›';
  color: var(--text-dim);
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════ */
/* ACT 3 — Intensity Drift                        */
/* ═══════════════════════════════════════════════ */

.drift-wrap {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.drift-canvas-wrap {
  position: relative;
  width: 100%;
  height: 260px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.drift-canvas {
  width: 100%;
  height: 100%;
}

.drift-legend {
  display: flex;
  gap: 20px;
  justify-content: center;
  font-size: 11px;
  color: var(--text-dim);
}
.drift-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}
.drift-legend-swatch {
  width: 16px;
  height: 3px;
  border-radius: 2px;
}

.drift-controls {
  display: flex;
  gap: 8px;
  justify-content: center;
}
.drift-btn {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 6px 16px;
  border: 1px solid var(--border);
  border-radius: 3px;
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
}
.drift-btn:hover {
  border-color: var(--cyan-dim);
  color: var(--cyan-dim);
}

/* ─── Act 3 — Ego Trigger Icon ─── */
.drift-ego-icon {
  text-align: center;
  margin-bottom: 24px;
}
.drift-ego-img {
  width: 160px;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 12px rgba(248,113,113,0.2));
  display: block;
  margin: 0 auto;
}

.drift-pullquote {
  text-align: center;
  font-style: italic;
  color: var(--text-dim);
  font-size: 0.85rem;
  padding: 8px 0;
}

/* ═══════════════════════════════════════════════ */
/* ACT 8 — CTA                                    */
/* ═══════════════════════════════════════════════ */

.act--cta {
  text-align: center;
}
.cta-quote {
  margin-bottom: 32px;
}
.cta-quote p {
  font-size: clamp(1.2rem, 3vw, 1.6rem);
  color: var(--cyan);
  font-style: italic;
  text-shadow: var(--glow-cyan);
}
.thesis {
  font-size: 0.9rem;
  color: var(--text-muted);
  letter-spacing: 0.1em;
  margin-bottom: 40px;
}
.cta-hero {
  font-size: clamp(1.6rem, 5vw, 2.8rem);
  font-weight: 400;
  color: var(--text-primary);
  text-shadow: var(--glow-blue);
  line-height: 1.3;
  margin-bottom: 40px;
}
/* ─── Act 8 — CTA Hero Icon ─── */
.cta-hero-icon {
  margin-bottom: 32px;
}
.cta-hero-img {
  width: 200px;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 16px rgba(0,212,255,0.2));
  display: block;
  margin: 0 auto;
}

.cta-button {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 10px 28px;
  border: 1px solid var(--cyan-dim);
  border-radius: 4px;
  color: var(--cyan-dim);
  background: rgba(0,212,255,0.06);
  transition: all 0.2s;
}
.cta-button:hover {
  background: rgba(0,212,255,0.14);
  box-shadow: 0 0 20px rgba(0,212,255,0.15);
}

/* ─── Placeholders ─── */
.placeholder-card {
  text-align: center;
  padding: 48px 24px;
  border: 1px dashed var(--border);
  border-radius: 6px;
  color: var(--text-dim);
  font-size: 0.85rem;
  letter-spacing: 0.08em;
}

/* ═══════════════════════════════════════════════ */
/* ACT 5 — Training Mode Quadrant                 */
/* ═══════════════════════════════════════════════ */

.quadrant-wrap {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.quadrant-axes {
  position: relative;
}

.quadrant-axis-y {
  position: absolute;
  left: -4px;
  top: 50%;
  transform: translateX(-100%) rotate(-90deg);
  transform-origin: right center;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
  white-space: nowrap;
}
.quadrant-axis-x {
  text-align: center;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-top: 8px;
}

.quadrant-grid-wrap {
  position: relative;
  margin-left: 32px;
}

.quadrant-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 3px;
  aspect-ratio: 1.6;
  max-height: 360px;
  position: relative;
}

.quadrant-cell {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px 16px;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.3s ease;
  overflow: hidden;
}
.quadrant-cell::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.06;
  transition: opacity 0.3s;
}
.quadrant-cell:hover::before {
  opacity: 0.12;
}
.quadrant-cell.active::before {
  opacity: 0.15;
}
.quadrant-cell.active {
  border-color: var(--cell-accent);
  box-shadow: 0 0 20px color-mix(in srgb, var(--cell-accent) 25%, transparent);
}

/* Quadrant-specific accents */
.quadrant-cell[data-q="flow"]    { --cell-accent: var(--green);  border-radius: 0 0 0 6px; }
.quadrant-cell[data-q="drill"]   { --cell-accent: var(--cyan);   border-radius: 0 0 6px 0; }
.quadrant-cell[data-q="spar"]    { --cell-accent: var(--red);    border-radius: 6px 0 0 0; }
.quadrant-cell[data-q="comp"]    { --cell-accent: var(--amber);  border-radius: 0 6px 0 0; }

.quadrant-cell[data-q="flow"]::before  { background: radial-gradient(ellipse at 70% 70%, var(--green), transparent 70%); }
.quadrant-cell[data-q="drill"]::before { background: radial-gradient(ellipse at 30% 70%, var(--cyan), transparent 70%); }
.quadrant-cell[data-q="spar"]::before  { background: radial-gradient(ellipse at 70% 30%, var(--red), transparent 70%); }
.quadrant-cell[data-q="comp"]::before  { background: radial-gradient(ellipse at 30% 30%, var(--amber), transparent 70%); }

/* Abstract geometric shapes inside each quadrant */
.quadrant-geo {
  width: 48px;
  height: 48px;
  margin-bottom: 10px;
  opacity: 0.5;
  transition: opacity 0.3s, transform 0.4s;
}
.quadrant-cell:hover .quadrant-geo,
.quadrant-cell.active .quadrant-geo {
  opacity: 0.85;
  transform: scale(1.1);
}

.quadrant-cell-label {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--cell-accent);
  text-shadow: 0 0 10px color-mix(in srgb, var(--cell-accent) 40%, transparent);
  text-align: center;
}
.quadrant-cell-sub {
  font-size: 0.72rem;
  color: var(--text-dim);
  margin-top: 3px;
  text-align: center;
}

/* Y-axis labels on left side */
.quadrant-y-labels {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 28px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}
.quadrant-y-labels span {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  writing-mode: vertical-lr;
  transform: rotate(180deg);
}

/* X-axis labels below */
.quadrant-x-labels {
  display: flex;
  justify-content: space-between;
  margin-left: 32px;
  padding: 4px 0 0;
}
.quadrant-x-labels span {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.quadrant-detail {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  min-height: 72px;
  transition: border-color 0.3s;
}
.quadrant-detail-title {
  font-size: 12px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 8px;
  font-weight: 700;
}
.quadrant-detail-desc {
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.5;
}
.quadrant-detail-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 10px;
}
.quadrant-tag {
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 3px;
  border: 1px solid var(--border);
  color: var(--text-dim);
}

/* ─── CLA Center Circle ─── */
.cla-circle {
  position: absolute;
  /* Place at grid center — grid gap is 3px, so offset by half-gap */
  top: calc(50% + 1.5px);
  left: calc(50% + 1.5px);
  transform: translate(-50%, -50%);
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 1.5px solid var(--accent-soft);
  background: radial-gradient(circle, rgba(169,112,255,0.15) 0%, rgba(169,112,255,0.04) 60%, transparent 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 5;
  box-shadow: 0 0 16px rgba(169,112,255,0.2), inset 0 0 12px rgba(169,112,255,0.1);
  overflow: hidden;
  /* Breathing animation — slow inhale/exhale */
  animation: cla-breathe 7s ease-in-out infinite;
  /* Transition for the expand-to-card */
  transition: width 0.7s cubic-bezier(0.4,0,0.2,1),
              height 0.7s cubic-bezier(0.4,0,0.2,1),
              border-radius 0.7s cubic-bezier(0.4,0,0.2,1),
              background 0.7s cubic-bezier(0.4,0,0.2,1),
              border-color 0.3s,
              box-shadow 0.3s;
}
.cla-circle:hover {
  border-color: #c4a0ff;
  box-shadow: 0 0 28px rgba(169,112,255,0.35), inset 0 0 16px rgba(169,112,255,0.15);
  animation-play-state: paused;
}

@keyframes cla-breathe {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    box-shadow: 0 0 16px rgba(169,112,255,0.15), inset 0 0 12px rgba(169,112,255,0.08);
  }
  50% {
    transform: translate(-50%, -50%) scale(1.35);
    box-shadow: 0 0 32px rgba(169,112,255,0.3), inset 0 0 20px rgba(169,112,255,0.15);
  }
}

.cla-circle-label {
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-soft);
  font-weight: 700;
  text-shadow: 0 0 10px rgba(169,112,255,0.5);
  white-space: nowrap;
  text-align: center;
  transition: opacity 0.3s;
}

/* Expanded state */
.cla-circle.expanded {
  width: 92%;
  height: 88%;
  border-radius: 12px;
  background: radial-gradient(circle at 50% 40%, rgba(169,112,255,0.12) 0%, rgba(5,5,9,0.97) 60%);
  border-color: var(--accent-soft);
  box-shadow: 0 0 40px rgba(169,112,255,0.2);
  overflow-y: auto;
  animation: none; /* stop breathing when expanded */
  transform: translate(-50%, -50%) scale(1);
}
.cla-circle.expanded:hover {
  animation: none;
}

.cla-expanded-content {
  display: none;
  flex-direction: column;
  padding: 20px 24px;
  width: 100%;
  max-height: 100%;
  overflow-y: auto;
}
.cla-circle.expanded .cla-expanded-content {
  display: flex;
}
.cla-circle.expanded .cla-circle-label {
  display: none;
}

.cla-title {
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-soft);
  font-weight: 700;
  text-shadow: 0 0 12px rgba(169,112,255,0.4);
  margin-bottom: 4px;
}
.cla-subtitle {
  font-size: 0.78rem;
  color: var(--text-dim);
  font-style: italic;
  margin-bottom: 14px;
}
.cla-body {
  font-size: 0.8rem;
  color: var(--text-muted);
  line-height: 1.6;
}
.cla-body p {
  margin-bottom: 10px;
}
.cla-body .cla-joke {
  color: var(--text-dim);
  font-style: italic;
  font-size: 0.75rem;
  border-left: 2px solid var(--accent-soft);
  padding-left: 10px;
  margin: 10px 0;
}
.cla-link {
  display: inline-block;
  margin-top: 8px;
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent-soft);
  text-decoration: none;
  border: 1px solid rgba(169,112,255,0.3);
  padding: 5px 14px;
  border-radius: 3px;
  transition: all 0.2s;
}
.cla-link:hover {
  background: rgba(169,112,255,0.1);
  border-color: var(--accent-soft);
}
.cla-close {
  position: absolute;
  top: 8px;
  right: 12px;
  font-size: 14px;
  color: var(--text-dim);
  cursor: pointer;
  background: none;
  border: none;
  font-family: var(--font-mono);
  padding: 4px 8px;
  transition: color 0.2s;
  z-index: 6;
  display: none;
}
.cla-circle.expanded .cla-close {
  display: block;
}
.cla-close:hover {
  color: var(--accent-soft);
}

/* Dim the quadrant cells when CLA is expanded */
.quadrant-grid.cla-open .quadrant-cell {
  opacity: 0.15;
  pointer-events: none;
  transition: opacity 0.5s;
}

/* Hide ring elements (breathing replaces ring pulse) */
.cla-ring { display: none; }

/* ═══════════════════════════════════════════════ */
/* ACT 6 — Weekly Training Schedule               */
/* ═══════════════════════════════════════════════ */

.week-wrap {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.week-sliders {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}
.week-slider-group {
  flex: 1;
  min-width: 220px;
}
.week-slider-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 6px;
}
.week-slider-label {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}
.week-slider-value {
  font-family: var(--font-mono);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--cyan);
  text-shadow: var(--glow-cyan);
}

.week-slider-track {
  position: relative;
  height: 36px;
}
.week-slider-track input[type="range"] {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  cursor: pointer;
  z-index: 2;
}
.week-slider-track input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px;
  height: 32px;
  border-radius: 3px;
  background: var(--cyan);
  border: 2px solid var(--bg);
  box-shadow: var(--glow-cyan);
  cursor: grab;
}
.week-slider-track input[type="range"]::-moz-range-thumb {
  width: 20px;
  height: 32px;
  border-radius: 3px;
  background: var(--cyan);
  border: 2px solid var(--bg);
  box-shadow: var(--glow-cyan);
  cursor: grab;
}
.week-slider-bg {
  position: absolute;
  inset: 0;
  border-radius: 4px;
  overflow: hidden;
}

/* Target zone marker on intensity slider */
.week-target-zone {
  position: absolute;
  top: 0;
  height: 100%;
  border-left: 1px dashed var(--green);
  border-right: 1px dashed var(--green);
  background: rgba(52,211,153,0.06);
  pointer-events: none;
  z-index: 1;
}
.week-target-label {
  position: absolute;
  top: -16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--green);
  white-space: nowrap;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}
.week-day {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.week-day-label {
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-align: center;
  padding-bottom: 4px;
}
.week-slot {
  height: 32px;
  border-radius: 3px;
  border: 1px solid var(--border);
  background: var(--bg);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}
.week-slot.active {
  border-color: transparent;
}
.week-slot.active::after {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.7;
  border-radius: 2px;
}
.week-slot.active.low::after    { background: linear-gradient(135deg, #065f46, var(--green)); }
.week-slot.active.mid::after    { background: linear-gradient(135deg, #92400e, var(--amber)); }
.week-slot.active.high::after   { background: linear-gradient(135deg, #991b1b, var(--red)); box-shadow: 0 0 8px rgba(248,113,113,0.3); }

.week-slot-time {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 7px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
  z-index: 1;
  opacity: 0.6;
}
.week-slot.active .week-slot-time {
  color: rgba(255,255,255,0.8);
  opacity: 1;
}

.week-stats {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  justify-content: center;
}
.week-stat {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  color: var(--text-muted);
}
.week-stat-dot {
  width: 8px;
  height: 8px;
  border-radius: 2px;
}

.week-warning {
  text-align: center;
  padding: 10px;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--red);
  border: 1px solid var(--red);
  border-radius: 4px;
  background: rgba(248,113,113,0.06);
  opacity: 0;
  transform: scaleY(0);
  transition: all 0.3s ease;
}
.week-warning.visible {
  opacity: 1;
  transform: scaleY(1);
  animation: pulse-warn 1.5s ease-in-out infinite alternate;
}
@keyframes pulse-warn {
  from { box-shadow: 0 0 0px rgba(248,113,113,0); border-color: #F8717166; }
  to   { box-shadow: 0 0 16px rgba(248,113,113,0.3); border-color: var(--red); }
}

.week-note {
  text-align: center;
  font-size: 0.78rem;
  color: var(--text-dim);
  font-style: italic;
  min-height: 1.2em;
}

/* ═══════════════════════════════════════════════ */
/* ACT 7 — Violence Spectrum + Scatter            */
/* ═══════════════════════════════════════════════ */

/* ── Vertical Spectrum ── */
.vspectrum-wrap {
  display: flex;
  flex-direction: column;
  gap: 0;
  max-width: 640px;
  margin: 0 auto;
}
.vspectrum-row {
  display: flex;
  align-items: center;
  gap: 0;
  position: relative;
  transition: all 0.25s;
  cursor: pointer;
  padding: 6px 0;
  border-bottom: 1px solid var(--border);
}
.vspectrum-row:last-child { border-bottom: none; }
.vspectrum-row:hover {
  background: rgba(255,255,255,0.02);
}
.vspectrum-row.active {
  background: rgba(255,255,255,0.04);
}

/* Center layout: [JA right-aligned] [bar] [EN left-aligned] */
.vspectrum-ja {
  flex: 1;
  font-size: 0.78rem;
  color: var(--text-dim);
  text-align: right;
  padding-right: 12px;
}
.vspectrum-zone-bar {
  width: 6px;
  min-height: 32px;
  border-radius: 2px;
  flex-shrink: 0;
  transition: box-shadow 0.3s;
}
.vspectrum-row:hover .vspectrum-zone-bar,
.vspectrum-row.active .vspectrum-zone-bar {
  box-shadow: 0 0 10px var(--bar-color);
}
.vspectrum-en {
  flex: 1;
  font-size: 0.82rem;
  color: var(--text-muted);
  text-align: left;
  padding-left: 12px;
}
.vspectrum-row.active .vspectrum-en {
  color: var(--text-primary);
}
.vspectrum-row.active .vspectrum-ja {
  color: var(--text-muted);
}

/* Zone group headers */
.vspectrum-zone-header {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
  padding: 12px 0 4px;
  color: var(--text-dim);
  border-bottom: 1px solid var(--border);
}

/* Roaming "you are here" marker — right of center bar, nudged just below the main text */
.vspectrum-marker {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translateY(4px);
  margin-left: 8px;
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--cyan-dim);
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
  pointer-events: none;
}
.vspectrum-marker.visible {
  opacity: 1;
}

/* ── 2D Scatter ── */
.vscatter-wrap {
  position: relative;
}
.vscatter-canvas-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1.3;
  max-height: 480px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.vscatter-canvas {
  width: 100%;
  height: 100%;
}
.vscatter-detail {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 12px 16px;
  margin-top: 12px;
  font-size: 0.82rem;
  color: var(--text-muted);
  min-height: 40px;
  transition: border-color 0.3s;
}
.vscatter-detail-title {
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 4px;
  font-weight: 700;
}
.vscatter-legend {
  display: flex;
  gap: 16px;
  justify-content: center;
  margin-top: 10px;
  font-size: 10px;
  color: var(--text-dim);
}
.vscatter-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
}
.vscatter-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

/* ─── Responsive ─── */
@media (max-width: 640px) {
  .body-mind-split { flex-direction: column; }
  .split-divider { width: 100%; height: 1px; }
  .split-panel { padding: 24px 16px; }
  .act { padding: 60px 16px; }
  .mismatch-cell { min-width: 60px; min-height: 60px; font-size: 1rem; }
  .drift-canvas-wrap { height: 200px; }
  .quadrant-grid-wrap { margin-left: 24px; }
