    html += `<div class="mismatch-axis-label">${ja ? '\u30D1\u30FC\u30C8\u30CA\u30FC\u306E\u5F37\u5EA6 \u2192' : "Partner's Intensity \u2192"}</div>`;
    html += '<div class="mismatch-grid">';

    // Header row
    html += '<div class="mismatch-corner mismatch-header"></div>';
    for (let c = 0; c < 3; c++) {
      html += `<div class="mismatch-header">${lvl(c)}</div>`;
    }

    // Data rows
    for (let r = 0; r < 3; r++) {
      html += `<div class="mismatch-header" style="writing-mode:vertical-lr;transform:rotate(180deg);font-size:10px">${ja ? '\u3042\u306A\u305F' : 'You'}: ${lvl(r)}</div>`;
      for (let c = 0; c < 3; c++) {
        const cell = cells[r][c];
        html += `<div class="mismatch-cell ${cell.type}" data-r="${r}" data-c="${c}"><img src="${cell.icon}" alt="" class="mismatch-cell-icon"><div class="mismatch-cell-label">${(ja ? cell.ja.title : cell.en.title).split(' \u2014 ').pop()}</div></div>`;
      }
    }

    html += '</div>'; // grid
    html += `<div class="mismatch-detail" id="mm-detail"><span style="color:var(--text-dim);font-size:0.82rem">${ja ? '\u30BB\u30EB\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u8A73\u7D30\u3092\u898B\u308B' : 'Click a cell to see details'}</span></div>`;
    html += '</div>';

    container.innerHTML = html;

    // Attach click handlers
    container.querySelectorAll('.mismatch-cell').forEach((el) => {
      el.addEventListener('click', () => {
