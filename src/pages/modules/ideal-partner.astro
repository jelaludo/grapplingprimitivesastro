// ═══ Drift Viz ═══
function initDriftViz(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  const isJa = () => document.body.classList.contains('lang-ja');

  container.innerHTML = `
    <div class="drift-wrap">
      <div class="drift-canvas-wrap">
        <canvas id="drift-canvas" class="drift-canvas"></canvas>
      </div>
      <div class="drift-legend">
        <div class="drift-legend-item"><div class="drift-legend-swatch" style="background:#F87171"></div><span id="drift-leg-actual">${isJa() ? '\u5B9F\u969B\u306E\u5F37\u5EA6' : 'Actual Intensity'}</span></div>
        <div class="drift-legend-item"><div class="drift-legend-swatch" style="background:#34D399"></div><span id="drift-leg-ideal">${isJa() ? '\u7406\u60F3\u7684\u306A\u5F37\u5EA6' : 'Ideal Intensity'}</span></div>
      </div>
      <div class="drift-controls">
        <button class="drift-btn" id="drift-play">${isJa() ? '\u518D\u751F' : 'Play'}</button>
        <button class="drift-btn" id="drift-reset">${isJa() ? '\u30EA\u30BB\u30C3\u30C8' : 'Reset'}</button>
      </div>
      <div class="drift-pullquote">
        <span lang="en">"People start light but once they're about to get swept they ramp up and steamroll."</span>
        <span lang="ja">\u300C\u307F\u3093\u306A\u8EFD\u304F\u59CB\u3081\u308B\u304C\u3001\u30B9\u30A4\u30FC\u30D7\u3055\u308C\u305D\u3046\u306B\u306A\u308B\u3068\u5F37\u5EA6\u3092\u4E0A\u3052\u3066\u62BC\u3057\u6F70\u3059\u3002\u300D</span>
      </div>
    </div>
  `;

  const canvas = document.getElementById('drift-canvas');
  const ctx = canvas.getContext('2d');
  const playBtn = document.getElementById('drift-play');
  const resetBtn = document.getElementById('drift-reset');

  // Drift data: normalized 0-1 time, 0-100 intensity
  const actualPoints = [
    [0, 20], [0.1, 22], [0.2, 25], [0.3, 30],
    [0.38, 35],
    [0.42, 55],
    [0.48, 70],
    [0.55, 78], [0.65, 82], [0.75, 80],
    [0.85, 75], [0.95, 72], [1, 70]
  ];

  const idealPoints = [
    [0, 25], [0.1, 28], [0.2, 30], [0.3, 28],
    [0.4, 32], [0.5, 30], [0.6, 33], [0.7, 28],
    [0.8, 30], [0.9, 27], [1, 25]
  ];

  let animProgress = 0;
  let animId = null;
  let playing = false;

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function lerp(points, t) {
    for (let i = 0; i < points.length - 1; i++) {
      const [t0, v0] = points[i];
      const [t1, v1] = points[i + 1];
      if (t >= t0 && t <= t1) {
        const frac = (t - t0) / (t1 - t0);
        return v0 + (v1 - v0) * frac;
      }
    }
    return points[points.length - 1][1];
  }

  function draw() {
    const w = canvas.width / (window.devicePixelRatio || 1);
    const h = canvas.height / (window.devicePixelRatio || 1);
    const pad = { top: 24, right: 16, bottom: 32, left: 44 };
    const pw = w - pad.left - pad.right;
    const ph = h - pad.top - pad.bottom;

    ctx.clearRect(0, 0, w, h);

    // Axes
    ctx.strokeStyle = '#1C1F26';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad.left, pad.top);
    ctx.lineTo(pad.left, h - pad.bottom);
    ctx.lineTo(w - pad.right, h - pad.bottom);
    ctx.stroke();

    // Y labels
    ctx.fillStyle = '#6B7280';
    ctx.font = '12px Courier New';
    ctx.textAlign = 'right';
    for (let v = 0; v <= 100; v += 25) {
      const y = pad.top + ph * (1 - v / 100);
      ctx.fillText(v + '%', pad.left - 6, y + 3);
      if (v > 0 && v < 100) {
        ctx.strokeStyle = '#1C1F2633';
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(w - pad.right, y);
        ctx.stroke();
      }
    }

    // X label
    ctx.fillStyle = '#6B7280';
    ctx.textAlign = 'center';
    ctx.fillText(isJa() ? '\u30E9\u30A6\u30F3\u30C9\u306E\u6642\u9593 \u2192' : 'Time in Round \u2192', w / 2, h - 6);

    // Draw ego trigger zone
    if (animProgress > 0.38) {
      const triggerX = pad.left + 0.40 * pw;
      ctx.fillStyle = 'rgba(248,113,113,0.06)';
      ctx.fillRect(triggerX - 12, pad.top, 24, ph);
      ctx.fillStyle = '#F8717166';
      ctx.font = '12px Courier New';
      ctx.textAlign = 'center';
      ctx.fillText(isJa() ? '\u30A8\u30B4' : 'EGO', triggerX, pad.top + 14);
      ctx.fillText('\u2193', triggerX, pad.top + 24);
    }

    function drawLine(points, color, maxT) {
      ctx.strokeStyle = color;
      ctx.lineWidth = 2.5;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      ctx.beginPath();
      const steps = 100;
      let started = false;
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        if (t > maxT) break;
        const x = pad.left + t * pw;
        const v = lerp(points, t);
        const y = pad.top + ph * (1 - v / 100);
        if (!started) { ctx.moveTo(x, y); started = true; }
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    // Ideal line (full, dimmer)
    drawLine(idealPoints, '#34D39988', animProgress);

    // Actual line
    drawLine(actualPoints, '#F87171', animProgress);
  }

  function animate() {
    if (!playing) return;
    animProgress += 0.006;
    if (animProgress >= 1) {
      animProgress = 1;
      playing = false;
    }
    draw();
    if (playing) animId = requestAnimationFrame(animate);
  }

  function play() {
    if (playing) return;
    if (animProgress >= 1) animProgress = 0;
    playing = true;
    animate();
  }

  function reset() {
    playing = false;
    if (animId) cancelAnimationFrame(animId);
    animProgress = 0;
    draw();
  }

  playBtn.addEventListener('click', play);
  resetBtn.addEventListener('click', reset);

  // Auto-play when section becomes visible
  const section = document.getElementById('act-3');
  if (section) {
    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && animProgress === 0) {
        setTimeout(play, 400);
      }
    }, { threshold: 0.3 });
    obs.observe(section);
  }

  window.addEventListener('resize', () => { resize(); draw(); });
  resize();
  draw();

  // Re-render on language change
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(draw, 10));
}

// ═══ Scroll Reveal + Deep Link Hash Tracking ═══
(function() {
  const acts = document.querySelectorAll('.act');
  let currentAct = null;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Track the most visible act for deep linking
        const actId = e.target.id;
        if (actId && actId !== currentAct) {
          currentAct = actId;
          history.replaceState(null, '', location.pathname + location.search + '#' + actId);
        }
      }
    });
  }, { threshold: 0.15 });
  acts.forEach((a) => observer.observe(a));

  // Restore scroll position from hash on load
  const hash = location.hash.replace('#', '');
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      // Small delay to let layout settle
      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth' });
        target.classList.add('visible');
      }, 200);
    }
  }
})();

