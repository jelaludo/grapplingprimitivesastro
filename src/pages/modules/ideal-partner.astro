<script define:vars={{ imgBase }}>
// ═══ Intensity Viz ═══
function initIntensityViz(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  const zones = [
    {
      key: 'low', range: [0, 2],
      en: { label: 'Cooperative / Basic Patterns Learning', body: 'Relaxed, exploratory', mindset: 'Learning, experimenting', icon: imgBase + 'icon_400x_0002_FlowCooperative.png' },
      ja: { label: '協力的 / 基本パターン学習', body: 'リラックス、探索的', mindset: '学習、実験', icon: imgBase + 'icon_400x_0002_FlowCooperative.png' }
    },
    {
      key: 'low', range: [3, 5],
      en: { label: 'Cooperative / Flow Rolling', body: 'Relaxed, slight resistance', mindset: 'Exploring, testing lightly', icon: imgBase + 'icon_400x_0002_FlowCooperative.png' },
      ja: { label: '協力的 / フローロール', body: 'リラックス、軽い抵抗', mindset: '探索、軽いテスト', icon: imgBase + 'icon_400x_0002_FlowCooperative.png' }
    },
    {
      key: 'med', range: [6, 8],
      en: { label: 'Technical / Pressure-Testing', body: 'Elevated heart rate, focused', mindset: 'Problem-solving under resistance', icon: imgBase + 'icon_400x_0003_FlowWithIntensity.png' },
      ja: { label: 'テクニカル / プレッシャーテスト', body: '心拍数上昇、集中', mindset: '抵抗下での問題解決', icon: imgBase + 'icon_400x_0003_FlowWithIntensity.png' }
    },
    {
      key: 'high', range: [9, 10],
      en: { label: 'Competitive / Almost Full Resistance', body: 'Max output, adrenaline', mindset: "Won't give you an inch", icon: imgBase + 'icon_400x_0005_FlowWithClash.png' },
      ja: { label: '競技的 / ほぼ全力抵抗', body: '最大出力、アドレナリン', mindset: '一歩も譲らない', icon: imgBase + 'icon_400x_0005_FlowWithClash.png' }
    }
  ];

  function getZone(val) {
    const v = Math.round(val);
    for (const z of zones) {
      if (v >= z.range[0] && v <= z.range[1]) return z;
    }
    return zones[0];
  }

  container.innerHTML = `
    <div class="intensity-wrap">
      <div class="intensity-value" id="int-val">0</div>
      <div class="intensity-track-wrap">
        <div class="intensity-track">
          <div class="intensity-zone-bg active" data-zone="low"></div>
          <div class="intensity-zone-bg" data-zone="med"></div>
          <div class="intensity-zone-bg" data-zone="high"></div>
        </div>
        <input type="range" class="intensity-slider" id="int-slider" min="0" max="10" step="1" value="0">
      </div>
      <div class="intensity-labels">
        <span>0</span><span>5</span><span>10</span>
      </div>
      <div class="intensity-card" id="int-card" data-zone="low">
        <div class="intensity-card-label" id="int-card-label"></div>
        <div id="int-card-body"></div>
      </div>
    </div>
  `;

  const slider = document.getElementById('int-slider');
  const valDisplay = document.getElementById('int-val');
  const card = document.getElementById('int-card');
  const cardLabel = document.getElementById('int-card-label');
  const cardBody = document.getElementById('int-card-body');
  const bgZones = container.querySelectorAll('.intensity-zone-bg');

  function update() {
    const v = parseInt(slider.value, 10);
    const zone = getZone(v);
    valDisplay.textContent = v;

    // Color the value display
    const colors = { low: '#34D399', med: '#FBBF24', high: '#F87171' };
    valDisplay.style.color = colors[zone.key];
    valDisplay.style.textShadow = `0 0 12px ${colors[zone.key]}88`;

    // Highlight active zone background
    bgZones.forEach((bg) => {
      bg.classList.toggle('active', bg.dataset.zone === zone.key);
    });

    // Update card
    card.dataset.zone = zone.key;
    const isJa = document.body.classList.contains('lang-ja');
    const d = isJa ? zone.ja : zone.en;
    cardLabel.innerHTML = `<img src="${d.icon}" alt="" class="intensity-zone-icon"> ${d.label}`;
    cardBody.innerHTML = `
      <div class="intensity-card-row"><span class="label">${isJa ? '身体状態' : 'Body State'}</span><span>${d.body}</span></div>
      <div class="intensity-card-row"><span class="label">${isJa ? 'マインドセット' : 'Mindset'}</span><span>${d.mindset}</span></div>
    `;
  }

  slider.addEventListener('input', update);

  // Re-render on language change
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(update, 10));

  update();
}

