        const cell = cells[r][c];
        const d = isJa() ? cell.ja : cell.en;
        const detail = document.getElementById('mm-detail');
        const cls = cell.type === 'matched' ? 'safe' : cell.type === 'mismatched' ? 'danger' : 'warn';
        detail.className = `mismatch-detail ${cls}`;
