// ═══ Weekly Training Schedule Viz ═══
function initWeekViz(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  const isJa = () => document.body.classList.contains('lang-ja');

  const daysEn = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const daysJa = ['月','火','水','木','金','土','日'];
  const slotsEn = ['AM','PM','EVE'];
  const slotsJa = ['朝','午後','夜'];

  let sessionsPerWeek = 4;
  let hardPct = 15;

  function distribute(total, hard) {
    // Build an array of 21 slots (7 days × 3 slots)
    // Fill with intensity levels based on total and hard%
    const slots = new Array(21).fill(null); // null = empty

    const numHard = Math.max(0, Math.round(total * hard / 100));
    const numMid = Math.round((total - numHard) * 0.35);
    const numLow = total - numHard - numMid;

    // Assign intensities
    const intensities = [];
    for (let i = 0; i < numLow; i++) intensities.push('low');
    for (let i = 0; i < numMid; i++) intensities.push('mid');
    for (let i = 0; i < numHard; i++) intensities.push('high');

    // Shuffle
    for (let i = intensities.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [intensities[i], intensities[j]] = [intensities[j], intensities[i]];
    }

    // Distribute across days — prioritize spreading across days first
    // Slot order per day: 0=morning, 1=afternoon, 2=evening
    // Fill pattern: first pass = 1 per day, second = 2 per day, third = 3
    const dayOrder = [0,1,2,3,4,5,6]; // Mon-Sun
    let placed = 0;

    // Pass 1: morning slots
    for (const d of dayOrder) {
      if (placed >= total) break;
      slots[d * 3 + 1] = intensities[placed++]; // afternoon first (primary session)
    }
    // Pass 2: morning slots for overflow
    for (const d of dayOrder) {
      if (placed >= total) break;
      if (slots[d * 3 + 1] !== null) { // only add 2nd session if day has 1st
        slots[d * 3 + 0] = intensities[placed++]; // morning
      }
    }
    // Pass 3: evening slots
    for (const d of dayOrder) {
      if (placed >= total) break;
      if (slots[d * 3 + 0] !== null) { // only add 3rd if day has 2nd
        slots[d * 3 + 2] = intensities[placed++]; // evening
      }
    }

    return slots;
  }

  // Use a seeded random for consistency within the same parameters
  let seed = 42;
  function seededRandom() {
    seed = (seed * 16807) % 2147483647;
    return (seed - 1) / 2147483646;
  }

  function distributeSeeded(total, hard) {
    seed = total * 100 + hard; // deterministic seed from params
    const slots = new Array(21).fill(null);

    const numHard = Math.max(0, Math.round(total * hard / 100));
    const numMid = Math.round((total - numHard) * 0.35);
    const numLow = total - numHard - numMid;

    const intensities = [];
    for (let i = 0; i < numLow; i++) intensities.push('low');
    for (let i = 0; i < numMid; i++) intensities.push('mid');
    for (let i = 0; i < numHard; i++) intensities.push('high');

    // Seeded shuffle
    for (let i = intensities.length - 1; i > 0; i--) {
      const j = Math.floor(seededRandom() * (i + 1));
      [intensities[i], intensities[j]] = [intensities[j], intensities[i]];
    }

    const dayOrder = [0,1,2,3,4,5,6];
    let placed = 0;

    for (const d of dayOrder) {
      if (placed >= total) break;
      slots[d * 3 + 1] = intensities[placed++];
    }
    for (const d of dayOrder) {
      if (placed >= total) break;
      if (slots[d * 3 + 1] !== null) {
        slots[d * 3 + 0] = intensities[placed++];
      }
    }
    for (const d of dayOrder) {
      if (placed >= total) break;
      if (slots[d * 3 + 0] !== null) {
        slots[d * 3 + 2] = intensities[placed++];
      }
    }

    return slots;
  }

  function render() {
    const ja = isJa();
    const days = ja ? daysJa : daysEn;
    const slotNames = ja ? slotsJa : slotsEn;

    let html = `<div class="week-wrap">`;

    // Sliders
    html += `<div class="week-sliders">`;

    // Sessions slider
    html += `<div class="week-slider-group">
      <div class="week-slider-header">
        <span class="week-slider-label">${ja ? 'セッション / 週' : 'Sessions / Week'}</span>
        <span class="week-slider-value" id="week-sess-val">${sessionsPerWeek}</span>
      </div>
      <div class="week-slider-track">
        <div class="week-slider-bg" style="background:linear-gradient(90deg, #065f46 0%, #34D399 33%, #FBBF24 66%, #F87171 100%);opacity:0.2;border-radius:4px;"></div>
        <input type="range" id="week-sess-slider" min="1" max="21" step="1" value="${sessionsPerWeek}">
      </div>
    </div>`;

    // Hard % slider
    html += `<div class="week-slider-group">
      <div class="week-slider-header">
        <span class="week-slider-label">${ja ? 'ハードトレーニング %' : 'Hard Training %'}</span>
        <span class="week-slider-value" id="week-hard-val">${hardPct}%</span>
      </div>
      <div class="week-slider-track" style="position:relative;">
        <div class="week-slider-bg" style="background:linear-gradient(90deg, #34D399 0%, #FBBF24 30%, #F87171 60%, #FF3333 100%);opacity:0.2;border-radius:4px;"></div>
        <div class="week-target-zone" id="week-target" style="left:10%;width:10%;"><span class="week-target-label">${ja ? '目標' : 'Target'} 10-20%</span></div>
        <input type="range" id="week-hard-slider" min="0" max="100" step="5" value="${hardPct}">
      </div>
    </div>`;

    html += `</div>`;

    // Week grid
    html += `<div class="week-grid" id="week-grid">`;
    for (let d = 0; d < 7; d++) {
      html += `<div class="week-day"><div class="week-day-label">${days[d]}</div>`;
      for (let s = 0; s < 3; s++) {
        html += `<div class="week-slot" data-day="${d}" data-slot="${s}"><span class="week-slot-time">${slotNames[s]}</span></div>`;
      }
      html += `</div>`;
    }
    html += `</div>`;

    // Stats
    html += `<div class="week-stats" id="week-stats"></div>`;

    // Warning
    html += `<div class="week-warning" id="week-warn"><span lang="en">⚠ UNSUSTAINABLE — injury risk, CNS fatigue, burnout</span><span lang="ja">⚠ 持続不可能 — 怪我のリスク、中枢神経疲労、バーンアウト</span></div>`;

    // Note
    html += `<div class="week-note" id="week-note"></div>`;

    html += `</div>`;

    container.innerHTML = html;

    const sessSlider = document.getElementById('week-sess-slider');
    const hardSlider = document.getElementById('week-hard-slider');
    const sessVal = document.getElementById('week-sess-val');
    const hardVal = document.getElementById('week-hard-val');
    const grid = document.getElementById('week-grid');
    const stats = document.getElementById('week-stats');
    const warn = document.getElementById('week-warn');
    const note = document.getElementById('week-note');

    function update() {
      sessionsPerWeek = parseInt(sessSlider.value, 10);
      hardPct = parseInt(hardSlider.value, 10);

      sessVal.textContent = sessionsPerWeek;
      hardVal.textContent = hardPct + '%';

      // Color the session value based on load
      if (sessionsPerWeek <= 5) {
        sessVal.style.color = 'var(--green)';
        sessVal.style.textShadow = '0 0 12px #34D39988';
      } else if (sessionsPerWeek <= 10) {
        sessVal.style.color = 'var(--cyan)';
        sessVal.style.textShadow = 'var(--glow-cyan)';
      } else if (sessionsPerWeek <= 15) {
        sessVal.style.color = 'var(--amber)';
        sessVal.style.textShadow = '0 0 12px #FBBF2488';
      } else {
        sessVal.style.color = 'var(--red)';
        sessVal.style.textShadow = '0 0 12px #F8717188';
      }

      // Color the hard% value
      if (hardPct <= 20) {
        hardVal.style.color = 'var(--green)';
        hardVal.style.textShadow = '0 0 12px #34D39988';
      } else if (hardPct <= 30) {
        hardVal.style.color = 'var(--amber)';
        hardVal.style.textShadow = '0 0 12px #FBBF2488';
      } else {
        hardVal.style.color = 'var(--red)';
        hardVal.style.textShadow = '0 0 12px #F8717188';
      }

      // Distribute sessions
      const slots = distributeSeeded(sessionsPerWeek, hardPct);

      // Update grid
      const slotEls = grid.querySelectorAll('.week-slot');
      let countLow = 0, countMid = 0, countHigh = 0;
      slotEls.forEach((el, i) => {
        const intensity = slots[i];
        el.classList.remove('active', 'low', 'mid', 'high');
        if (intensity) {
          el.classList.add('active', intensity);
          if (intensity === 'low') countLow++;
          else if (intensity === 'mid') countMid++;
          else countHigh++;
        }
      });

      // Stats
      const ja = isJa();
      stats.innerHTML = `
        <div class="week-stat"><div class="week-stat-dot" style="background:var(--green);"></div>${ja ? '低' : 'Low'}: ${countLow}</div>
        <div class="week-stat"><div class="week-stat-dot" style="background:var(--amber);"></div>${ja ? '中' : 'Mid'}: ${countMid}</div>
        <div class="week-stat"><div class="week-stat-dot" style="background:var(--red);"></div>${ja ? '高' : 'High'}: ${countHigh}</div>
      `;

      // Warning
      const unsustainable = (hardPct > 30 && sessionsPerWeek > 14) || sessionsPerWeek >= 20;
      warn.classList.toggle('visible', unsustainable);

      // Note about multi-session days
      const daysUsed = new Set();
      slots.forEach((s, i) => { if (s) daysUsed.add(Math.floor(i / 3)); });
      const maxPerDay = Math.ceil(sessionsPerWeek / 7);

      if (sessionsPerWeek > 14) {
        note.textContent = ja ? '⚡ 1日3セッション — プロ選手のスケジュール' : '⚡ 3 sessions/day — pro athlete schedule';
        note.style.color = 'var(--red)';
      } else if (sessionsPerWeek > 7) {
        note.textContent = ja ? '↑ 一部の日は2セッション' : '↑ Some days have 2 sessions';
        note.style.color = 'var(--amber)';
      } else if (sessionsPerWeek >= 5) {
        note.textContent = ja ? '◆ 週5+は回復日が必要' : '◆ 5+/week needs planned recovery days';
        note.style.color = 'var(--text-dim)';
      } else {
        note.textContent = '';
      }
    }

    sessSlider.addEventListener('input', update);
    hardSlider.addEventListener('input', update);
    update();
  }

  render();
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(render, 10));
}

// ═══ Violence Spectrum Viz (1D faithful to 2019) ═══
function initViolenceSpectrum(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  const isJa = () => document.body.classList.contains('lang-ja');

  // Data: top = most violent, bottom = most peaceful
  // zone: 'none' (no rules), 'rules', 'collab'
  const items = [
    { zone: 'none',  color: '#991b1b', en: 'Warzone',                              ja: '交戦地帯' },
    { zone: 'none',  color: '#B91C1C', en: 'Organized Crime, Murder etc.',          ja: '組織犯罪・暗殺未遂など' },
    { zone: 'none',  color: '#DC2626', en: 'Gang Violence',                         ja: '暴力団' },
    { zone: 'none',  color: '#EF4444', en: 'Mugging',                               ja: '強盗' },
    { zone: 'none',  color: '#F87171', en: 'Street Fight / Bar Brawl',              ja: '喧嘩' },
    { zone: 'rules', color: '#B45309', en: 'Vale Tudo, no Gloves',                  ja: 'バーリトゥード、グローブ無し' },
    { zone: 'rules', color: '#D97706', en: 'MMA',                                   ja: '総合格闘技試合' },
    { zone: 'rules', color: '#F59E0B', en: 'Grappling Competition, high-level',     ja: 'グラップリング試合・プロ級' },
    { zone: 'rules', color: '#FBBF24', en: 'Grappling Competition, local',          ja: 'グラップリング試合' },
    { zone: 'collab', color: '#059669', en: 'Hard Sparring',                         ja: 'ハード・スパー',           marker: { en: 'hard, not reckless', ja: '激しく、無謀にあらず' } },
    { zone: 'collab', color: '#10B981', en: 'Light Sparring',                        ja: 'ライト・スパー',           marker: { en: 'chill out', ja: 'リラックス' } },
    { zone: 'collab', color: '#34D399', en: 'Situation Sparring',                        ja: 'シチュエーション・スパー' },
    { zone: 'collab', color: '#6EE7B7', en: 'Repetitions',                           ja: '打ち込み' },
    { zone: 'collab', color: '#A7F3D0', en: 'Research',                              ja: '研究' },
  ];

  // Items the roaming marker can appear on
  const markerPool = [
    { idx: 0,  en: '...',                 ja: '...' },
    { idx: 1,  en: 'no thanks',           ja: 'いいえ結構' },
    { idx: 2,  en: 'what a scourge',      ja: 'なんという惨禍' },
    { idx: 3,  en: 'sorry that happened', ja: '大変でしたね' },
    { idx: 4,  en: 'nothing to gain here',ja: 'ここには何もない' },
    { idx: 5,  en: 'hardcore!',           ja: 'ハードコア！' },
    { idx: 6,  en: 'or here?',            ja: 'それともここ？' },
    { idx: 7,  en: 'you are here',        ja: 'ここにいる' },
    { idx: 8,  en: 'you are here',        ja: 'ここにいる' },
    { idx: 9,  en: 'hard, not reckless',  ja: '激しく、無謀にあらず' },
    { idx: 10, en: 'chill out',           ja: 'リラックス' },
    { idx: 11, en: 'here?',              ja: 'ここ？' },
    { idx: 12, en: 'you are here',       ja: 'ここにいる' },
    { idx: 13, en: 'you are here',       ja: 'ここにいる' },
  ];

  const zoneLabels = {
    none:  { en: 'No Rules', ja: 'ルール無し' },
    rules: { en: 'Rules',    ja: 'ルール有り' },
    collab:{ en: 'Collaboration', ja: '協力' }
  };

  let markerInterval = null;

  function render() {
    if (markerInterval) clearInterval(markerInterval);
    const ja = isJa();
    let html = '<div class="vspectrum-wrap">';

    let lastZone = null;
    items.forEach((item, idx) => {
      if (item.zone !== lastZone) {
        const zl = ja ? zoneLabels[item.zone].ja : zoneLabels[item.zone].en;
        html += `<div class="vspectrum-zone-header" style="color:${item.color};">${zl}</div>`;
        lastZone = item.zone;
      }

      html += `<div class="vspectrum-row" data-idx="${idx}">`;
      html += `<span class="vspectrum-ja">${item.ja}</span>`;
      html += `<div class="vspectrum-zone-bar" style="background:${item.color};--bar-color:${item.color};"></div>`;
      html += `<span class="vspectrum-en">${item.en}</span>`;
      html += `<span class="vspectrum-marker" data-idx="${idx}">← </span>`;
      html += `</div>`;
    });

    html += '</div>';
    container.innerHTML = html;

    // Hover highlight
    container.querySelectorAll('.vspectrum-row').forEach(el => {
      el.addEventListener('mouseenter', () => {
        container.querySelectorAll('.vspectrum-row').forEach(r => r.classList.remove('active'));
        el.classList.add('active');
      });
    });

    // Roaming marker animation
    const allMarkers = container.querySelectorAll('.vspectrum-marker');
    let currentMarkerEl = null;

    function showRandomMarker() {
      // Pick a random item from the pool
      const pick = markerPool[Math.floor(Math.random() * markerPool.length)];
      const text = isJa() ? pick.ja : pick.en;

      // Hide current
      if (currentMarkerEl) {
        currentMarkerEl.classList.remove('visible');
      }

      // Find the marker element for this index
      allMarkers.forEach(el => {
        if (parseInt(el.dataset.idx, 10) === pick.idx) {
          el.textContent = '← ' + text;
          // Small delay so the fade-out can happen first
          setTimeout(() => {
            el.classList.add('visible');
            currentMarkerEl = el;
          }, 400);
        }
      });
    }

    // Start the roaming cycle
    showRandomMarker();
    markerInterval = setInterval(showRandomMarker, 2800);
  }

  render();
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(render, 10));
}

// ═══ Violence Scatter Viz (2D: Intensity × Rules/Consent) ═══
function initViolenceScatter(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  const isJa = () => document.body.classList.contains('lang-ja');

  // Each point: x = rules/consent (0=none, 1=full), y = intensity (0=low, 1=lethal)
  // size = relative visual weight, zone for color
  const points = [
    { id: 'research',     x: 0.95, y: 0.05, zone: 'collab', en: 'Research',                          ja: '研究',                    desc_en: 'Pure exploration. Zero resistance, full consent, full safety. Learning at its most collaborative.', desc_ja: '純粋な探索。抵抗ゼロ、完全な同意と安全。最も協力的な学習。' },
    { id: 'reps',         x: 0.90, y: 0.10, zone: 'collab', en: 'Repetitions',                        ja: '打ち込み',                desc_en: 'Drilling patterns with a compliant partner. Building muscle memory in a safe, structured setting.', desc_ja: '従順なパートナーとのパターン練習。安全で構造化された環境で筋肉記憶を構築。' },
    { id: 'situspar',     x: 0.85, y: 0.22, zone: 'collab', en: 'Situation Sparring',                 ja: 'シチュエーション・スパー', desc_en: 'Resistance drilling from specific positions. Consent is explicit, intensity is controlled, reset is instant.', desc_ja: '特定のポジションからの抵抗ドリル。同意は明示的、強度は制御され、即座にリセット可能。' },
    { id: 'lightspar',    x: 0.80, y: 0.32, zone: 'collab', en: 'Light Sparring',                     ja: 'ライト・スパー',          desc_en: 'Flow rolling with moderate resistance. Both partners modulate intensity by mutual agreement. The sweet spot.', desc_ja: 'フローロールで適度な抵抗。両パートナーが合意により強度を調整。スイートスポット。' },
    { id: 'hardspar',     x: 0.72, y: 0.48, zone: 'collab', en: 'Hard Sparring',                      ja: 'ハード・スパー',          desc_en: 'Near-competition intensity but with the safety net of trust, tap, and reset. The edge of collaboration.', desc_ja: '試合に近い強度だが、信頼・タップ・リセットのセーフティネット付き。協力の境界線。' },
    { id: 'graplocal',    x: 0.65, y: 0.55, zone: 'rules',  en: 'Grappling Comp (local)',             ja: 'グラップリング試合',      desc_en: 'Full resistance within a ruleset. Referee, time limit, weight class. Consent is given by entering.', desc_ja: 'ルール内での全力抵抗。レフェリー、制限時間、体重階級。参加することで同意。' },
    { id: 'grapro',       x: 0.60, y: 0.62, zone: 'rules',  en: 'Grappling Comp (pro)',               ja: 'グラップリング・プロ級',  desc_en: 'Elite competition. Higher stakes, more aggressive rule interpretation, career implications.', desc_ja: 'エリート競技。より高いステークス、攻撃的なルール解釈、キャリアへの影響。' },
    { id: 'mma',          x: 0.50, y: 0.72, zone: 'rules',  en: 'MMA',                                ja: '総合格闘技',              desc_en: 'Strikes + grappling within athletic commission rules. Referee can stop. Significant injury risk accepted.', desc_ja: '打撃＋組技をアスレチックコミッション規則内で。レフェリーが止められる。重大な怪我リスクを受容。' },
    { id: 'valetudo',     x: 0.35, y: 0.78, zone: 'rules',  en: 'Vale Tudo, no Gloves',               ja: 'バーリトゥード',          desc_en: 'Minimal rules, no gloves. The old days. Consent exists but protection is almost gone.', desc_ja: '最小限のルール、グローブなし。昔の時代。同意はあるが保護はほぼない。' },
    { id: 'streetfight',  x: 0.15, y: 0.65, zone: 'none',   en: 'Street Fight / Bar Brawl',           ja: '喧嘩',                    desc_en: 'Mutual but unregulated. No referee, no tap, no weight class. Ego-driven escalation with no safety net.', desc_ja: '相互だが規制なし。レフェリーなし、タップなし、体重階級なし。セーフティネットのないエゴ主導のエスカレーション。' },
    { id: 'mugging',      x: 0.05, y: 0.60, zone: 'none',   en: 'Mugging',                            ja: '強盗',                    desc_en: 'Non-consensual. One-sided intent. The victim has no agreed-upon rules and no way to tap out.', desc_ja: '非合意。一方的な意図。被害者には合意されたルールもタップアウトの方法もない。' },
    { id: 'gang',         x: 0.05, y: 0.78, zone: 'none',   en: 'Gang Violence',                      ja: '暴力団',                  desc_en: 'Organized, non-consensual, asymmetric. Violence as tool for territorial control.', desc_ja: '組織的、非合意、非対称。領域支配のための暴力。' },
    { id: 'crime',        x: 0.03, y: 0.88, zone: 'none',   en: 'Organized Crime, Murder',             ja: '組織犯罪・暗殺',         desc_en: 'Premeditated lethal violence. Zero consent, zero rules, zero reversibility.', desc_ja: '計画的な致命的暴力。同意ゼロ、ルールゼロ、可逆性ゼロ。' },
    { id: 'warzone',      x: 0.02, y: 0.98, zone: 'none',   en: 'Warzone',                            ja: '交戦地帯',                desc_en: 'State-level violence. Weapons, explosives, collateral damage. The furthest point from your gym.', desc_ja: '国家レベルの暴力。武器、爆発物、巻き添え被害。あなたのジムから最も遠い地点。' },
  ];

  const zoneColors = {
    collab: '#34D399',
    rules:  '#FBBF24',
    none:   '#F87171'
  };

  function render() {
    const ja = isJa();
    let html = '<div class="vscatter-wrap">';
    html += '<div class="vscatter-canvas-wrap"><canvas id="vscatter-canvas" class="vscatter-canvas"></canvas></div>';
    html += `<div class="vscatter-legend">
      <div class="vscatter-legend-item"><div class="vscatter-legend-dot" style="background:#34D399;"></div>${ja ? '協力' : 'Collaboration'}</div>
      <div class="vscatter-legend-item"><div class="vscatter-legend-dot" style="background:#FBBF24;"></div>${ja ? 'ルール有り' : 'Rules'}</div>
      <div class="vscatter-legend-item"><div class="vscatter-legend-dot" style="background:#F87171;"></div>${ja ? 'ルール無し' : 'No Rules'}</div>
    </div>`;
    html += `<div class="vscatter-detail" id="vscatter-detail"><span style="color:var(--text-dim);font-size:0.82rem;">${ja ? 'ドットをクリックして詳細を見る' : 'Click a dot to see details'}</span></div>`;
    html += '</div>';
    container.innerHTML = html;

    const canvas = document.getElementById('vscatter-canvas');
    const ctx = canvas.getContext('2d');
    let hoveredIdx = -1;
    let selectedIdx = -1;

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const pad = { top: 28, right: 20, bottom: 40, left: 56 };

    function toScreen(pt) {
      const rect = canvas.parentElement.getBoundingClientRect();
      const w = rect.width;
      const h = rect.height;
      const pw = w - pad.left - pad.right;
      const ph = h - pad.top - pad.bottom;
      return {
        sx: pad.left + pt.x * pw,
        sy: pad.top + (1 - pt.y) * ph
      };
    }

    function draw() {
      const w = canvas.width / (window.devicePixelRatio || 1);
      const h = canvas.height / (window.devicePixelRatio || 1);
      const pw = w - pad.left - pad.right;
      const ph = h - pad.top - pad.bottom;
      const ja = isJa();

      ctx.clearRect(0, 0, w, h);

      // Draw subtle grid
      ctx.strokeStyle = '#1C1F2644';
      ctx.lineWidth = 0.5;
      for (let i = 0; i <= 4; i++) {
        const gy = pad.top + (ph * i / 4);
        ctx.beginPath(); ctx.moveTo(pad.left, gy); ctx.lineTo(w - pad.right, gy); ctx.stroke();
        const gx = pad.left + (pw * i / 4);
        ctx.beginPath(); ctx.moveTo(gx, pad.top); ctx.lineTo(gx, h - pad.bottom); ctx.stroke();
      }

      // Axes
      ctx.strokeStyle = '#1C1F26';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad.left, pad.top);
      ctx.lineTo(pad.left, h - pad.bottom);
      ctx.lineTo(w - pad.right, h - pad.bottom);
      ctx.stroke();

      // Y-axis label
      ctx.save();
      ctx.fillStyle = '#6B7280';
      ctx.font = '12px Courier New';
      ctx.textAlign = 'center';
      ctx.translate(12, pad.top + ph / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillText(ja ? '強度 / 殺害意図 →' : 'Intensity / Intent to Harm →', 0, 0);
      ctx.restore();

      // Y-axis tick labels
      ctx.fillStyle = '#6B7280';
      ctx.font = '12px Courier New';
      ctx.textAlign = 'right';
      ctx.fillText(ja ? '平和' : 'Peace', pad.left - 6, h - pad.bottom + 3);
      ctx.fillText(ja ? '致命的' : 'Lethal', pad.left - 6, pad.top + 5);

      // X-axis label
      ctx.textAlign = 'center';
      ctx.fillText(ja ? '← ルール無し　　　　　ルール/同意 →' : '← No Rules          Rules / Consent →', pad.left + pw / 2, h - 8);

      // Draw "BJJ training zone" highlight area
      ctx.fillStyle = 'rgba(0,212,255,0.03)';
      ctx.strokeStyle = 'rgba(0,212,255,0.12)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      const zx1 = pad.left + 0.65 * pw;
      const zy1 = pad.top + (1 - 0.55) * ph;
      const zx2 = pad.left + 0.98 * pw;
      const zy2 = pad.top + (1 - 0.02) * ph;
      ctx.beginPath();
      ctx.roundRect(zx1, zy1, zx2 - zx1, zy2 - zy1, 6);
      ctx.fill();
      ctx.stroke();
      ctx.setLineDash([]);

      // Label the BJJ zone
      ctx.fillStyle = '#00d4ff44';
      ctx.font = '12px Courier New';
      ctx.textAlign = 'right';
      ctx.fillText(ja ? 'BJJトレーニング' : 'BJJ Training', zx2 - 4, zy1 + 12);

      // Draw points
      points.forEach((pt, idx) => {
        const { sx, sy } = toScreen(pt);
        const color = zoneColors[pt.zone];
        const isHovered = idx === hoveredIdx;
        const isSelected = idx === selectedIdx;
        const r = isHovered || isSelected ? 7 : 5;

        // Glow
        if (isHovered || isSelected) {
          ctx.beginPath();
          ctx.arc(sx, sy, r + 6, 0, Math.PI * 2);
          ctx.fillStyle = color.replace(')', ',0.15)').replace('rgb', 'rgba');
          // manual alpha
          ctx.fillStyle = color + '22';
          ctx.fill();
        }

        // Dot
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fillStyle = isSelected ? '#fff' : color;
        ctx.fill();
        ctx.strokeStyle = color;
        ctx.lineWidth = isSelected ? 2 : 0;
        if (isSelected) ctx.stroke();

        // Label (show on hover/select or for key points)
        if (isHovered || isSelected) {
          const label = ja ? pt.ja : pt.en;
          ctx.fillStyle = '#E5E7EB';
          ctx.font = '12px Courier New';
          ctx.textAlign = sx > w / 2 ? 'right' : 'left';
          const lx = sx > w / 2 ? sx - r - 6 : sx + r + 6;
          ctx.fillText(label, lx, sy + 3);
        }
      });
    }

    // Hit detection
    function getPointAt(mx, my) {
      const rect = canvas.getBoundingClientRect();
      const x = mx - rect.left;
      const y = my - rect.top;
      for (let i = points.length - 1; i >= 0; i--) {
        const { sx, sy } = toScreen(points[i]);
        const dx = x - sx;
        const dy = y - sy;
        if (dx * dx + dy * dy < 144) return i; // radius ~12
      }
      return -1;
    }

    canvas.addEventListener('mousemove', (e) => {
      const idx = getPointAt(e.clientX, e.clientY);
      if (idx !== hoveredIdx) {
        hoveredIdx = idx;
        canvas.style.cursor = idx >= 0 ? 'pointer' : 'default';
        draw();
      }
    });

    canvas.addEventListener('click', (e) => {
      const idx = getPointAt(e.clientX, e.clientY);
      if (idx >= 0) {
        selectedIdx = idx;
        const pt = points[idx];
        const ja = isJa();
        const detail = document.getElementById('vscatter-detail');
        const color = zoneColors[pt.zone];
        detail.style.borderColor = color + '66';
        detail.innerHTML = `
          <div class="vscatter-detail-title" style="color:${color};">${ja ? pt.ja : pt.en}</div>
          <p>${ja ? pt.desc_ja : pt.desc_en}</p>
        `;
        draw();
      }
    });

    canvas.addEventListener('mouseleave', () => {
      hoveredIdx = -1;
      draw();
    });

    window.addEventListener('resize', () => { resize(); draw(); });
    resize();
    draw();
  }

  render();
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(render, 10));
}

