  .week-slot { height: 24px; }
  .week-slot-time { font-size: 8px; }
  .week-day-label { font-size: 9px; }
  .vspectrum-ja { font-size: 0.7rem; padding-right: 6px; }
  .vspectrum-en { font-size: 0.72rem; padding-left: 6px; }
  .vspectrum-marker { font-size: 9px; margin-left: 6px; }
  .vspectrum-zone-header { font-size: 10px; }
  .vscatter-canvas-wrap { aspect-ratio: 1; }
}
