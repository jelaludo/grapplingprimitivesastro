        { id: "mom_inert", name: "Inertia", nameJa: "慣性" }
      ]},
      { id: "cog", name: "Cognitive Disruption", nameJa: "認知的撹乱", desc: "Attention misdirection, sensory overload, lag.", sub: [
        { id: "cog_feint", name: "Feint", nameJa: "フェイント" },
        { id: "cog_over", name: "Overload", nameJa: "過負荷" },
        { id: "cog_tempo", name: "Tempo Break", nameJa: "テンポ崩し" }
      ]},
      { id: "iso", name: "Isolation", nameJa: "孤立化", desc: "Separating limbs from the core, denying connection.", sub: [
        { id: "iso_limb", name: "Limb Separation", nameJa: "四肢の分離" },
        { id: "iso_pin", name: "Pinning", nameJa: "ピニング" },
        { id: "iso_deny", name: "Connection Denial", nameJa: "接続の遮断" }
      ]}
    ],
    theme: { main: "#ea580c", glow: "#fdba74", sub: "#f97316", bgDark: "#431407", strokeDark: "#9a3412", bgNode: "#2c0b02" }
  }
};

function initFunctionViz(containerId, dataKey, prefix) {
  const container = document.getElementById(containerId);
  if (!container) return;

  const vizData = FUNCTION_DATA[dataKey];
  const theme = vizData.theme;
  const isJa = () => document.body.classList.contains('lang-ja');

  // Component values (all start at 50)
  const componentValues = {};
  vizData.components.forEach(c => { componentValues[c.id] = 50; });
  let timeValue = 50;
  let hoveredNodeId = null;

  // SVG dimensions
  const svgW = 700, svgH = 500;
  const cx = svgW / 2, cy = svgH / 2;

  // Build DOM
  container.innerHTML = '';

  // Title
  const titleDiv = document.createElement('div');
  titleDiv.style.cssText = 'text-align:center;margin-bottom:16px;';
  titleDiv.innerHTML = `
    <div style="font-size:1.2rem;font-weight:600;color:${theme.main};letter-spacing:0.05em;">
      <span lang="en">ƒ(${vizData.title})</span><span lang="ja">ƒ(${vizData.titleJa})</span>
    </div>
    <div style="font-size:0.8rem;color:${theme.glow};letter-spacing:0.1em;">
      <span lang="en">${vizData.subtitle}</span><span lang="ja">${vizData.subtitleJa}</span>
    </div>`;
  container.appendChild(titleDiv);

  // SVG
  const svgNs = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(svgNs, 'svg');
  svg.setAttribute('viewBox', `0 0 ${svgW} ${svgH}`);
  svg.setAttribute('width', '100%');
  svg.style.cssText = 'display:block;width:100%;margin:0 auto;';

  // Glow filter
  const defs = document.createElementNS(svgNs, 'defs');
  defs.innerHTML = `<filter id="${prefix}-glow" x="-50%" y="-50%" width="200%" height="200%">
    <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur"/>
    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
  </filter>`;
  svg.appendChild(defs);

  const linesGroup = document.createElementNS(svgNs, 'g');
  const nodesGroup = document.createElementNS(svgNs, 'g');
  svg.appendChild(linesGroup);
  svg.appendChild(nodesGroup);

  // Center core
  const centerCore = document.createElementNS(svgNs, 'circle');
  centerCore.setAttribute('cx', cx);
  centerCore.setAttribute('cy', cy);
  centerCore.setAttribute('r', 40);
  centerCore.setAttribute('fill', theme.bgDark);
  centerCore.setAttribute('stroke', theme.main);
  centerCore.setAttribute('stroke-width', '2');
  svg.appendChild(centerCore);

  const centerText = document.createElementNS(svgNs, 'text');
  centerText.setAttribute('x', cx);
  centerText.setAttribute('y', cy + 5);
  centerText.setAttribute('text-anchor', 'middle');
  centerText.setAttribute('fill', theme.glow);
  centerText.setAttribute('font-size', '14px');
  centerText.setAttribute('font-weight', 'bold');
  centerText.textContent = `ƒ(${vizData.title})`;
  svg.appendChild(centerText);

  container.appendChild(svg);

  // Tooltip
  const tooltip = document.createElement('div');
  tooltip.style.cssText = `min-height:40px;margin-top:8px;text-align:center;font-size:0.8rem;color:${theme.glow};opacity:0;transition:opacity 0.2s;`;
  container.appendChild(tooltip);



  function createSvgEl(tag) {
    return document.createElementNS(svgNs, tag);
  }

  function buildSvgElements() {
    linesGroup.innerHTML = '';
    nodesGroup.innerHTML = '';
    const numNodes = vizData.components.length;

    vizData.components.forEach((comp, i) => {
      const angle = (Math.PI * 2 * i) / numNodes - Math.PI / 2;
      const nodeX = cx + Math.cos(angle) * 150;
      const nodeY = cy + Math.sin(angle) * 150;

      // Main line
      const line = createSvgEl('line');
      line.setAttribute('x1', cx);
      line.setAttribute('y1', cy);
      line.setAttribute('x2', nodeX);
      line.setAttribute('y2', nodeY);
      line.setAttribute('id', `${prefix}-line-${comp.id}`);
      linesGroup.appendChild(line);

      // Sub-nodes
      if (comp.sub) {
        const numSub = comp.sub.length;
        const wedgeAngle = (Math.PI * 2) / numNodes;
        const wedgeStart = angle - (wedgeAngle / 2);
        const padding = wedgeAngle * 0.1;
        const usableStart = wedgeStart + padding;
        const usableAngle = wedgeAngle - (padding * 2);

        comp.sub.forEach((subComp, j) => {
          const subAngle = numSub > 1
            ? usableStart + (usableAngle * (j / (numSub - 1)))
            : angle;
          const outerR = 230;
          const subX = cx + Math.cos(subAngle) * outerR;
          const subY = cy + Math.sin(subAngle) * outerR;

          // Sub-line
          const subLine = createSvgEl('line');
          subLine.setAttribute('x1', nodeX);
          subLine.setAttribute('y1', nodeY);
          subLine.setAttribute('x2', subX);
          subLine.setAttribute('y2', subY);
          subLine.setAttribute('id', `${prefix}-line-${subComp.id}`);
          subLine.setAttribute('stroke', theme.strokeDark);
          subLine.setAttribute('stroke-dasharray', '2,2');
          linesGroup.appendChild(subLine);

          // Sub-circle
          const subCircle = createSvgEl('circle');
          subCircle.setAttribute('cx', subX);
          subCircle.setAttribute('cy', subY);
          subCircle.setAttribute('id', `${prefix}-circle-${subComp.id}`);
          subCircle.setAttribute('r', '5');
          subCircle.setAttribute('fill', theme.bgNode);
          subCircle.setAttribute('stroke', theme.glow);
          subCircle.setAttribute('stroke-width', '1');
          nodesGroup.appendChild(subCircle);

          // Sub-text
          const subText = createSvgEl('text');
          subText.setAttribute('x', subX);
          subText.setAttribute('y', subY);
          subText.setAttribute('id', `${prefix}-text-${subComp.id}`);
          subText.setAttribute('text-anchor', 'middle');
          subText.setAttribute('font-size', '10px');
          subText.setAttribute('fill', '#ccc');
          subText.textContent = isJa() ? (subComp.nameJa || subComp.name) : subComp.name;
          nodesGroup.appendChild(subText);
        });
      }

      // Node group (interactive)
      const g = createSvgEl('g');
      g.style.cursor = 'pointer';
      g.addEventListener('mouseenter', () => setHover(comp.id));
      g.addEventListener('mouseleave', () => setHover(null));
      g.addEventListener('touchstart', (e) => { e.preventDefault(); setHover(hoveredNodeId === comp.id ? null : comp.id); }, { passive: false });

      const circle = createSvgEl('circle');
      circle.setAttribute('cx', nodeX);
      circle.setAttribute('cy', nodeY);
      circle.setAttribute('id', `${prefix}-circle-${comp.id}`);
      circle.setAttribute('stroke-width', '2');

      const text = createSvgEl('text');
      text.setAttribute('x', nodeX);
      text.setAttribute('id', `${prefix}-text-${comp.id}`);
      text.setAttribute('text-anchor', 'middle');
      text.textContent = isJa() ? (comp.nameJa || comp.name) : comp.name;

      g.appendChild(circle);
      g.appendChild(text);
      nodesGroup.appendChild(g);
    });
  }

  function setHover(id) {
    hoveredNodeId = id;
    if (id) {
      const comp = vizData.components.find(c => c.id === id);
      if (comp) {
        tooltip.style.opacity = '1';
        tooltip.innerHTML = `<strong>${isJa() ? (comp.nameJa || comp.name) : comp.name}</strong><br/><span style="color:#9CA3AF;font-size:0.75rem;">${comp.desc}</span>`;
      }
    } else {
      tooltip.style.opacity = '0';
    }
    updateVisualization();
  }

  function updateVisualization() {
    const numNodes = vizData.components.length;
    const vals = Object.values(componentValues);
    let baseOutput = vals.reduce((a, b) => a + b, 0) / vals.length;
    let output = 0;

    if (vizData.timeEffect === 'decay') {
      output = baseOutput * Math.max(0, 100 - timeValue) / 100;
    } else {
      output = Math.min(100, baseOutput * (0.5 + (timeValue / 100)));
    }

    // Update center core
    const coreR = Math.min(80, Math.max(20, 30 + (output / 2.5)));
    centerCore.setAttribute('r', coreR);
    centerCore.setAttribute('stroke', output > 80 ? theme.glow : theme.main);
    centerCore.setAttribute('stroke-width', output > 80 ? '4' : '2');
    centerCore.setAttribute('filter', output > 70 ? `url(#${prefix}-glow)` : 'none');
    centerText.textContent = `ƒ(${isJa() ? vizData.titleJa : vizData.title})`;


    vizData.components.forEach((comp, i) => {
      const angle = (Math.PI * 2 * i) / numNodes - Math.PI / 2;
      const isHovered = (hoveredNodeId === comp.id);
      const val = componentValues[comp.id] || 0;
      const nodeSize = 25 + (val / 4);
      const currentRadius = coreR + nodeSize + 15;
      const nodeX = cx + Math.cos(angle) * currentRadius;
      const nodeY = cy + Math.sin(angle) * currentRadius;

      const line = document.getElementById(`${prefix}-line-${comp.id}`);
      if (line) {
        line.setAttribute('x2', nodeX);
        line.setAttribute('y2', nodeY);
        line.setAttribute('stroke', isHovered ? theme.main : theme.strokeDark);
        line.setAttribute('stroke-width', isHovered ? '3' : String(1 + val / 30));
        line.setAttribute('stroke-dasharray', isHovered ? 'none' : '4,4');
      }

      const circle = document.getElementById(`${prefix}-circle-${comp.id}`);
      if (circle) {
        circle.setAttribute('cx', nodeX);
        circle.setAttribute('cy', nodeY);
        circle.setAttribute('r', nodeSize);
        circle.setAttribute('fill', isHovered ? theme.main : theme.bgNode);
        circle.setAttribute('stroke', isHovered ? theme.glow : theme.strokeDark);
        circle.setAttribute('filter', (isHovered || val > 70) ? `url(#${prefix}-glow)` : 'none');
      }

      const text = document.getElementById(`${prefix}-text-${comp.id}`);
      if (text) {
        text.setAttribute('x', nodeX);
        text.setAttribute('y', nodeY);
        text.setAttribute('fill', isHovered ? '#fff' : '#e5e0d8');
        text.setAttribute('font-size', isHovered ? '11px' : '9px');
        text.setAttribute('font-weight', isHovered ? 'bold' : 'normal');
        text.setAttribute('dominant-baseline', 'central');
        text.textContent = isJa() ? (comp.nameJa || comp.name) : comp.name;
      }

      // Sub-nodes
      if (comp.sub) {
        const numSub = comp.sub.length;
        const wedgeAngle = (Math.PI * 2) / numNodes;
        const wedgeStart = angle - (wedgeAngle / 2);
        const padding = wedgeAngle * 0.1;
        const usableStart = wedgeStart + padding;
        const usableAngle = wedgeAngle - (padding * 2);
        const outerR = 200 + (val / 4);

        comp.sub.forEach((sub, j) => {
          const subAngle = numSub > 1
            ? usableStart + (usableAngle * (j / (numSub - 1)))
            : angle;
          const subX = cx + Math.cos(subAngle) * outerR;
          const subY = cy + Math.sin(subAngle) * outerR;
          const subSize = 4 + (val / 25);

          const subCircle = document.getElementById(`${prefix}-circle-${sub.id}`);
          if (subCircle) {
            subCircle.setAttribute('cx', subX);
            subCircle.setAttribute('cy', subY);
            subCircle.setAttribute('r', subSize);
            subCircle.setAttribute('stroke', isHovered ? theme.glow : theme.strokeDark);
            subCircle.setAttribute('fill', isHovered ? theme.main : theme.bgNode);
          }
          const subText = document.getElementById(`${prefix}-text-${sub.id}`);
          if (subText) {
            subText.setAttribute('fill', isHovered ? '#fff' : '#ccc');
            subText.setAttribute('font-size', '10px');
            const dx = subX - cx;
            const dy = subY - cy;
            const labelR = 14 + subSize;
            const labelX = subX + (dx / outerR) * labelR;
            const labelY = subY + (dy / outerR) * labelR;
            let anchor = 'middle';
            if (dx > 30) anchor = 'start';
            else if (dx < -30) anchor = 'end';
            subText.setAttribute('x', labelX);
            subText.setAttribute('y', labelY);
            subText.setAttribute('text-anchor', anchor);
            subText.setAttribute('dominant-baseline', 'central');
            subText.textContent = isJa() ? (sub.nameJa || sub.name) : sub.name;
          }
          const subLine = document.getElementById(`${prefix}-line-${sub.id}`);
          if (subLine) {
            subLine.setAttribute('x1', nodeX);
            subLine.setAttribute('y1', nodeY);
            subLine.setAttribute('x2', subX);
            subLine.setAttribute('y2', subY);
            subLine.setAttribute('stroke', isHovered ? theme.main : theme.strokeDark);
          }
        });
      }
    });
  }

  // Re-render on language change
  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => {
    setTimeout(() => { buildSvgElements(); updateVisualization(); }, 10);
  });

  buildSvgElements();
  updateVisualization();
}

// ═══════════════════════════════════════════════════════════════════════════════
// Act 5 — Flow Diagram: Tsukuri → Kuzushi → Kake
// ═══════════════════════════════════════════════════════════════════════════════

function initFlowViz(containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  const isJa = () => document.body.classList.contains('lang-ja');

  function render() {
    const ja = isJa();
    container.innerHTML = '';

    // Main flow: [ Tsukuri frame [ Jibun wo Tsukuru + Kuzushi ] ] → Kake
    const flow = document.createElement('div');
    flow.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;';

    // === Tsukuri outer frame ===
    const tsukuriFrame = document.createElement('div');
    tsukuriFrame.style.cssText = 'border:2px solid #4C8DFF44;border-radius:8px;padding:12px;background:rgba(76,141,255,0.03);position:relative;';

    // Tsukuri label
    const tsukuriLabel = document.createElement('div');
    tsukuriLabel.style.cssText = 'position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#0E1014;padding:0 10px;font-size:0.8rem;font-weight:700;color:#4C8DFF;letter-spacing:0.1em;white-space:nowrap;';
    tsukuriLabel.textContent = ja ? '作り / Tsukuri' : 'Tsukuri / 作り';
    tsukuriFrame.appendChild(tsukuriLabel);

    // Inner boxes container
    const inner = document.createElement('div');
    inner.style.cssText = 'display:flex;align-items:stretch;gap:12px;margin-top:8px;';

    // Jibun wo Tsukuru box (green)
    const jibunBox = document.createElement('div');
    jibunBox.style.cssText = 'flex:1;min-width:150px;padding:16px 14px;border:1px solid #16a34a44;border-radius:6px;background:#052e16;text-align:center;';
    jibunBox.innerHTML = `
      <div style="font-size:1rem;font-weight:700;color:#16a34a;margin-bottom:4px;">${ja ? '自分を作る' : 'Jibun wo Tsukuru'}</div>
      <div style="font-size:0.7rem;color:#86efac;letter-spacing:0.1em;margin-bottom:8px;text-transform:uppercase;">${ja ? '自分を構築する' : 'Build Yourself'}</div>
      <div style="font-size:0.7rem;color:#9CA3AF;line-height:1.5;">${ja ? '姿勢、グリップ、構造、整列' : 'Posture, grips, structure, alignment'}</div>`;
    inner.appendChild(jibunBox);

    // + sign
    const plus = document.createElement('div');
    plus.style.cssText = 'display:flex;align-items:center;font-size:1.2rem;color:#6B7280;flex-shrink:0;';
    plus.textContent = '+';
    inner.appendChild(plus);

    // Kuzushi box (orange)
    const kuzushiBox = document.createElement('div');
    kuzushiBox.style.cssText = 'flex:1;min-width:150px;padding:16px 14px;border:1px solid #ea580c44;border-radius:6px;background:#431407;text-align:center;';
    kuzushiBox.innerHTML = `
      <div style="font-size:1rem;font-weight:700;color:#ea580c;margin-bottom:4px;">${ja ? '崩し' : 'Kuzushi'}</div>
      <div style="font-size:0.7rem;color:#fdba74;letter-spacing:0.1em;margin-bottom:8px;text-transform:uppercase;">${ja ? '崩壊' : 'Break / Disrupt'}</div>
      <div style="font-size:0.7rem;color:#9CA3AF;line-height:1.5;">${ja ? '不整列、ベース除去、孤立化' : 'Misalign, remove base, isolate'}</div>`;
    inner.appendChild(kuzushiBox);

    tsukuriFrame.appendChild(inner);
    flow.appendChild(tsukuriFrame);

    // Arrow → Kake
    const arrow = document.createElement('div');
    arrow.style.cssText = 'display:flex;align-items:center;padding:0 12px;font-size:1.4rem;color:#6B7280;flex-shrink:0;';
    arrow.textContent = '→';
    flow.appendChild(arrow);

    // Kake box (red)
    const kakeBox = document.createElement('div');
    kakeBox.style.cssText = 'min-width:140px;max-width:180px;padding:20px 16px;border:1px solid #dc262644;border-radius:6px;background:#450a0a;text-align:center;align-self:stretch;display:flex;flex-direction:column;justify-content:center;';
    kakeBox.innerHTML = `
      <div style="font-size:1.1rem;font-weight:700;color:#dc2626;margin-bottom:4px;">${ja ? '掛け' : 'Kake'}</div>
      <div style="font-size:0.7rem;color:#fca5a5;letter-spacing:0.1em;margin-bottom:8px;text-transform:uppercase;">${ja ? '実行' : 'Execute'}</div>
      <div style="font-size:0.7rem;color:#9CA3AF;line-height:1.5;">${ja ? '条件が揃った時に技を実行' : 'Perform the technique when conditions are met'}</div>`;
    flow.appendChild(kakeBox);

    container.appendChild(flow);

    // Insight text
    const insight = document.createElement('div');
    insight.style.cssText = 'text-align:center;margin-top:16px;font-size:0.8rem;color:#9CA3AF;line-height:1.7;max-width:600px;margin-left:auto;margin-right:auto;';
    insight.innerHTML = ja
      ? '最初の二つは入れ替え可能というよりも、どちらも前提条件である。相手を常に崩しの状態に置くことはできないが、自分の身体を常にレジリエントな状態に保つことはコントロールできるはずだ。「ベース」はこの概念に関連する用語で、<span style="color:#00d4ff;">「力を吸収し、力を生み出す能力」</span>と表現されることがある。'
      : 'It\'s not really that the first two are interchangeable, more like they\'re both pre-requisites. While we cannot always have the other in a state of Kuzushi, we should be able to control our body to always be in a resilient state. "Base" is another term associated with this idea, I heard it described by Canadians as <span style="color:#00d4ff;">"the ability to absorb and generate force"</span>. Great definition.';
    container.appendChild(insight);
  }

  render();

  const langBtn = document.getElementById('lang-toggle');
  if (langBtn) langBtn.addEventListener('click', () => setTimeout(render, 10));
}

// ═══ Initialize All Visualizations ═══
initFunctionViz('viz-tsukuri', 'Tsukuri', 'tsu');
initFunctionViz('viz-kuzushi', 'Kuzushi', 'kuz');
initFlowViz('viz-flow');

</script>
