---
import BaseLayout from '@/layouts/BaseLayout.astro';
import defaultArchetypes from '@/data/archetypes.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imgBase = base + '/images/partners/';
---

<BaseLayout title="Training Partners — Grappling Primitives" fullscreen={true}>

<!-- ── Toolbar ──────────────────────────────────────────────────────────────── -->
<div id="toolbar" style="position:fixed;top:0;left:0;right:0;height:36px;z-index:50;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Courier New',Consolas,Monaco,monospace;overflow-x:auto;-webkit-overflow-scrolling:touch;flex-wrap:nowrap;">
  <a href={`${base}/`} style="font-size:10px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;text-decoration:none;white-space:nowrap;flex-shrink:0;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'">← Home</a>
  <span style="color:#21262d;flex-shrink:0;">|</span>
  <span class="toolbar-title" style="font-size:11px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;white-space:nowrap;flex-shrink:0;">Training Partners</span>
  <div style="flex:1;min-width:4px;flex-shrink:1;"></div>
  <!-- Deep Link -->
  <button id="btn-deeplink" style="font-family:inherit;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;padding:3px 9px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;white-space:nowrap;flex-shrink:0;">Link</button>
  <span style="color:#21262d;">|</span>
  <!-- Font size -->
  <span id="btn-sm"  title="Small text"  style="font-family:inherit;font-size:11px;padding:2px 5px;cursor:pointer;color:#6b7280;border:1px solid transparent;border-radius:2px;line-height:1;user-select:none;flex-shrink:0;">小</span>
  <span id="btn-med" title="Medium text" style="font-family:inherit;font-size:11px;padding:2px 5px;cursor:pointer;color:#00d4ff;border:1px solid #00d4ff;border-radius:2px;line-height:1;user-select:none;flex-shrink:0;">中</span>
  <span id="btn-lg"  title="Large text"  style="font-family:inherit;font-size:11px;padding:2px 5px;cursor:pointer;color:#6b7280;border:1px solid transparent;border-radius:2px;line-height:1;user-select:none;flex-shrink:0;">大</span>
  <span style="color:#21262d;">|</span>
  <!-- Download (self-assess only) -->
  <button id="btn-download" style="display:none;font-family:inherit;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;padding:3px 9px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;" title="Click to download an image of your self-assessment">↓ Save</button>
  <!-- Mode buttons -->
  <button id="btn-archetypes" style="font-family:inherit;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #00d4ff;background:rgba(0,212,255,0.1);color:#00d4ff;white-space:nowrap;flex-shrink:0;">Archetypes ▾</button>
  <button id="btn-self"       style="font-family:inherit;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;white-space:nowrap;flex-shrink:0;">Self-Assess</button>
  <!-- Admin — injected by JS on localhost only -->
</div>

<!-- ── Pill rail ─────────────────────────────────────────────────────────────── -->
<div id="pill-rail" style="position:fixed;top:36px;left:0;right:0;z-index:40;display:none;flex-wrap:wrap;align-items:center;gap:6px;padding:8px 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);max-height:60vh;overflow-y:auto;"></div>

<!-- ── App layout ────────────────────────────────────────────────────────────── -->
<div id="app" style="position:fixed;top:36px;left:0;right:0;bottom:0;display:flex;overflow:hidden;font-family:'Courier New',Consolas,Monaco,monospace;background:#050509;">

  <!-- Left panel ──────────────────────────────────────────────────────────── -->
  <div id="panel-left" style="width:260px;flex-shrink:0;display:flex;flex-direction:column;border-right:1px solid #0d1117;overflow-y:auto;background:#070710;">
    <div id="char-img-wrap" style="position:relative;width:100%;aspect-ratio:5/7;flex-shrink:0;background:#0d1117;overflow:hidden;">
      <img id="char-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;object-position:center top;opacity:0.9;transition:opacity 0.3s;" />
      <div id="char-color-bar" style="position:absolute;bottom:0;left:0;right:0;height:3px;"></div>
      <div id="char-overall" style="position:absolute;bottom:10px;right:10px;font-family:'DS-Digital',monospace;font-size:15px;font-weight:700;color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.75);padding:3px 10px;border-radius:2px;letter-spacing:0.06em;text-shadow:0 0 8px rgba(255,255,255,0.3);"></div>
    </div>
    <div style="padding:14px 14px 6px;flex-shrink:0;">
      <div id="char-name"    style="font-size:14px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c9d1d9;margin-bottom:3px;"></div>
      <div id="char-tagline" style="font-size:11px;letter-spacing:0.14em;color:#6b7280;text-transform:uppercase;margin-bottom:10px;font-style:italic;"></div>
      <div id="char-desc"    style="font-size:10px;color:#8b949e;line-height:1.75;"></div>
    </div>
    <!-- Self-assess: closest match -->
    <div id="match-panel" style="display:none;margin:10px 12px 12px;padding:11px 12px;border:1px solid #21262d;border-radius:3px;flex-shrink:0;">
      <div style="font-size:10px;letter-spacing:0.18em;color:#6b7280;text-transform:uppercase;margin-bottom:8px;">Closest match</div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
        <img id="match-img" src="" alt="" style="width:44px;height:44px;object-fit:cover;border-radius:2px;flex-shrink:0;" />
        <div>
          <div id="match-name" style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:2px;"></div>
          <div id="match-pct"  style="font-family:'DS-Digital',monospace;font-size:13px;font-weight:700;color:#6b7280;letter-spacing:0.04em;"></div>
        </div>
      </div>
      <div id="match-msg" style="font-size:12px;color:#8b949e;line-height:1.65;font-style:italic;"></div>
    </div>
    <div id="self-portrait" style="display:none;padding:12px 14px;">
      <div style="font-size:10px;letter-spacing:0.2em;color:#30363d;text-transform:uppercase;margin-bottom:8px;">YOUR PROFILE</div>
      <div style="font-size:12px;color:#6b7280;line-height:1.75;font-style:italic;">Rate yourself honestly on each attribute.</div>
    </div>
    <!-- Legend anchored to bottom of left panel -->
    <div style="margin-top:auto;padding:10px 12px;border-top:1px solid #0d1117;display:flex;flex-direction:column;gap:4px;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#6b7280;">
      <span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;background:rgba(230,100,80,0.6);display:inline-block;border-radius:1px;flex-shrink:0;"></span>Needs Work (1–3)</span>
      <span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;background:rgba(210,170,50,0.6);display:inline-block;border-radius:1px;flex-shrink:0;"></span>Developing (4–7)</span>
      <span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;background:rgba(30,180,150,0.6);display:inline-block;border-radius:1px;flex-shrink:0;"></span>Excellent (8–10)</span>
    </div>
  </div>

  <!-- Right panel ─────────────────────────────────────────────────────────── -->
  <div id="panel-right" style="flex:1;overflow-y:auto;padding:14px 20px 32px;">
    <div id="bars-view">
      <div id="attr-bars-container" style="position:relative;"></div>
    </div>
    <div id="self-view" style="display:none;">
      <div id="self-sliders-container" style="position:relative;"></div>
      <!-- Quote -->
      <div style="margin-top:32px;padding:20px 0 8px;border-top:1px solid #0d1117;text-align:center;">
        <div style="font-size:13px;font-style:italic;color:rgba(200,210,220,0.45);letter-spacing:0.06em;line-height:1.6;">
          "Be the Training Partner you wish you had"
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #toolbar::-webkit-scrollbar { display:none; }
  #toolbar { scrollbar-width:none; }
  #pill-rail::-webkit-scrollbar   { display:none; }
  #panel-left::-webkit-scrollbar  { width:3px; }
  #panel-left::-webkit-scrollbar-track  { background:#050509; }
  #panel-left::-webkit-scrollbar-thumb  { background:#21262d; border-radius:2px; }
  #panel-right::-webkit-scrollbar { width:4px; }
  #panel-right::-webkit-scrollbar-track { background:#050509; }
  #panel-right::-webkit-scrollbar-thumb { background:#21262d; border-radius:2px; }
  #kanri-panel::-webkit-scrollbar { width:4px; }
  #kanri-panel::-webkit-scrollbar-track { background:#070710; }
  #kanri-panel::-webkit-scrollbar-thumb { background:#21262d; border-radius:2px; }
  @media (max-width:640px) {
    #app { flex-direction:row !important; }
    #panel-left { width:33% !important; min-width:110px !important; border-right:1px solid #0d1117 !important; border-bottom:none !important; max-height:none !important; overflow-y:auto !important; }
    #panel-right { padding:6px 8px 12px !important; }
    #char-desc { display:none !important; }
    #char-tagline { font-size:10px !important; margin-bottom:4px !important; }
    #char-name { font-size:11px !important; margin-bottom:2px !important; }
    #match-panel { margin:6px 8px !important; padding:8px !important; }
    .toolbar-title { display:none !important; }
    #btn-sm, #btn-med, #btn-lg { display:none !important; }
  }
</style>

<script define:vars={{ imgBase, defaultArchetypes }}>
'use strict';

// ─── Attributes (fixed) ───────────────────────────────────────────────────────
const ATTRIBUTES = [
  { id:'ctrl_mov',  label:'Controlled Movements',                     cat:'Technical Attributes' },
  { id:'ctrl_sub',  label:'Controlled Submissions',                   cat:'Technical Attributes' },
  { id:'intensity', label:'Modular Intensity',                        cat:'Technical Attributes' },
  { id:'knowledge', label:'Depth of Knowledge',                       cat:'Technical Attributes' },
  { id:'inj_know',  label:'Knowledgeable about injury patterns',      cat:'Technical Attributes' },
  { id:'looks',     label:'Ability to give "looks" / work specifics', cat:'Technical Attributes' },
  { id:'ego',       label:'Controlled Ego',                           cat:'Mindset & Attitude' },
  { id:'playful',   label:'Agreeableness',                            cat:'Mindset & Attitude' },
  { id:'rnd',       label:'R&D mindset (discover & troubleshoot)',    cat:'Mindset & Attitude' },
  { id:'concise',   label:'Not overtalking / over-explaining',        cat:'Mindset & Attitude' },
  { id:'comms',     label:'Communicative about boundaries & injuries',cat:'Mindset & Attitude' },
  { id:'feedback',  label:'Feedback receptivity',                     cat:'Mindset & Attitude' },
  { id:'safety',    label:'Safety consciousness',                     cat:'Mindset & Attitude' },
  { id:'recovery',  label:'Recovery awareness',                       cat:'Mindset & Attitude' },
  { id:'self_aware',label:'Ability to identify own weaknesses',       cat:'Mindset & Attitude' },
  { id:'hygiene',     label:'Hygiene',                                  cat:'Others' },
  { id:'reliable',    label:'Reliability',                              cat:'Others' },
  { id:'dark_triad',  label:'Dark Triad',   cat:'Others', inverted:true, tooltip:'Narcissism: Grandiosity, entitlement, lack of empathy.\n\nMachiavellianism: Cunning, strategic exploitation, moral disengagement.\n\nPsychopathy: Impulsivity, callousness, antisocial tendencies.' },
  { id:'extraversion',label:'Extraversion', cat:'Others' },
  { id:'neuroticism', label:'Neuroticism',  cat:'Others', inverted:true },
];

// ─── Archetypes (source of truth: src/data/archetypes.json, injected at build) ─
const DEFAULT_ARCHETYPES = defaultArchetypes;

// Load from localStorage if modified by KANRI
const LS_KEY = 'gp-tp-archetypes';
let ARCHETYPES;
try {
  const saved = localStorage.getItem(LS_KEY);
  ARCHETYPES = saved ? JSON.parse(saved) : JSON.parse(JSON.stringify(DEFAULT_ARCHETYPES));
} catch(e) {
  ARCHETYPES = JSON.parse(JSON.stringify(DEFAULT_ARCHETYPES));
}
function saveArchetypes() { localStorage.setItem(LS_KEY, JSON.stringify(ARCHETYPES)); }

// ─── Font size config ─────────────────────────────────────────────────────────
const FONT_CFG = {
  sm:  { attrPx:7,  catPx:9,  labelW:'145px' },
  med: { attrPx:9,  catPx:11, labelW:'186px' },
  lg:  { attrPx:11, catPx:13, labelW:'220px' },
};
let fontKey = 'med';
function fc() {
  const base = FONT_CFG[fontKey];
  if (window.innerWidth < 640) return { attrPx: Math.min(base.attrPx, 8), catPx: Math.min(base.catPx, 10), labelW: '88px', barH: 16 };
  return { ...base, barH: 22 };
}

// ─── Color helpers ────────────────────────────────────────────────────────────
// 11-entry array indexed by score 0–10: dark red → orange → amber → yellow-green → teal
const SCORE_COLORS = [
  '#7f0000', // 0  — very dark red
  '#c62828', // 1  — dark red
  '#e53935', // 2  — red
  '#f4511e', // 3  — deep orange
  '#fb8c00', // 4  — orange
  '#fdd835', // 5  — yellow
  '#c0ca33', // 6  — lime
  '#7cb342', // 7  — green
  '#26a69a', // 8  — teal
  '#00acc1', // 9  — cyan
  '#00d4ff', // 10 — bright cyan
];
function fillColor(v) { return SCORE_COLORS[Math.max(0, Math.min(10, Math.round(v)))]; }
// Single gradient strip background (replaces 3-band system)
const ZONE_GRADIENT     = 'linear-gradient(to right,rgba(198,40,40,0.18),rgba(253,216,53,0.12) 50%,rgba(0,212,255,0.18))';
const ZONE_GRADIENT_INV = 'linear-gradient(to right,rgba(0,212,255,0.18),rgba(253,216,53,0.12) 50%,rgba(198,40,40,0.18))';
function zoneBg(inv) { return inv ? ZONE_GRADIENT_INV : ZONE_GRADIENT; }
function avgScore(scores) {
  return (ATTRIBUTES.reduce((s,a) => s + (scores[a.id]??0), 0) / ATTRIBUTES.length).toFixed(1);
}

// ─── DOM refs ─────────────────────────────────────────────────────────────────
const pillRail      = document.getElementById('pill-rail');
const charImg       = document.getElementById('char-img');
const charColorBar  = document.getElementById('char-color-bar');
const charOverall   = document.getElementById('char-overall');
const charName      = document.getElementById('char-name');
const charTagline   = document.getElementById('char-tagline');
const charDesc      = document.getElementById('char-desc');
const matchPanel    = document.getElementById('match-panel');
const matchImg      = document.getElementById('match-img');
const matchName     = document.getElementById('match-name');
const matchPct      = document.getElementById('match-pct');
const matchMsg      = document.getElementById('match-msg');
const selfPortrait  = document.getElementById('self-portrait');
const barsView      = document.getElementById('bars-view');
const selfView      = document.getElementById('self-view');
const attrBarsEl    = document.getElementById('attr-bars-container');
const selfSlidersEl = document.getElementById('self-sliders-container');
const panelRight    = document.getElementById('panel-right');
const btnArch       = document.getElementById('btn-archetypes');
const btnSelf       = document.getElementById('btn-self');
const btnDl         = document.getElementById('btn-download');
const toolbar       = document.getElementById('toolbar');

// ─── Tooltip ──────────────────────────────────────────────────────────────────
const tip = document.createElement('div');
tip.style.cssText = 'position:fixed;z-index:9000;background:#0d1117;border:1px solid #30363d;border-radius:3px;padding:9px 12px;font-size:12px;line-height:1.7;color:#8b949e;font-family:inherit;pointer-events:none;max-width:260px;white-space:pre-wrap;letter-spacing:0.03em;opacity:0;transition:opacity 0.15s;box-shadow:0 4px 16px rgba(0,0,0,0.6);';
document.body.appendChild(tip);
function showTip(text, e) {
  tip.textContent = text;
  tip.style.opacity = '1';
  moveTip(e);
}
function moveTip(e) {
  const pad = 12, tw = tip.offsetWidth, th = tip.offsetHeight;
  let x = e.clientX + pad, y = e.clientY + pad;
  if (x + tw > window.innerWidth  - pad) x = e.clientX - tw - pad;
  if (y + th > window.innerHeight - pad) y = e.clientY - th - pad;
  tip.style.left = x + 'px';
  tip.style.top  = y + 'px';
}
function hideTip() { tip.style.opacity = '0'; }

// ─── State ────────────────────────────────────────────────────────────────────
let mode        = 'archetypes';
let currentArch = ARCHETYPES[0];
const selfScores = {};
ATTRIBUTES.forEach(a => { selfScores[a.id] = 5; });

// ─── Font size buttons ────────────────────────────────────────────────────────
function applyFontSize(key) {
  fontKey = key;
  ['sm','med','lg'].forEach(k => {
    const b = document.getElementById('btn-'+k);
    if (!b) return;
    const active = k === key;
    b.style.color       = active ? '#00d4ff' : '#6b7280';
    b.style.borderColor = active ? '#00d4ff' : 'transparent';
  });
  // Re-render active view
  if (mode === 'archetypes') renderAttrBars(currentArch.scores, currentArch.color);
  else                       buildSelfSliders();
}
document.getElementById('btn-sm') .addEventListener('click', () => applyFontSize('sm'));
document.getElementById('btn-med').addEventListener('click', () => applyFontSize('med'));
document.getElementById('btn-lg') .addEventListener('click', () => applyFontSize('lg'));

// ─── Pill rail ────────────────────────────────────────────────────────────────
function buildPills() {
  pillRail.innerHTML = '';
  ARCHETYPES.forEach(arch => {
    const btn = document.createElement('button');
    btn.id = 'pill-' + arch.id;
    btn.textContent = arch.name;
    btn.style.cssText = 'font-family:inherit;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;padding:3px 9px;border-radius:2px;border:1px solid #21262d;background:transparent;color:#6b7280;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all 0.15s;';
    btn.addEventListener('click', () => selectArchetype(arch));
    pillRail.appendChild(btn);
  });
}
function updatePills() {
  ARCHETYPES.forEach(arch => {
    const btn = document.getElementById('pill-' + arch.id);
    if (!btn) return;
    const active = arch.id === currentArch.id;
    btn.style.borderColor = active ? arch.color : '#21262d';
    btn.style.background  = active ? arch.color + '22' : 'transparent';
    btn.style.color       = active ? arch.color : '#6b7280';
  });
}

// ─── Bar row builder (shared by archetype + download canvas) ─────────────────
function makeBarRow(attrLabel, v, color, tooltip, inverted) {
  const cfg = fc();
  const pct = v * 10;
  const fcolor = fillColor(inverted ? 10 - v : v);

  const row = document.createElement('div');
  row.style.cssText = 'display:flex;align-items:center;margin-bottom:5px;';

  const lbl = document.createElement('div');
  lbl.style.cssText = `width:${cfg.labelW};flex-shrink:0;font-size:${cfg.attrPx}px;letter-spacing:0.04em;color:#8b949e;padding-right:12px;line-height:1.3;font-family:inherit;`;
  lbl.textContent = attrLabel;
  if (tooltip) {
    lbl.style.cursor = 'help';
    lbl.style.borderBottom = '1px dotted #30363d';
    lbl.addEventListener('mouseenter', e => showTip(tooltip, e));
    lbl.addEventListener('mousemove',  e => moveTip(e));
    lbl.addEventListener('mouseleave', hideTip);
  }

  const bw = document.createElement('div');
  bw.style.cssText = `flex:1;position:relative;height:${cfg.barH}px;border-radius:3px;overflow:hidden;background:#0c0c18;`;

  bw.innerHTML = `
    <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:${zoneBg(inverted)};pointer-events:none;"></div>
    <div style="position:absolute;top:0;left:0;width:${pct}%;height:100%;background:${fcolor};opacity:0.75;z-index:1;"></div>
    <div data-dot="1" style="position:absolute;top:50%;left:${pct}%;width:9px;height:9px;border-radius:50%;transform:translate(-50%,-50%);background:#0c0c18;border:2.5px solid ${fcolor};box-shadow:0 0 4px ${fcolor}88;z-index:3;"></div>
    <div style="position:absolute;right:6px;top:50%;transform:translateY(-50%);font-family:'DS-Digital',monospace;font-size:12px;font-weight:700;color:${fcolor};z-index:4;">${v}</div>
  `;

  row.appendChild(lbl);
  row.appendChild(bw);
  return row;
}

function makeCatHeader(text, color) {
  const h = document.createElement('div');
  h.style.cssText = `font-size:${fc().catPx}px;font-weight:700;letter-spacing:0.06em;padding:8px 0 4px;border-bottom:1px solid #0d1117;margin-bottom:4px;color:${color};font-family:inherit;`;
  h.textContent = text;
  return h;
}

// ─── Archetype bar chart ──────────────────────────────────────────────────────
function renderAttrBars(scores, color) {
  attrBarsEl.innerHTML = '';
  const cats = {}, catOrder = [];
  ATTRIBUTES.forEach(attr => {
    if (!cats[attr.cat]) { cats[attr.cat] = []; catOrder.push(attr.cat); }
    cats[attr.cat].push(attr);
  });
  catOrder.forEach((cat, ci) => {
    const group = document.createElement('div');
    group.style.cssText = `display:flex;align-items:stretch;${ci > 0 ? 'margin-top:5px;' : ''}`;

    const hdr = document.createElement('div');
    hdr.style.cssText = `writing-mode:vertical-rl;transform:rotate(180deg);font-size:${fc().catPx}px;font-weight:700;letter-spacing:0.1em;color:${color};display:flex;align-items:center;justify-content:center;padding:0 4px;border-right:1px solid #1a1f2e;flex-shrink:0;min-width:18px;user-select:none;`;
    hdr.textContent = cat;

    const wrap = document.createElement('div');
    wrap.style.cssText = 'flex:1;padding-left:8px;padding-top:2px;padding-bottom:2px;';
    cats[cat].forEach(attr => wrap.appendChild(makeBarRow(attr.label, scores[attr.id]??0, color, attr.tooltip, attr.inverted)));

    group.appendChild(hdr);
    group.appendChild(wrap);
    attrBarsEl.appendChild(group);
  });
  requestAnimationFrame(() => requestAnimationFrame(drawSparkline));
}

// ─── Sparkline helper (offset-based — layout-relative, resize-safe) ───────────
function dotPosInContainer(dot, container) {
  let x = dot.offsetLeft, y = dot.offsetTop;
  let cur = dot.offsetParent;
  while (cur && cur !== container) { x += cur.offsetLeft; y += cur.offsetTop; cur = cur.offsetParent; }
  return { x, y };
}
function buildSparklineSVG(dots, container, id, stroke) {
  const old = document.getElementById(id);
  if (old) old.remove();
  if (dots.length < 2) return;
  const pts = dots.map(d => {
    const {x,y} = dotPosInContainer(d, container);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  const svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
  svg.id = id;
  svg.style.cssText = `position:absolute;top:0;left:0;width:100%;height:${container.scrollHeight}px;pointer-events:none;z-index:5;overflow:visible;`;
  const poly = document.createElementNS('http://www.w3.org/2000/svg','polyline');
  poly.setAttribute('points', pts);
  poly.setAttribute('stroke', stroke);
  poly.setAttribute('stroke-width','1.5');
  poly.setAttribute('fill','none');
  poly.setAttribute('stroke-linejoin','round');
  svg.appendChild(poly);
  container.appendChild(svg);
}

function drawSparkline() {
  buildSparklineSVG(
