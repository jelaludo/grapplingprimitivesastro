// ─── Download (canvas render) ─────────────────────────────────────────────────
btnDl.addEventListener('click', downloadSelf);
function downloadSelf() {
  const DPR=2, W=820, LP=20, LW=200, BW=W-LP-LW-LP-28, BH=20, RH=30, HDR=44, TP=60;
  let H=TP, lc='';
  ATTRIBUTES.forEach(a => { if(a.cat!==lc){lc=a.cat;H+=HDR;} H+=RH; });
  H+=90;
  const cv=document.createElement('canvas');
  cv.width=W*DPR; cv.height=H*DPR;
  const ctx=cv.getContext('2d'); ctx.scale(DPR,DPR);
  ctx.fillStyle='#050509'; ctx.fillRect(0,0,W,H);

  // Title
  ctx.font=`bold 15px 'Courier New',monospace`; ctx.fillStyle='#c9d1d9'; ctx.textAlign='left';
  ctx.fillText('TRAINING PARTNER  ·  SELF-ASSESSMENT',LP,26);
  ctx.font=`12px 'Courier New',monospace`; ctx.fillStyle='#6b7280';
  const {arch,pct}=findClosest(selfScores);
  ctx.fillText(`AVG ${avgScore(selfScores)}  ·  Closest match: ${arch.name} (${pct}%)`,LP,44);

  let y=TP, lastC=''; const dots=[];
  ATTRIBUTES.forEach(attr => {
    if(attr.cat!==lastC){
      lastC=attr.cat; y+=6;
      ctx.font=`bold 10px 'Courier New',monospace`; ctx.fillStyle='#00d4ff'; ctx.textAlign='left';
      ctx.fillText(attr.cat.toUpperCase(),LP,y+16);
      ctx.strokeStyle='#0d1117'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(LP,y+22); ctx.lineTo(W-LP,y+22); ctx.stroke();
      y+=HDR;
    }
    const v=selfScores[attr.id]??0, pct2=v/10;
    const barX=LP+LW, barY=y+(RH-BH)/2;
    // label
    ctx.font=`12px 'Courier New',monospace`; ctx.fillStyle='#8b949e'; ctx.textAlign='right';
    ctx.fillText(attr.label, barX-8, barY+BH/2+3);
    // zone gradient strip
    ctx.globalAlpha=1;
    const zg=ctx.createLinearGradient(barX,0,barX+BW,0);
    if(attr.inverted){zg.addColorStop(0,'rgba(0,212,255,0.18)');zg.addColorStop(0.5,'rgba(253,216,53,0.12)');zg.addColorStop(1,'rgba(198,40,40,0.18)');}
    else{zg.addColorStop(0,'rgba(198,40,40,0.18)');zg.addColorStop(0.5,'rgba(253,216,53,0.12)');zg.addColorStop(1,'rgba(0,212,255,0.18)');}
    ctx.fillStyle=zg;ctx.fillRect(barX,barY,BW,BH);
    // fill
    const fc2=fillColor(attr.inverted?10-v:v); ctx.globalAlpha=0.72; ctx.fillStyle=fc2;
    ctx.fillRect(barX,barY,BW*pct2,BH); ctx.globalAlpha=1;
    // number
    ctx.font=`bold 12px 'Courier New',monospace`; ctx.fillStyle=fc2; ctx.textAlign='right';
    ctx.fillText(String(v),barX+BW-4,barY+BH/2+3);
    // dot pos
    dots.push({x:barX+BW*pct2, y:barY+BH/2, c:fc2});
    y+=RH;
  });
  // sparkline
  ctx.strokeStyle='rgba(0,212,255,0.35)'; ctx.lineWidth=1.5; ctx.lineJoin='round';
  ctx.beginPath();
  dots.forEach((d,i)=>{ i===0?ctx.moveTo(d.x,d.y):ctx.lineTo(d.x,d.y); });
  ctx.stroke();
  // dots
  dots.forEach(d=>{
    ctx.beginPath(); ctx.arc(d.x,d.y,3.5,0,Math.PI*2);
    ctx.fillStyle='#050509'; ctx.fill();
    ctx.strokeStyle=d.c; ctx.lineWidth=2; ctx.stroke();
  });
  // quote
  ctx.font=`italic 13px 'Courier New',monospace`; ctx.fillStyle='rgba(200,210,220,0.45)'; ctx.textAlign='center';
  ctx.fillText('"Be the Training Partner you wish you had"',W/2,H-28);

  const link=document.createElement('a');
  link.download='training-partner-self-assessment.png';
  link.href=cv.toDataURL('image/png'); link.click();
}

// ─── KANRI admin (localhost only) ─────────────────────────────────────────────
const isLocal = ['localhost','127.0.0.1',''].includes(window.location.hostname);
if (isLocal) {
  // Add 管 button to toolbar
  const kanriBtn = document.createElement('button');
  kanriBtn.id = 'btn-kanri';
  kanriBtn.textContent = '管';
  kanriBtn.title = 'KANRI — Edit archetypes';
  kanriBtn.style.cssText = 'font-family:inherit;font-size:13px;padding:1px 6px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;margin-left:4px;';
  kanriBtn.addEventListener('click', openKanri);
  toolbar.appendChild(kanriBtn);

  let kanriArch = ARCHETYPES[0];

  // ── File System Access helpers ──────────────────────────────────────────────
  const IDB_NAME = 'gp-kanri-store';
  const IDB_HANDLE_KEY = 'archetypes-file-handle';
  const LS_BACKUP_KEY = 'gp-archetypes-backup';

  function idbGet(key) {
    return new Promise((res, rej) => {
      const req = indexedDB.open(IDB_NAME, 1);
      req.onupgradeneeded = () => req.result.createObjectStore('kv');
      req.onsuccess = () => {
        const r = req.result.transaction('kv','readonly').objectStore('kv').get(key);
        r.onsuccess = () => res(r.result); r.onerror = rej;
      };
      req.onerror = rej;
    });
  }
  function idbSet(key, val) {
    return new Promise((res, rej) => {
      const req = indexedDB.open(IDB_NAME, 1);
      req.onupgradeneeded = () => req.result.createObjectStore('kv');
      req.onsuccess = () => {
        const tx = req.result.transaction('kv','readwrite');
        tx.objectStore('kv').put(val, key);
        tx.oncomplete = res; tx.onerror = rej;
      };
      req.onerror = rej;
    });
  }

  async function exportToSource(toastEl) {
    const json = JSON.stringify(ARCHETYPES, null, 2);
    const toast = (msg, color='#9ccc65') => {
      if (!toastEl) return;
      toastEl.textContent = msg; toastEl.style.color = color;
      toastEl.style.opacity = '1'; setTimeout(() => { toastEl.style.opacity = '0'; }, 3500);
    };

    // Fallback for browsers without File System Access API
    if (!window.showSaveFilePicker) {
      const blob = new Blob([json], { type:'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'archetypes.json'; a.click();
      URL.revokeObjectURL(url);
      toast('↓ downloaded — replace src/data/archetypes.json and push');
      return;
    }

    // Retrieve stored handle
    let handle = await idbGet(IDB_HANDLE_KEY).catch(() => null);
    if (handle) {
      const perm = await handle.queryPermission({ mode:'readwrite' });
      if (perm !== 'granted') {
        const r = await handle.requestPermission({ mode:'readwrite' });
        if (r !== 'granted') handle = null;
      }
    }

    // First time (or permission lost): ask user to pick the file
    if (!handle) {
      try {
        handle = await window.showSaveFilePicker({
          suggestedName: 'archetypes.json',
          types: [{ description:'JSON', accept:{ 'application/json':['.json'] } }],
        });
        await idbSet(IDB_HANDLE_KEY, handle);
      } catch(e) {
        if (e.name !== 'AbortError') toast('Error: ' + e.message, '#ef5350');
        return;
      }
    }

    // Backup existing content before overwriting
    try {
      const existing = await (await handle.getFile()).text();
      localStorage.setItem(LS_BACKUP_KEY, JSON.stringify({ ts: Date.now(), data: existing }));
    } catch(e) {}

    // Write
    try {
      const writable = await handle.createWritable();
      await writable.write(json); await writable.close();
      toast('✓ archetypes.json saved — git push to deploy');
      // Refresh backup button in panel
      renderKanriPanel();
    } catch(e) {
      // Handle may have gone stale — clear it and retry once
      await idbSet(IDB_HANDLE_KEY, null).catch(()=>{});
      toast('Permission lost — click Export again to re-pick the file', '#fdd835');
    }
  }

  function openKanri() {
    let overlay = document.getElementById('kanri-overlay');
    if (overlay) { overlay.style.display='flex'; renderKanriPanel(); return; }

    overlay = document.createElement('div');
    overlay.id = 'kanri-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;z-index:200;display:flex;justify-content:flex-end;font-family:"Courier New",monospace;';

    const backdrop = document.createElement('div');
    backdrop.style.cssText = 'position:absolute;inset:0;background:rgba(0,0,0,0.55);';
    backdrop.addEventListener('click', () => { overlay.style.display='none'; });

    const panel = document.createElement('div');
    panel.id = 'kanri-panel';
    panel.style.cssText = 'position:relative;width:460px;max-width:100vw;height:100%;background:#070710;border-left:1px solid #21262d;overflow-y:auto;z-index:1;display:flex;flex-direction:column;';

    overlay.appendChild(backdrop);
    overlay.appendChild(panel);
    document.body.appendChild(overlay);
    renderKanriPanel();
  }

  function renderKanriPanel() {
    const panel = document.getElementById('kanri-panel');
    panel.innerHTML = '';

    // Header
    const hdr = document.createElement('div');
    hdr.style.cssText = 'display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid #21262d;flex-shrink:0;';
    hdr.innerHTML = `<span style="font-size:18px;color:#ffd54f;">管</span><span style="font-size:10px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;flex:1;">KANRI — Training Partners</span>`;
    const closeBtn = document.createElement('button');
    closeBtn.textContent='✕'; closeBtn.style.cssText='font-family:inherit;font-size:11px;padding:2px 6px;border:1px solid #21262d;background:transparent;color:#6b7280;cursor:pointer;border-radius:2px;';
    closeBtn.addEventListener('click',()=>{ document.getElementById('kanri-overlay').style.display='none'; });
    hdr.appendChild(closeBtn); panel.appendChild(hdr);

    // Controls
    const ctrl = document.createElement('div');
    ctrl.style.cssText = 'display:flex;gap:6px;padding:8px 14px;border-bottom:1px solid #0d1117;flex-shrink:0;flex-wrap:wrap;';

    function makeCtrlBtn(label,title,onClick,color='#6b7280') {
      const b=document.createElement('button');
      b.textContent=label; b.title=title||'';
      b.style.cssText=`font-family:inherit;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;padding:3px 9px;border-radius:2px;border:1px solid ${color}44;background:transparent;color:${color};cursor:pointer;`;
      b.addEventListener('click',onClick); return b;
    }
    ctrl.appendChild(makeCtrlBtn('+ Add','Clone selected archetype',()=>{
      const clone = JSON.parse(JSON.stringify(kanriArch));
      clone.id = 'arch_' + Date.now();
      clone.name = 'NEW ARCHETYPE';
      ARCHETYPES.push(clone); kanriArch = clone;
      saveArchetypes(); buildPills(); renderKanriPanel();
    },'#00d4ff'));
    ctrl.appendChild(makeCtrlBtn('🗑 Delete','Delete selected archetype',()=>{
      if(ARCHETYPES.length<=1){alert('Cannot delete last archetype.');return;}
      if(!confirm(`Delete "${kanriArch.name}"?`)) return;
      const idx=ARCHETYPES.findIndex(a=>a.id===kanriArch.id);
      ARCHETYPES.splice(idx,1); kanriArch=ARCHETYPES[0];
      saveArchetypes(); buildPills();
      if(mode==='archetypes') selectArchetype(currentArch);
      renderKanriPanel();
    },'#ef5350'));
    ctrl.appendChild(makeCtrlBtn('⬇ Export to Source','Write directly to src/data/archetypes.json (pick file once, then auto-saves)',()=>{
      exportToSource(ctrl.querySelector('[data-toast]'));
    },'#9ccc65'));
    ctrl.appendChild(makeCtrlBtn('↺ Reset','Reset to defaults',()=>{
      if(!confirm('Reset all archetypes to defaults?')) return;
      ARCHETYPES.length=0; JSON.parse(JSON.stringify(DEFAULT_ARCHETYPES)).forEach(a=>ARCHETYPES.push(a));
      kanriArch=ARCHETYPES[0]; saveArchetypes(); buildPills();
      if(mode==='archetypes') selectArchetype(currentArch);
      renderKanriPanel();
    },'#6b7280'));
    // Restore Backup button — only if a backup exists
    try {
      const raw = localStorage.getItem(LS_BACKUP_KEY);
      if (raw) {
        const { ts } = JSON.parse(raw);
        const age = new Date(ts).toLocaleTimeString();
        ctrl.appendChild(makeCtrlBtn(`↩ Restore backup (${age})`, 'Restore archetypes from before last export', () => {
          if (!confirm('Restore backup? Current KANRI state will be replaced.')) return;
          const { data } = JSON.parse(localStorage.getItem(LS_BACKUP_KEY));
          ARCHETYPES.length = 0; JSON.parse(data).forEach(a => ARCHETYPES.push(a));
          kanriArch = ARCHETYPES[0]; saveArchetypes(); buildPills();
          if (mode === 'archetypes') selectArchetype(currentArch);
          renderKanriPanel();
        }, '#fdd835'));
      }
    } catch(e) {}
    const toast=document.createElement('span'); toast.setAttribute('data-toast','1');
    toast.textContent=''; toast.style.cssText='font-size:10px;color:#9ccc65;opacity:0;transition:opacity 0.3s;align-self:center;letter-spacing:0.04em;';
    ctrl.appendChild(toast); panel.appendChild(ctrl);

    // Archetype selector pills
    const pills = document.createElement('div');
    pills.style.cssText = 'display:flex;flex-wrap:wrap;gap:5px;padding:10px 14px;border-bottom:1px solid #0d1117;flex-shrink:0;';
    ARCHETYPES.forEach(arch => {
      const b=document.createElement('button');
      b.textContent=arch.name;
      const active=arch.id===kanriArch.id;
      b.style.cssText=`font-family:inherit;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 8px;border-radius:2px;border:1px solid ${active?arch.color:'#21262d'};background:${active?arch.color+'22':'transparent'};color:${active?arch.color:'#6b7280'};cursor:pointer;`;
      b.addEventListener('click',()=>{ kanriArch=arch; selectArchetype(arch); renderKanriPanel(); });
      pills.appendChild(b);
    }); panel.appendChild(pills);

    // Edit form
    const form = document.createElement('div');
    form.style.cssText = 'padding:14px;flex:1;overflow-y:auto;';

    function field(label,val,onInput,type='text',opts={}) {
      const wrap=document.createElement('div'); wrap.style.cssText='margin-bottom:10px;';
      const lbl2=document.createElement('div'); lbl2.textContent=label; lbl2.style.cssText='font-size:10px;letter-spacing:0.16em;color:#6b7280;text-transform:uppercase;margin-bottom:4px;';
      let inp;
      if(type==='textarea'){
        inp=document.createElement('textarea');
        inp.style.cssText='width:100%;box-sizing:border-box;background:#0a0a12;color:#c9d1d9;border:1px solid #21262d;border-radius:2px;padding:5px 7px;font-family:inherit;font-size:12px;line-height:1.5;resize:vertical;min-height:60px;';
      } else {
        inp=document.createElement('input'); inp.type=type;
        inp.style.cssText='width:100%;box-sizing:border-box;background:#0a0a12;color:#c9d1d9;border:1px solid #21262d;border-radius:2px;padding:5px 7px;font-family:inherit;font-size:12px;';
      }
      inp.value=val;
      if(type==='color') inp.style.cssText='height:28px;background:#0a0a12;border:1px solid #21262d;border-radius:2px;cursor:pointer;padding:2px;';
      inp.addEventListener('input',()=>onInput(inp.value));
      wrap.appendChild(lbl2); wrap.appendChild(inp);
      return wrap;
    }

    form.appendChild(field('Name', kanriArch.name, v => {
      kanriArch.name=v.toUpperCase();
      const pill=document.getElementById('pill-'+kanriArch.id); if(pill) pill.textContent=kanriArch.name;
      if(currentArch.id===kanriArch.id) { charName.textContent=kanriArch.name; }
      saveArchetypes();
    }));
    form.appendChild(field('Color', kanriArch.color, v => {
      kanriArch.color=v; saveArchetypes();
      const pill=document.getElementById('pill-'+kanriArch.id);
      if(pill){ pill.style.borderColor=v; pill.style.color=v; }
      if(currentArch.id===kanriArch.id){charColorBar.style.background=v;charName.style.color=v;charTagline.style.color=v+'bb';}
    },'color'));
    form.appendChild(field('Image filename', kanriArch.img, v => {
      kanriArch.img=v; saveArchetypes();
      if(currentArch.id===kanriArch.id) charImg.src=imgBase+v;
    }));
    form.appendChild(field('Tagline', kanriArch.tagline, v => {
      kanriArch.tagline=v; saveArchetypes();
      if(currentArch.id===kanriArch.id) charTagline.textContent=v;
    }));
    form.appendChild(field('Description', kanriArch.desc, v => {
      kanriArch.desc=v; saveArchetypes();
      if(currentArch.id===kanriArch.id) charDesc.textContent=v;
    },'textarea'));

    // Score sliders
    const scoreHdr=document.createElement('div');
    scoreHdr.style.cssText='font-size:10px;letter-spacing:0.16em;color:#6b7280;text-transform:uppercase;margin:14px 0 8px;padding-top:10px;border-top:1px solid #0d1117;';
    scoreHdr.textContent='Attribute Scores'; form.appendChild(scoreHdr);

    let lastScoreCat='';
    ATTRIBUTES.forEach(attr => {
      if(attr.cat!==lastScoreCat){
        lastScoreCat=attr.cat;
        const ch=document.createElement('div');
        ch.style.cssText='font-size:11px;font-weight:700;color:#42a5f5;margin:10px 0 5px;';
        ch.textContent=attr.cat; form.appendChild(ch);
      }
      const sv = kanriArch.scores[attr.id]??0;
      const srow=document.createElement('div'); srow.style.cssText='display:flex;align-items:center;gap:8px;margin-bottom:6px;';
      const slbl=document.createElement('div'); slbl.style.cssText='flex:1;font-size:11px;color:#8b949e;'; slbl.textContent=attr.label;
      const snum=document.createElement('div'); snum.style.cssText='width:18px;text-align:right;font-size:12px;font-weight:700;color:'+fillColor(attr.inverted?10-sv:sv)+';'; snum.textContent=sv;
      const sslider=document.createElement('input'); sslider.type='range'; sslider.min='0'; sslider.max='10'; sslider.step='1'; sslider.value=sv;
      sslider.style.cssText='width:80px;flex-shrink:0;accent-color:#00d4ff;cursor:pointer;';
      sslider.addEventListener('input',()=>{
        const nv=+sslider.value;
        kanriArch.scores[attr.id]=nv;
        snum.textContent=nv; snum.style.color=fillColor(attr.inverted?10-nv:nv);
        saveArchetypes();
        if(mode==='archetypes'&&currentArch.id===kanriArch.id) renderAttrBars(kanriArch.scores,kanriArch.color);
      });
      srow.appendChild(slbl); srow.appendChild(sslider); srow.appendChild(snum);
      form.appendChild(srow);
    });

    panel.appendChild(form);
  }
}

// ─── Deep Link button ─────────────────────────────────────────────────────────
const deepLinkBtn = document.getElementById('btn-deeplink');
if (deepLinkBtn) {
  deepLinkBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      deepLinkBtn.textContent = 'Copied!';
      deepLinkBtn.style.color = '#00d4ff';
      deepLinkBtn.style.borderColor = '#00d4ff';
      setTimeout(() => {
        deepLinkBtn.textContent = 'Link';
        deepLinkBtn.style.color = '#6b7280';
        deepLinkBtn.style.borderColor = '#21262d';
      }, 1500);
    });
  });
}

// ─── Close pill dropdown on outside click ─────────────────────────────────────
document.addEventListener('click', (e) => {
  if (pillRail.style.display === 'flex' && !pillRail.contains(e.target) && e.target !== btnArch) {
    pillRail.style.display = 'none';
  }
});

// ─── Init ─────────────────────────────────────────────────────────────────────
buildPills();
buildSelfSliders();
setMode('archetypes');
// Restore from URL hash (deep link)
(function() {
  const h = location.hash;
  if (h.startsWith('#arch=')) {
    const arch = ARCHETYPES.find(a => a.id === h.slice(6));
    if (arch) selectArchetype(arch);
  } else if (h === '#mode=self') {
    setMode('self');
  }
})();
</script>

</BaseLayout>
