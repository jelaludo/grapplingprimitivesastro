// ─── Closest match ────────────────────────────────────────────────────────────
const MATCH_MSGS = {
  spaz:'Slow down. Awareness before speed.',
  injury:'Communicate your limits. Tap early. Rest when needed.',
  ig:'The gram won\'t help your guard. Train like no one\'s watching.',
  troll:'One fix away from excellent. You know which one.',
  gandalf:'Wisdom + technique = the ideal partner. You\'re almost there.',
  brute:'Technique is leverage. Strength fades. Learn to feel pressure.',
  competitor:'Dial it down. Not every round needs to be the finals.',
};
function findClosest(scores) {
  const candidates = ARCHETYPES.filter(a => !a.noMatch);
  let best=candidates[0]??ARCHETYPES[0], bestD=Infinity;
  candidates.forEach(a => {
    const d = Math.sqrt(ATTRIBUTES.reduce((s,attr) => { const diff=(scores[attr.id]??0)-(a.scores[attr.id]??0); return s+diff*diff; },0));
    if (d<bestD) { bestD=d; best=a; }
  });
  return { arch:best, pct:Math.round((1-bestD/Math.sqrt(ATTRIBUTES.length*100))*100) };
}
function updateSelfProfile() {
  const {arch,pct} = findClosest(selfScores);
  matchImg.src           = imgBase + arch.img;
  matchImg.alt           = arch.name;
  matchName.textContent  = arch.name;
  matchName.style.color  = arch.color;
  matchPct.textContent   = `${pct}% similar`;
  matchMsg.textContent   = MATCH_MSGS[arch.id] || '';
  charOverall.textContent= `AVG ${avgScore(selfScores)}`;
}

