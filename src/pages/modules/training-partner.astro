      const numEl = document.createElement('div');
      numEl.style.cssText = `position:absolute;right:6px;top:50%;transform:translateY(-50%);font-family:'DS-Digital',monospace;font-size:12px;font-weight:700;color:${fcolor};z-index:4;pointer-events:none;`;
      numEl.textContent = v;

