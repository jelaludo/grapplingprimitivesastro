---
import BaseLayout from '@/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Breathing — Grappling Primitives" fullscreen>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=optional" rel="stylesheet" />

  <!-- ── Toolbar ──────────────────────────────────────────────────────────────── -->
  <div id="toolbar" style="position:fixed;top:0;left:0;right:0;height:36px;z-index:50;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Source Code Pro','Courier New',monospace;">
    <a href={`${base}/`} style="font-size:12px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;text-decoration:none;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'">← Home</a>
    <span style="color:#21262d;">|</span>
    <span style="font-size:12px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;">Breathing</span>
    <div style="flex:1;"></div>
    <button id="btn-deeplink" style="font-family:inherit;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;" onmouseover="this.style.borderColor='rgba(0,212,255,0.4)';this.style.color='#00d4ff'" onmouseout="if(this.textContent==='Link'){this.style.borderColor='#21262d';this.style.color='#6b7280'}">Link</button>
  </div>

  <canvas id="c"></canvas>
  <button id="notes-toggle" title="Accuracy notes">+</button>
  <div id="notes-panel">
    <h3>Accuracy notes</h3>
    <ul id="notes-list"></ul>
  </div>

  <style>
    canvas { display: block; pointer-events: none; position: fixed; inset: 0; }

    #notes-toggle {
      position: fixed;
      bottom: 16px;
      left: 16px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(20, 20, 30, 0.7);
      color: rgba(255,255,255,0.35);
      font: 18px/1 sans-serif;
      cursor: pointer;
      z-index: 20;
      backdrop-filter: blur(8px);
      transition: color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #notes-toggle:hover { color: rgba(255,255,255,0.6); border-color: rgba(255,255,255,0.25); }

    #notes-panel {
      display: none;
      position: fixed;
      bottom: 60px;
      left: 16px;
      width: min(360px, calc(100vw - 32px));
      max-height: min(50vh, 400px);
      overflow-y: auto;
      padding: 14px 16px;
      background: rgba(20, 20, 30, 0.94);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      backdrop-filter: blur(12px);
      font: 13px/1.55 "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: #999;
      z-index: 20;
    }
    #notes-panel.open { display: block; }
    #notes-panel h3 {
      margin: 0 0 10px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #666;
    }
    #notes-panel ul { margin: 0; padding: 0 0 0 16px; }
    #notes-panel li { margin-bottom: 8px; }
  </style>

  <script>
    const TEXT = `The urge to breathe is primarily a CO\u2082 signal, not an oxygen signal. Panic-breathing dumps CO\u2082 too fast, which (Bohr Effect) reduces O\u2082 delivery to tissues. Low CO\u2082 tolerance and high anxiety are often the same problem wearing different masks: amygdala activation can trigger unconscious apnea, CO\u2082 spikes, and a fear response self-reinforcing loop. Training breath trains the nervous system.

Breath operates on two levels simultaneously: mechanical (intra-abdominal pressure, core stabilization, gas exchange) and regulatory (autonomic tone, amygdala suppression, state management). Pilates names this as \u201Clateral ribcage breathing,\u201D preserving deep abdominal engagement that belly breathing can undermine. \u201CExhale on exertion\u201D is another mantra; it has a direct physiological basis: inhalation during maximal effort is associated with reduced performance and degraded autonomic stability. The exhale is where core locks, power transfers, and the parasympathetic system gets going.

Sports science confirms the training effect is real. Slow-paced breathing shows large effect sizes on physical performance for longer-term interventions. The gains are both metabolic and psychological: lower heart rate, better O\u2082 absorption, reduced cortisol, sharper decision-making under load.

BJJ is a stress test. The practitioner breathes under positional compression, against resistance, while solving aggressive puzzles. Most beginners hold their breath in high-stress moments without realizing it, and once fight-or-flight kicks in, they stop solving problems and start reacting. Gassing out in BJJ is often not a cardio failure but a breath failure. The percussive exhale can break the panic-apnea cycle fast. Grapplers can exhale sharply on explosive moves to stabilize the core and transfer power\u2014same principle as Pilates, different context.

The exhale is the universal key. It clears CO\u2082, engages the core, and signals safety to the amygdala. In every domain (Pilates, strength training, grappling, etc.), the practitioner who controls the exhale does better.`;

    const NOTES = [
      '\u201CUrge to breathe is a CO\u2082 signal\u201D \u2013 Mostly correct. The dominant chemical drive is CO\u2082 via central chemoreceptors; low O\u2082 becomes a strong driver mainly in severe hypoxia.',
      'Panic-breathing + Bohr Effect \u2013 Accurate: hyperventilation \u2192 \u2193CO\u2082 \u2192 \u2191pH \u2192 left-shift of O\u2082-Hb curve \u2192 reduced O\u2082 offloading to tissues.',
      'Low CO\u2082 tolerance & anxiety \u2013 Conceptually reasonable; high anxiety often correlates with low CO\u2082 tolerance and hyperventilation, not strictly the same but similar.',
      'Amygdala \u2192 apnea \u2192 CO\u2082 spike \u2192 fear \u2013 Plausible as a pattern but oversimplified mechanistically.',
      'Breath on two levels (mechanical & regulatory) \u2013 Good framing. IAP, core engagement, gas exchange vs. autonomic tone / amygdala / state.',
      'Exhale on exertion \u2013 Correct: inhaling during maximal effort can reduce core stability and power transfer.',
      'Slow-paced breathing & effect sizes \u2013 Generally supported: slow breathing (~6 breaths/min) can improve HRV, reduce stress markers, and enhance perceived performance.',
      'BJJ as stress test / breath failure vs cardio failure \u2013 Very reasonable: many athletes gas out because of poor breathing mechanics and panic, not pure aerobic capacity.',
      'Percussive exhale breaks panic-apnea cycle \u2013 Plausible: a sharp exhale can reset breathing rhythm and reduce panic.',
      'Exhale as universal key \u2013 Strong but defensible as a coaching principle: exhale \u2192 CO\u2082 clearance, core engagement, parasympathetic signaling.',
    ];

    const FONT = '"Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    const TOOLBAR_H = 36;
    const PADDING = 60;
    const BREATH_PERIOD = 4500;
    const MAX_SCALE_OFFSET = 0.2;
    const MAX_ALPHA_OFFSET = 0.27;
    const BASE_ALPHA = 0.96;
    const WAVE_RADIUS = 1500;
    const WAVE_DELAY = 0.8;
    const DRIFT = 10;
    const FONT_SIZE = 15;
    const LINE_HEIGHT = 20;
    const MAX_TEXT_WIDTH = 570;

    const canvas = document.getElementById('c') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let dpr = window.devicePixelRatio || 1;

    type CharInfo = { char: string; x: number; y: number; w: number };

    let chars: CharInfo[] = [];
    let centerX = 0;
    let centerY = 0;
    let contentHeight = 0;
    let scrollY = 0;
    let needsRelayout = true;

    const graphemeSegmenter = typeof Intl !== 'undefined' && Intl.Segmenter
      ? new Intl.Segmenter(undefined, { granularity: 'grapheme' })
      : null;

    function splitGraphemes(text: string): string[] {
      if (graphemeSegmenter) return Array.from(graphemeSegmenter.segment(text), s => s.segment);
      return Array.from(text);
    }

    function getFont(): string {
      return `${FONT_SIZE}px ${FONT}`;
    }

    /** Simple word-wrap using canvas measureText */
    function wrapText(text: string, maxWidth: number): string[] {
      const font = getFont();
      ctx.font = font;
      const lines: string[] = [];
      const paragraphs = text.split('\n');
      for (const para of paragraphs) {
        if (para.trim() === '') { lines.push(''); continue; }
        const words = para.split(' ');
        let current = '';
        for (const word of words) {
          const test = current ? current + ' ' + word : word;
          if (ctx.measureText(test).width > maxWidth && current) {
            lines.push(current);
            current = word;
          } else {
            current = test;
          }
        }
        if (current) lines.push(current);
      }
      return lines;
    }

    function resize() {
      dpr = window.devicePixelRatio || 1;
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = `${window.innerWidth}px`;
      canvas.style.height = `${window.innerHeight}px`;
      needsRelayout = true;
    }

    function layoutText() {
      const font = getFont();
      const textWidth = Math.min(MAX_TEXT_WIDTH, window.innerWidth - PADDING * 2);
      ctx.save();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = font;

      const lines = wrapText(TEXT, textWidth);
      const totalHeight = lines.length * LINE_HEIGHT;
      const startX = Math.floor((window.innerWidth - textWidth) / 2);
      // If content fits below toolbar, center it; otherwise start with top padding
      const availH = window.innerHeight - TOOLBAR_H;
      const startY = totalHeight <= availH
        ? TOOLBAR_H + Math.floor((availH - totalHeight) / 2)
        : TOOLBAR_H + PADDING;

      contentHeight = totalHeight + PADDING * 2;
      centerX = window.innerWidth / 2;
      centerY = startY + totalHeight / 2;

      chars = [];
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const y = startY + i * LINE_HEIGHT;
        let x = startX;
        const graphemes = splitGraphemes(line);
        for (const g of graphemes) {
          const w = ctx.measureText(g).width;
          chars.push({ char: g, x, y, w });
          x += w;
        }
      }
      ctx.restore();
      needsRelayout = false;
    }

    function render(time: number) {
      if (needsRelayout) layoutText();

      ctx.save();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

      const phase = (time % BREATH_PERIOD) / BREATH_PERIOD;
      ctx.font = getFont();
      ctx.textBaseline = 'top';

      for (let i = 0; i < chars.length; i++) {
        const c = chars[i];
        if (c.char.trim() === '') continue;

        const charCenterX = c.x + c.w / 2;
        const charCenterY = c.y + FONT_SIZE / 2 - scrollY;

        // Skip chars that are off-screen
        if (charCenterY < -FONT_SIZE || charCenterY > window.innerHeight + FONT_SIZE) continue;
        const dx = charCenterX - centerX;
        const dy = charCenterY - (centerY - scrollY);
        const dist = Math.sqrt(dx * dx + dy * dy);

        const localPhase = phase - (dist / WAVE_RADIUS) * WAVE_DELAY;
        const localBreath = Math.sin(localPhase * Math.PI * 2);

        const proximity = Math.max(0, 1 - dist / WAVE_RADIUS);
        const soft = proximity * proximity;

        const scale = 1 + localBreath * MAX_SCALE_OFFSET * soft;
        const alpha = BASE_ALPHA + localBreath * MAX_ALPHA_OFFSET * soft;

        const driftMag = localBreath * DRIFT * soft;
        const angle = Math.atan2(dy, dx);
        const driftX = Math.cos(angle) * driftMag;
        const driftY = Math.sin(angle) * driftMag;

        ctx.save();
        ctx.globalAlpha = Math.max(0.15, Math.min(1, alpha));
        ctx.translate(charCenterX + driftX, charCenterY + driftY);
        ctx.scale(scale, scale);
        ctx.fillStyle = '#e8e4dc';
        ctx.fillText(c.char, -c.w / 2, -FONT_SIZE / 2);
        ctx.restore();
      }

      ctx.restore();
      requestAnimationFrame(render);
    }

    // Notes toggle
    const notesToggle = document.getElementById('notes-toggle');
    const notesPanel = document.getElementById('notes-panel');
    const notesList = document.getElementById('notes-list');
    if (notesToggle && notesPanel && notesList) {
      for (const note of NOTES) {
        const li = document.createElement('li');
        li.textContent = note;
        notesList.appendChild(li);
      }
      notesToggle.addEventListener('click', () => {
        notesPanel.classList.toggle('open');
        notesToggle.textContent = notesPanel.classList.contains('open') ? '\u00D7' : '+';
      });
    }

    function clampScroll() {
      const maxScroll = Math.max(0, contentHeight - window.innerHeight);
      scrollY = Math.max(0, Math.min(scrollY, maxScroll));
    }

    window.addEventListener('wheel', (e) => {
      scrollY += e.deltaY;
      clampScroll();
    }, { passive: true });

    // Touch scrolling
    let touchStartY = 0;
    let touchScrollStart = 0;
    window.addEventListener('touchstart', (e) => {
      touchStartY = e.touches[0].clientY;
      touchScrollStart = scrollY;
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      const dy = touchStartY - e.touches[0].clientY;
      scrollY = touchScrollStart + dy;
      clampScroll();
    }, { passive: true });

    // Deep link
    const deepLinkBtn = document.getElementById('btn-deeplink');
    if (deepLinkBtn) {
      deepLinkBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(location.href).then(() => {
          deepLinkBtn.textContent = 'Copied!';
          deepLinkBtn.style.color = '#00d4ff';
          deepLinkBtn.style.borderColor = '#00d4ff';
          setTimeout(() => {
            deepLinkBtn.textContent = 'Link';
            deepLinkBtn.style.color = '#6b7280';
            deepLinkBtn.style.borderColor = '#21262d';
          }, 1500);
        });
      });
    }

    window.addEventListener('resize', () => { resize(); clampScroll(); });
    document.fonts.ready.then(() => {
      resize();
      clampScroll();
      requestAnimationFrame(render);
    });
  </script>
</BaseLayout>
