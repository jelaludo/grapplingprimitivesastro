---
import BaseLayout from '@/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="BJJ Pricing Worldwide — Grappling Primitives" fullscreen={true}>

  <!-- Google Fonts + D3 -->
  <Fragment slot="default">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js"></script>
  </Fragment>

  <style>
    /* ── PRICING MODULE SCOPED STYLES ── */
    .pricing-page {
      --bg: #F7F6F2;
      --surface: #FFFFFF;
      --border: #E5E2D9;
      --text-primary: #1C1917;
      --text-secondary: #6B6560;
      --text-tertiary: #A09C96;
      --accent: #2D3BCD;
      --accent-light: #EEF0FC;
      --accent-muted: #7B86E0;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'IBM Plex Sans', system-ui, sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;

      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
      padding-top: 36px;
    }

    /* ── TOOLBAR ── */
    .pricing-toolbar {
      position: fixed; top: 0; left: 0; right: 0; height: 36px; z-index: 50;
      display: flex; align-items: center; gap: 10px; padding: 0 12px;
      border-bottom: 1px solid #21262d;
      background: rgba(5,5,9,0.97); backdrop-filter: blur(8px);
      font-family: 'Courier New', Consolas, Monaco, monospace;
    }
    .pricing-toolbar a {
      font-size: 10px; letter-spacing: 0.2em; color: #6b7280;
      text-transform: uppercase; text-decoration: none;
    }
    .pricing-toolbar a:hover { color: #00d4ff; }
    .pricing-toolbar span.sep { color: #21262d; }
    .pricing-toolbar span.title {
      font-size: 11px; letter-spacing: 0.2em; color: #6b7280;
      text-transform: uppercase; user-select: none;
    }

    /* ── HEADER ── */
    .top-bar {
      max-width: 1200px; margin: 0 auto; padding: 24px 48px 0;
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .top-bar h1 {
      font-family: var(--font-display); font-size: 24px;
      font-weight: 600; letter-spacing: -0.02em;
    }
    .top-bar-right { display: flex; align-items: center; gap: 12px; }

    /* ── CURRENCY TOGGLE ── */
    .currency-group {
      display: flex; align-items: center; background: var(--surface);
      border: 1px solid var(--border); border-radius: 8px; padding: 3px; gap: 2px;
    }
    .currency-btn {
      font-family: var(--font-mono); font-size: 11px; font-weight: 500;
      padding: 5px 13px; border-radius: 5px; border: none;
      background: transparent; color: var(--text-secondary);
      cursor: pointer; transition: all 0.15s ease; letter-spacing: 0.04em;
    }
    .currency-btn:hover { color: var(--text-primary); }
    .currency-btn.active { background: var(--accent); color: white; }

    /* ── RATE NOTE ── */
    .rate-note-bar {
      max-width: 1200px; margin: 0 auto; padding: 5px 48px 0; text-align: right;
    }
    .rate-note {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--text-tertiary); letter-spacing: 0.03em;
    }

    /* ── TABS ── */
    .tab-bar-wrap { max-width: 1200px; margin: 0 auto; padding: 16px 48px 0; }
    .tab-bar { display: flex; border-bottom: 1px solid var(--border); }
    .tab-btn {
      font-family: var(--font-body); font-size: 13px; font-weight: 500;
      padding: 9px 22px; border: none; border-bottom: 2px solid transparent;
      background: transparent; color: var(--text-tertiary);
      cursor: pointer; margin-bottom: -1px; transition: all 0.15s ease;
    }
    .tab-btn:hover { color: var(--text-primary); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ── PANELS ── */
    .pricing-page .panel { display: none; }
    .pricing-page .panel.active { display: block; }

    /* ── LAYOUT ── */
    .pricing-page main {
      max-width: 1200px; margin: 0 auto; padding: 0 48px 80px;
    }
    .pricing-page section { padding: 32px 0; }
    .section-header {
      display: flex; align-items: baseline; justify-content: space-between;
      margin-bottom: 24px; flex-wrap: wrap; gap: 10px;
    }
    .section-title {
      font-family: var(--font-display); font-size: 21px;
      font-weight: 600; letter-spacing: -0.01em;
    }
    .section-subtitle { font-size: 12px; color: var(--text-secondary); font-weight: 300; }

    /* ── SUMMARY STRIP ── */
    .summary-strip {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1px; background: var(--border); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden; margin-bottom: 24px;
    }
    .summary-cell {
      background: var(--surface); padding: 14px 18px;
      display: flex; flex-direction: column; gap: 2px;
    }
    .summary-cell-label {
      font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-tertiary);
    }
    .summary-cell-value {
      font-family: var(--font-display); font-size: 21px;
      font-weight: 700; letter-spacing: -0.02em;
    }
    .summary-cell-sub { font-size: 10px; color: var(--text-secondary); }

    /* ── MAP ── */
    .map-container {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 22px; margin-bottom: 24px;
    }
    .map-label {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 14px;
    }
    #region-map { width: 100%; display: block; cursor: pointer; }
    .region-shape { transition: all 0.2s ease; cursor: pointer; }
    .region-shape:hover { opacity: 0.85; }
    .region-text {
      font-family: 'IBM Plex Sans', sans-serif; font-size: 11px; font-weight: 500;
      fill: white; pointer-events: none; text-anchor: middle;
    }
    .region-subtext {
      font-family: 'IBM Plex Mono', monospace; font-size: 9px;
      fill: rgba(255,255,255,0.85); pointer-events: none; text-anchor: middle;
    }
    .region-hint {
      font-size: 11px; color: var(--text-tertiary); margin-top: 9px; font-style: italic;
    }

    /* ── SELECTION BAR ── */
    .selection-bar {
      display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
      padding: 8px 14px; background: var(--accent-light); border-radius: 8px;
      border: 1px solid rgba(79,70,229,0.15);
    }
    .selection-bar-dot {
      width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0;
    }
    .selection-bar-text {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--accent); letter-spacing: 0.04em;
    }
    .selection-clear {
      margin-left: auto; font-size: 11px; color: var(--accent); cursor: pointer;
      text-decoration: underline; background: none; border: none;
      font-family: var(--font-body); padding: 0;
    }
    .selection-clear:hover { opacity: 0.7; }

    /* ── BOX PLOT CARDS ── */
    .boxplot-grid { display: grid; gap: 18px; }
    .boxplot-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 22px 26px; transition: border-color 0.2s;
    }
    .boxplot-card:hover { border-color: var(--accent-muted); }
    .boxplot-card-header {
      display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;
    }
    .boxplot-tier {
      font-family: var(--font-display); font-size: 16px;
      font-weight: 600; letter-spacing: -0.01em;
    }
    .boxplot-badge {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em;
      text-transform: uppercase; padding: 3px 10px; border-radius: 20px;
      background: var(--accent-light); color: var(--accent);
    }
    .legend-row {
      display: flex; gap: 18px; flex-wrap: wrap;
      margin-top: 6px; padding-top: 10px; border-top: 1px solid var(--border);
    }
    .legend-item {
      display: flex; align-items: center; gap: 7px;
      font-size: 10px; color: var(--text-secondary);
    }
    .legend-swatch { width: 18px; height: 3px; border-radius: 2px; }
    .legend-dot { width: 8px; height: 8px; border-radius: 50%; }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center; padding: 40px 0;
      color: var(--text-tertiary); font-size: 13px;
    }
    .empty-state-icon { font-size: 26px; margin-bottom: 10px; }

    /* ── SEMINAR ── */
    .seminar-grid { display: flex; flex-direction: column; gap: 22px; }
    .seminar-row {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 22px 26px;
    }
    .seminar-row-header {
      display: flex; align-items: flex-start; gap: 14px; margin-bottom: 16px;
    }
    .seminar-rank-badge {
      width: 34px; height: 34px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .seminar-row-info h3 {
      font-family: var(--font-display); font-size: 17px; font-weight: 600;
      letter-spacing: -0.01em; margin-bottom: 3px;
    }
    .seminar-row-info p { font-size: 12px; color: var(--text-secondary); font-weight: 300; }
    .seminar-tags { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 6px; }
    .seminar-tag {
      font-size: 10px; padding: 3px 10px; border-radius: 20px; font-family: var(--font-mono);
    }

    /* ── SEMINAR SUB-TABS ── */
    .seminar-subtab-bar { display: flex; gap: 6px; margin-bottom: 24px; flex-wrap: wrap; }
    .seminar-subtab-btn {
      font-family: var(--font-mono); font-size: 11px; font-weight: 500;
      letter-spacing: 0.05em; padding: 6px 16px; border-radius: 20px;
      border: 1px solid var(--border); background: var(--surface);
      color: var(--text-secondary); cursor: pointer; transition: all 0.15s ease;
      display: flex; align-items: center; gap: 6px;
    }
    .seminar-subtab-btn:hover { border-color: var(--text-tertiary); color: var(--text-primary); }
    .seminar-subtab-btn.active {
      background: var(--text-primary); border-color: var(--text-primary); color: white;
    }
    .seminar-subtab-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .seminar-context-note {
      font-size: 11px; color: var(--text-tertiary); font-style: italic;
      margin-bottom: 18px; padding: 8px 12px; background: var(--bg);
      border-radius: 6px; border-left: 2px solid var(--border);
    }

    /* ── TOOLTIP ── */
    .pricing-tooltip {
      position: fixed; background: var(--text-primary); color: white;
      padding: 11px 15px; border-radius: 8px; font-size: 12px; line-height: 1.6;
      max-width: 260px; pointer-events: none; opacity: 0;
      transition: opacity 0.12s ease; z-index: 9999;
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    .pricing-tooltip.visible { opacity: 1; }
    .tooltip-title { font-weight: 600; font-size: 12px; margin-bottom: 5px; }
    .tooltip-price { font-family: var(--font-mono); font-size: 14px; font-weight: 500; color: #93C5FD; margin-bottom: 5px; }
    .tooltip-examples { color: #D1D5DB; font-size: 11px; }
    .tooltip-example { display: block; padding: 1px 0; }

    /* ── FOOTER ── */
    .pricing-page footer {
      padding: 22px 48px; max-width: 1200px; margin: 0 auto;
      border-top: 1px solid var(--border);
    }
    .footer-text { font-size: 10px; color: var(--text-tertiary); line-height: 1.8; }

    @media (max-width: 768px) {
      .top-bar, .rate-note-bar, .tab-bar-wrap, .pricing-page main, .pricing-page footer {
        padding-left: 20px; padding-right: 20px;
      }
      .map-container { padding: 16px; }
    }
  </style>

  <!-- ── Toolbar ── -->
  <div class="pricing-toolbar">
    <a href={`${base}/`}>← Home</a>
    <span class="sep">|</span>
    <span class="title">BJJ Pricing</span>
    <div style="flex:1;"></div>
    <button id="btn-deeplink" style="font-family:inherit;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;" onmouseover="this.style.borderColor='rgba(0,212,255,0.4)';this.style.color='#00d4ff'" onmouseout="if(this.textContent==='Link'){this.style.borderColor='#21262d';this.style.color='#6b7280'}">Link</button>
  </div>

  <!-- ── Page wrapper ── -->
  <div class="pricing-page">

    <div class="pricing-tooltip" id="tooltip">
      <div class="tooltip-title" id="tt-title"></div>
      <div class="tooltip-price" id="tt-price"></div>
      <div class="tooltip-examples" id="tt-examples"></div>
    </div>

    <!-- TOP BAR -->
    <div class="top-bar">
      <h1>BJJ Pricing Worldwide</h1>
      <div class="top-bar-right">
        <div class="currency-group">
          <button class="currency-btn active" data-currency="USD" onclick="setCurrency('USD')">USD</button>
          <button class="currency-btn" data-currency="EUR" onclick="setCurrency('EUR')">EUR</button>
          <button class="currency-btn" data-currency="JPY" onclick="setCurrency('JPY')">JPY</button>
        </div>
      </div>
    </div>

    <div class="rate-note-bar">
      <span class="rate-note" id="rate-note">Showing USD · assumed rates: 1 USD = 0.91 EUR = 149 JPY</span>
    </div>

    <!-- TABS -->
    <div class="tab-bar-wrap">
      <div class="tab-bar">
        <button class="tab-btn active" onclick="switchTab('monthly')">Monthly Memberships</button>
        <button class="tab-btn" onclick="switchTab('seminars')">Seminar Fees</button>
      </div>
    </div>

    <main>
      <!-- PANEL: MONTHLY -->
      <div class="panel active" id="panel-monthly">
        <section>
          <div class="section-header">
            <div>
              <h2 class="section-title">Monthly Memberships</h2>
              <p class="section-subtitle">Adult unlimited plan (or closest available) · displaying <span id="mem-currency-label">USD</span></p>
            </div>
          </div>
          <div class="summary-strip" id="summary-strip"></div>
          <div class="map-container">
            <div class="map-label">Click a region to explore pricing tiers</div>
            <svg id="region-map" viewBox="0 0 900 295" preserveAspectRatio="xMidYMid meet"></svg>
            <div class="region-hint">Select a region to view detailed pricing breakdown below</div>
          </div>
          <div class="selection-bar" id="selection-bar" style="display:none">
            <div class="selection-bar-dot"></div>
            <span class="selection-bar-text" id="selection-bar-text"></span>
            <button class="selection-clear" onclick="clearRegion()">Clear</button>
          </div>
          <div id="boxplot-container">
            <div class="empty-state">
              <div class="empty-state-icon">🗺</div>
              <div>Select a region on the map to view detailed pricing tiers</div>
            </div>
          </div>
        </section>
      </div>

      <!-- PANEL: SEMINARS -->
      <div class="panel" id="panel-seminars">
        <section>
          <div class="section-header">
            <div>
              <h2 class="section-title">Seminar Fees</h2>
              <p class="section-subtitle">Per-person fee for a 2-4 hour session · displaying <span id="sem-currency-label">USD</span></p>
            </div>
          </div>

          <!-- Seminar sub-tabs -->
          <div class="seminar-subtab-bar">
            <button class="seminar-subtab-btn active" data-semview="global" onclick="switchSeminarTab('global')">
              <span class="seminar-subtab-dot" style="background:#6B7280"></span>Global
            </button>
            <button class="seminar-subtab-btn" data-semview="us" onclick="switchSeminarTab('us')">
              <span class="seminar-subtab-dot" style="background:#2D3BCD"></span>USD / US
            </button>
            <button class="seminar-subtab-btn" data-semview="eu" onclick="switchSeminarTab('eu')">
              <span class="seminar-subtab-dot" style="background:#7C3AED"></span>EUR / EU
            </button>
            <button class="seminar-subtab-btn" data-semview="jp" onclick="switchSeminarTab('jp')">
              <span class="seminar-subtab-dot" style="background:#B45309"></span>JPY / JP
            </button>
          </div>

          <div class="seminar-context-note" id="seminar-context-note">
            Global ranges aggregated across all regions. Currency toggle applies to display only.
          </div>

          <div class="seminar-grid" id="seminar-grid"></div>
        </section>
      </div>
    </main>

    <footer>
      <p class="footer-text">
        Sources: gym price pages, White Belt Club 2025 guide, BJJEE, Kioto BJJ, Novakik BJJ, r/bjj and r/Tokyo forums, individual academy websites.
        <br>Exchange rate assumptions (approximate, stable rates used for display conversion only):
        <strong>1 USD = 0.91 EUR = 149 JPY · 1 EUR = 1.10 USD · 1 GBP = 1.25 USD.</strong>
        All membership data reflects adult unlimited plans as of 2024-2025. Data stored internally in USD.
      </p>
    </footer>

  </div><!-- /.pricing-page -->

  <script is:inline>
  // ─────────────────────────────────────────────
  // CURRENCY
  // ─────────────────────────────────────────────
  const RATES  = { USD: 1, EUR: 0.91, JPY: 149 };
  const SYMBOLS = { USD: '$', EUR: '€', JPY: '¥' };
  const RATE_NOTES = {
    USD: 'Showing USD · assumed rates: 1 USD = 0.91 EUR = 149 JPY',
    EUR: 'Showing EUR · assumed rates: 1 EUR = 1.10 USD = 164 JPY',
    JPY: 'Showing JPY · assumed rates: 100 JPY = 0.67 USD = 0.61 EUR',
  };

  let currentCurrency = 'USD';

  function cv(usdVal) {
    const v = usdVal * RATES[currentCurrency];
    if (currentCurrency === 'JPY') return Math.round(v / 100) * 100;
    return Math.round(v);
  }
  function fmt(usdVal) {
    const v = cv(usdVal);
    if (currentCurrency === 'JPY') return '¥' + v.toLocaleString();
    return SYMBOLS[currentCurrency] + v;
  }

  function setCurrency(c) {
    currentCurrency = c;
    document.querySelectorAll('.currency-btn').forEach(b =>
      b.classList.toggle('active', b.dataset.currency === c));
    document.getElementById('rate-note').textContent = RATE_NOTES[c];
    document.getElementById('mem-currency-label').textContent = c;
    document.getElementById('sem-currency-label').textContent = c;
    buildSummaryStrip();
    updateMapLabels();
    if (selectedRegion) renderBoxPlots();
    document.getElementById('seminar-context-note').textContent = SEMINAR_DATASETS[currentSeminarView].context;
    document.getElementById('seminar-grid').innerHTML = '';
    buildSeminars();
  }

  // ─────────────────────────────────────────────
  // DATA  (all prices internally in USD)
  // ─────────────────────────────────────────────
  const REGIONS = [
    {
      id:'us', name:'United States', color:'#2D3BCD',
      mapX:55, mapY:65, mapW:220, mapH:148,
      summaryMedian:160, summaryColor:'#2D3BCD',
      tiers:[
        { label:'Mainstream', badge:'Most commercial gyms',
          min:120, q1:135, median:160, q3:182, max:200, outliers:[],
          examples:[
            {name:'New England BJJ Academy', city:'Massachusetts', price_usd:160},
            {name:'Orlando BJJ',              city:'Florida',       price_usd:180},
            {name:'Typical TX / FL gym',      city:'TX / FL',       price_usd:165},
          ]},
        { label:'Big-city & Elite', badge:'NYC · LA · SF · Top teams',
          min:200, q1:220, median:262, q3:282, max:300, outliers:[325],
          examples:[
            {name:'NYC academies',             city:'New York',      price_usd:215},
            {name:'LA / SF elite teams',       city:'California',    price_usd:265},
            {name:'World-champion affiliates', city:'US nationwide', price_usd:285},
          ]},
      ]
    },
    {
      id:'uk', name:'United Kingdom', color:'#059669',
      mapX:350, mapY:42, mapW:78, mapH:88,
      summaryMedian:90, summaryColor:'#059669',
      tiers:[
        { label:'Regional UK', badge:'Outside London',
          min:70, q1:78, median:90, q3:100, max:110, outliers:[],
          examples:[
            {name:'Peak Jiu Jitsu',       city:'UK regional',  price_usd:75},
            {name:'Average commercial gym', city:'UK nationwide', price_usd:90},
          ]},
        { label:'London', badge:'Central & prestige gyms',
          min:120, q1:138, median:155, q3:172, max:200, outliers:[250,340],
          examples:[
            {name:'Fightzone London', city:'London', price_usd:131},
            {name:'GB Top Team',       city:'London', price_usd:200},
            {name:'Outlier super-gyms', city:'London', price_usd:320},
          ]},
      ]
    },
    {
      id:'br', name:'Brazil', color:'#16A34A',
      mapX:135, mapY:145, mapW:168, mapH:128,
      summaryMedian:35, summaryColor:'#16A34A',
      tiers:[
        { label:'Favela / Community', badge:'Social-project gyms',
          min:7, q1:10, median:15, q3:20, max:25, outliers:[],
          examples:[
            {name:'Community project gyms', city:'Rio favelas', price_usd:10},
            {name:'Small-city academies',   city:'Interior',    price_usd:20},
          ]},
        { label:'Mainstream', badge:'City academies',
          min:20, q1:25, median:35, q3:44, max:55, outliers:[],
          examples:[
            {name:'Standard Rio academy', city:'Rio de Janeiro', price_usd:30},
            {name:'São Paulo mid-tier',   city:'São Paulo',      price_usd:40},
          ]},
        { label:'Elite', badge:'Alliance · Atos · GFTeam HQ',
          min:55, q1:62, median:75, q3:88, max:100, outliers:[120],
          examples:[
            {name:'Alliance HQ',  city:'São Paulo', price_usd:75},
            {name:'Atos HQ',      city:'São Paulo', price_usd:80},
            {name:'Premium plan', city:'Rio',        price_usd:100},
          ]},
      ]
    },
    {
      id:'weu', name:'Western EU', color:'#7C3AED',
      mapX:432, mapY:70, mapW:140, mapH:128,
      summaryMedian:90, summaryColor:'#7C3AED',
      tiers:[
        { label:'Club / Verein', badge:'Sports-club model',
          min:35, q1:44, median:50, q3:57, max:65, outliers:[],
