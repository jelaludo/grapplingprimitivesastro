  // ─────────────────────────────────────────────
  // TABS
  // ─────────────────────────────────────────────
  function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach((b, i) =>
      b.classList.toggle('active', ['monthly','seminars'][i] === name));
    document.querySelectorAll('.pricing-page .panel').forEach(p =>
      p.classList.toggle('active', p.id === 'panel-' + name));
  }

  // ─────────────────────────────────────────────
  // SEMINAR SUB-TABS
  // ─────────────────────────────────────────────
  let currentSeminarView = 'global';

  function switchSeminarTab(view) {
    currentSeminarView = view;
    document.querySelectorAll('.seminar-subtab-btn').forEach(b =>
      b.classList.toggle('active', b.dataset.semview === view));
    document.getElementById('seminar-context-note').textContent =
      SEMINAR_DATASETS[view].context;
    document.getElementById('seminar-grid').innerHTML = '';
    buildSeminars();
  }

  // ─────────────────────────────────────────────
  // TOOLTIP
  // ─────────────────────────────────────────────
  const tooltip    = document.getElementById('tooltip');
  const ttTitle    = document.getElementById('tt-title');
  const ttPrice    = document.getElementById('tt-price');
  const ttExamples = document.getElementById('tt-examples');

  function showTooltip(evt, title, priceStr, lines) {
    ttTitle.textContent = title;
    ttPrice.textContent = priceStr;
    ttExamples.innerHTML = lines.map(l => '<span class="tooltip-example">• ' + l + '</span>').join('');
    tooltip.classList.add('visible');
    moveTooltip(evt);
  }
  function moveTooltip(evt) {
    var x = evt.clientX + 14, y = evt.clientY - 10;
    var tw = 260, th = 130;
    tooltip.style.left = (x + tw > window.innerWidth  ? x - tw - 28 : x) + 'px';
    tooltip.style.top  = (y + th > window.innerHeight ? y - th      : y) + 'px';
  }
  function hideTooltip() { tooltip.classList.remove('visible'); }
  document.addEventListener('mousemove', function(e) {
    if (tooltip.classList.contains('visible')) moveTooltip(e);
  });

  // ─────────────────────────────────────────────
  // SUMMARY STRIP
  // ─────────────────────────────────────────────
  function buildSummaryStrip() {
    document.getElementById('summary-strip').innerHTML =
      REGIONS.map(function(r) { return '\
        <div class="summary-cell">\
          <span class="summary-cell-label">' + r.name + '</span>\
          <span class="summary-cell-value" style="color:' + r.summaryColor + '">' + fmt(r.summaryMedian) + '</span>\
          <span class="summary-cell-sub">median / month</span>\
        </div>';
      }).join('');
  }

  // ─────────────────────────────────────────────
  // MAP
  // ─────────────────────────────────────────────
  function buildMap() {
    var svg = d3.select('#region-map');
    var W = 900, H = 295;

    // Subtle grid
    var gridG = svg.append('g');
    for (var x = 0; x <= W; x += 60)
      gridG.append('line').attr('x1',x).attr('y1',0).attr('x2',x).attr('y2',H)
        .attr('stroke','#E5E2D9').attr('stroke-width',0.5);
    for (var y = 0; y <= H; y += 60)
      gridG.append('line').attr('x1',0).attr('y1',y).attr('x2',W).attr('y2',y)
        .attr('stroke','#E5E2D9').attr('stroke-width',0.5);

    // Continent area labels
    [{t:'AMERICAS',x:165},{t:'EUROPE',x:507},{t:'EAST ASIA',x:789}].forEach(function(l) {
      svg.append('text').text(l.t)
        .attr('x',l.x).attr('y',260)
        .attr('fill','#C8C4BC').attr('font-size',8).attr('letter-spacing',3)
        .attr('font-family','IBM Plex Mono').attr('text-anchor','middle');
    });

    // Zone dividers
    [[328,18,328,248],[694,18,694,248]].forEach(function(c) {
      svg.append('line').attr('x1',c[0]).attr('y1',c[1]).attr('x2',c[2]).attr('y2',c[3])
        .attr('stroke','#D0CCC4').attr('stroke-width',1).attr('stroke-dasharray','4,4');
    });

    // Region blobs
    REGIONS.forEach(function(r) {
      var g = svg.append('g').attr('class','region-shape').datum(r)
        .on('click', function(_,d) { selectRegion(d.id); })
        .on('mouseenter', function(evt,d) {
          var lines = d.tiers.map(function(t) { return t.label + ': ' + fmt(t.median) + '/mo'; });
          showTooltip(evt, d.name,
            fmt(Math.min.apply(null, d.tiers.map(function(t){return t.min;}))) + '–' +
            fmt(Math.max.apply(null, d.tiers.map(function(t){return t.max;}))) + '/mo',
            lines);
        })
        .on('mouseleave', hideTooltip);

      g.append('rect')
        .attr('x',r.mapX).attr('y',r.mapY)
        .attr('width',r.mapW).attr('height',r.mapH)
        .attr('rx',10).attr('ry',10)
        .attr('fill',r.color).attr('stroke',r.color).attr('stroke-width',1.5)
        .attr('id','region-rect-' + r.id);

      var cx = r.mapX + r.mapW/2;
      var cy = r.mapY + r.mapH/2;
      g.append('text').text(r.name).attr('x',cx).attr('y',cy-8).attr('class','region-text');
      g.append('text').attr('x',cx).attr('y',cy+9).attr('class','region-subtext').attr('id','map-price-' + r.id);
      g.append('text').text(r.tiers.length + ' tier' + (r.tiers.length>1?'s':''))
        .attr('x',cx).attr('y',cy+23).attr('class','region-subtext').style('opacity',0.65);
    });

    updateMapLabels();
  }

  function updateMapLabels() {
    REGIONS.forEach(function(r) {
      var el = document.getElementById('map-price-' + r.id);
      if (!el) return;
      var ms = r.tiers.map(function(t) { return t.median; });
      el.textContent = ms.length === 1
        ? fmt(ms[0]) + '/mo'
        : fmt(Math.min.apply(null, ms)) + '–' + fmt(Math.max.apply(null, ms)) + '/mo';
    });
  }

  // ─────────────────────────────────────────────
  // REGION SELECTION
  // ─────────────────────────────────────────────
  var selectedRegion = null;

  function selectRegion(id) {
    selectedRegion = selectedRegion === id ? null : id;
    updateMapState();
    renderBoxPlots();
    updateSelectionBar();
  }
  function clearRegion() {
    selectedRegion = null;
    updateMapState();
    renderBoxPlots();
    updateSelectionBar();
  }
  function updateMapState() {
    REGIONS.forEach(function(r) {
      var rect = document.getElementById('region-rect-' + r.id);
      if (!rect) return;
      var isActive = r.id === selectedRegion;
      rect.style.opacity     = !selectedRegion || isActive ? '1' : '0.28';
      rect.style.filter      = isActive ? 'brightness(1.1)' : 'none';
      rect.style.strokeWidth = isActive ? '3' : '1.5';
    });
  }
  function updateSelectionBar() {
    var bar = document.getElementById('selection-bar');
    var txt = document.getElementById('selection-bar-text');
    if (selectedRegion) {
      var r = REGIONS.find(function(r) { return r.id === selectedRegion; });
      bar.style.display = 'flex';
      txt.textContent = 'Viewing: ' + r.name + ' — ' + r.tiers.length + ' pricing tier' + (r.tiers.length>1?'s':'');
    } else {
      bar.style.display = 'none';
    }
  }

  // ─────────────────────────────────────────────
  // BOX PLOTS
  // ─────────────────────────────────────────────
  function renderBoxPlots() {
    var container = document.getElementById('boxplot-container');
    if (!selectedRegion) {
      container.innerHTML = '\
        <div class="empty-state">\
          <div class="empty-state-icon">🗺</div>\
          <div>Select a region on the map to view detailed pricing tiers</div>\
        </div>';
      return;
    }
    var region = REGIONS.find(function(r) { return r.id === selectedRegion; });
    container.innerHTML = '';

    var allUsd = region.tiers.flatMap(function(t) { return [t.min].concat(t.outliers, [t.max]); });
    var dMinUsd = Math.max(0, Math.min.apply(null, allUsd) - 15);
    var dMaxUsd = Math.max.apply(null, allUsd) + 25;

    region.tiers.forEach(function(tier) {
      var safeId = 'bp-' + tier.label.replace(/[^a-zA-Z0-9]/g,'-').toLowerCase();
      var card = document.createElement('div');
      card.className = 'boxplot-card';
      card.innerHTML = '\
        <div class="boxplot-card-header">\
          <div class="boxplot-tier">' + tier.label + '</div>\
          <div class="boxplot-badge">' + tier.badge + '</div>\
        </div>\
        <div id="' + safeId + '"></div>\
        <div class="legend-row">\
          <div class="legend-item">\
            <div class="legend-swatch" style="background:' + region.color + '"></div><span>Typical range (Q1–Q3)</span>\
          </div>\
          <div class="legend-item">\
            <div class="legend-dot" style="background:' + region.color + '"></div><span>Median</span>\
          </div>\
          <div class="legend-item">\
            <div class="legend-swatch" style="background:' + region.color + '; opacity:0.3"></div><span>Full range</span>\
          </div>' +
          (tier.outliers.length ? '\
          <div class="legend-item">\
            <div class="legend-dot" style="background:transparent;border:2px solid #EF4444;width:9px;height:9px"></div><span>Outliers</span>\
          </div>' : '') +
        '</div>';
      container.appendChild(card);
      drawBoxPlot(safeId, tier, region.color, dMinUsd, dMaxUsd);
    });
  }

  function drawBoxPlot(cid, tier, color, dMinUsd, dMaxUsd) {
    var el = document.getElementById(cid);
    if (!el) return;
    var W = el.parentElement.clientWidth - 52;
    var H = 92, mL=6, mR=6, mT=22, mB=22;
    var iW = W-mL-mR, iH = H-mT-mB, cy = iH/2;

    var svg = d3.select('#' + cid).append('svg').attr('width',W).attr('height',H);
    var g   = svg.append('g').attr('transform','translate(' + mL + ',' + mT + ')');

    var x = d3.scaleLinear().domain([cv(dMinUsd), cv(dMaxUsd)]).range([0, iW]);

    // Grid + axis
    d3.scaleLinear().domain([dMinUsd, dMaxUsd]).ticks(6).forEach(function(t) {
      var px = x(cv(t));
      g.append('line').attr('x1',px).attr('x2',px).attr('y1',0).attr('y2',iH)
        .attr('stroke','#E5E2D9').attr('stroke-width',1);
      g.append('text').text(fmt(t))
        .attr('x',px).attr('y',iH+14).attr('text-anchor','middle')
        .attr('fill','#A09C96').attr('font-size',9).attr('font-family','IBM Plex Mono');
    });

    // Whisker
    g.append('line')
      .attr('x1',x(cv(tier.min))).attr('x2',x(cv(tier.max))).attr('y1',cy).attr('y2',cy)
      .attr('stroke',color).attr('stroke-width',2).attr('opacity',0.28);
    [tier.min, tier.max].forEach(function(v) {
      g.append('line')
        .attr('x1',x(cv(v))).attr('x2',x(cv(v))).attr('y1',cy-9).attr('y2',cy+9)
        .attr('stroke',color).attr('stroke-width',2).attr('opacity',0.45);
    });

    // IQR box fill
    var bH = 26;
    g.append('rect')
      .attr('x',x(cv(tier.q1))).attr('y',cy-bH/2)
      .attr('width',x(cv(tier.q3))-x(cv(tier.q1))).attr('height',bH)
      .attr('fill',color).attr('opacity',0.12).attr('rx',4);
    // IQR box border (interactive)
    g.append('rect')
      .attr('x',x(cv(tier.q1))).attr('y',cy-bH/2)
      .attr('width',x(cv(tier.q3))-x(cv(tier.q1))).attr('height',bH)
      .attr('fill','none').attr('stroke',color).attr('stroke-width',1.5).attr('rx',4)
      .style('cursor','pointer')
      .on('mouseenter', function(evt) {
        var lines = tier.examples.map(function(e) { return e.name + ' (' + e.city + '): ' + fmt(e.price_usd) + '/mo'; });
        showTooltip(evt, tier.label, 'Typical: ' + fmt(tier.q1) + '–' + fmt(tier.q3) + '/mo', lines);
      })
      .on('mouseleave', hideTooltip);

    // Median line + label
    g.append('line')
      .attr('x1',x(cv(tier.median))).attr('x2',x(cv(tier.median)))
      .attr('y1',cy-bH/2-2).attr('y2',cy+bH/2+2)
      .attr('stroke',color).attr('stroke-width',2.5);
    g.append('text').text(fmt(tier.median))
      .attr('x',x(cv(tier.median))).attr('y',cy-bH/2-5)
      .attr('text-anchor','middle').attr('fill',color)
      .attr('font-size',11).attr('font-weight','600').attr('font-family','IBM Plex Mono');

    // Outliers
    tier.outliers.forEach(function(v) {
      g.append('circle')
        .attr('cx',x(cv(v))).attr('cy',cy).attr('r',5)
        .attr('fill','none').attr('stroke','#EF4444').attr('stroke-width',2)
        .style('cursor','pointer')
        .on('mouseenter', function(evt) { showTooltip(evt,'Outlier', fmt(v)+'/mo',
          ['Premium / superstar-affiliated gym','Above typical market rate']); })
        .on('mouseleave', hideTooltip);
    });

    // Min/Max labels below whiskers
    [tier.min, tier.max].forEach(function(v) {
      g.append('text').text(fmt(v))
        .attr('x',x(cv(v))).attr('y',cy+bH/2+14)
        .attr('text-anchor','middle').attr('fill','#B0ACA6')
        .attr('font-size',9).attr('font-family','IBM Plex Mono');
    });
  }

  // ─────────────────────────────────────────────
  // SEMINARS
  // ─────────────────────────────────────────────
  function buildSeminars() {
    var grid = document.getElementById('seminar-grid');
    var dataset = SEMINAR_DATASETS[currentSeminarView].tiers;
    var dMaxUsd = Math.max.apply(null, dataset.map(function(s) { return s.max; })) + 30;

    dataset.forEach(function(s, i) {
      var tags = s.examples_usd.map(function(e) {
        var str = e.min === e.max
          ? e.label + ': ' + fmt(e.min)
          : e.label + ': ' + fmt(e.min) + '–' + fmt(e.max);
        return '<span class="seminar-tag" style="background:' + s.badgeBg + ';color:' + s.badgeColor + '">' + str + '</span>';
      }).join('');

      var row = document.createElement('div');
      row.className = 'seminar-row';
      row.innerHTML = '\
        <div class="seminar-row-header">\
          <div class="seminar-rank-badge" style="background:' + s.badgeBg + '">' + s.badge + '</div>\
          <div class="seminar-row-info">\
            <h3>' + s.tier + '</h3>\
            <p>' + s.description + '</p>\
          </div>\
        </div>\
        <div id="sem-chart-' + i + '"></div>\
        <div style="margin-top:10px;font-size:11px;color:var(--text-secondary);font-style:italic;padding-top:10px;border-top:1px solid var(--border)">' + s.note + '</div>\
        <div class="seminar-tags">' + tags + '</div>';
      grid.appendChild(row);
      drawSeminarBar('sem-chart-' + i, s, dMaxUsd);
    });
  }

  function drawSeminarBar(cid, s, dMaxUsd) {
    var el = document.getElementById(cid);
    if (!el) return;
    var W = el.parentElement.clientWidth - 52;
    var H = 75, mL=6, mR=6, mT=18, mB=22;
    var iW = W-mL-mR, iH = H-mT-mB, cy = iH/2;

    var svg = d3.select('#' + cid).append('svg').attr('width',W).attr('height',H);
    var g   = svg.append('g').attr('transform','translate(' + mL + ',' + mT + ')');

    var x = d3.scaleLinear().domain([cv(0), cv(dMaxUsd)]).range([0, iW]);

    // Axis ticks
    [0,50,100,150,200,250,300].filter(function(t) { return t <= dMaxUsd+10; }).forEach(function(t) {
      var px = x(cv(t));
      if (t > 0)
        g.append('line').attr('x1',px).attr('x2',px).attr('y1',0).attr('y2',iH)
          .attr('stroke','#E5E2D9').attr('stroke-width',1);
      g.append('text').text(t === 0 ? '' : fmt(t))
        .attr('x',px).attr('y',iH+14).attr('text-anchor','middle')
        .attr('fill','#A09C96').attr('font-size',9).attr('font-family','IBM Plex Mono');
    });

    // Background track
    g.append('rect').attr('x',0).attr('y',cy-5).attr('width',iW).attr('height',10)
      .attr('fill',s.barBgColor).attr('rx',5);
    // Full range
    g.append('rect')
      .attr('x',x(cv(s.min))).attr('y',cy-5)
      .attr('width',x(cv(s.max))-x(cv(s.min))).attr('height',10)
      .attr('fill',s.barColor).attr('opacity',0.18).attr('rx',5);
    // Typical range
    g.append('rect')
      .attr('x',x(cv(s.typical_low))).attr('y',cy-9)
      .attr('width',x(cv(s.typical_high))-x(cv(s.typical_low))).attr('height',18)
      .attr('fill',s.barColor).attr('opacity',0.55).attr('rx',5)
      .style('cursor','pointer')
      .on('mouseenter', function(evt) {
        var lines = s.examples_usd.map(function(e) {
          return e.min===e.max ? e.label + ': ' + fmt(e.min) : e.label + ': ' + fmt(e.min) + '–' + fmt(e.max);
        });
        showTooltip(evt, s.tier, fmt(s.typical_low) + '–' + fmt(s.typical_high) + '/person', lines);
      })
      .on('mouseleave', hideTooltip);

    // Median
    g.append('line')
      .attr('x1',x(cv(s.median))).attr('x2',x(cv(s.median)))
      .attr('y1',cy-14).attr('y2',cy+14)
      .attr('stroke',s.barColor).attr('stroke-width',3);
    g.append('text').text(fmt(s.median))
      .attr('x',x(cv(s.median))).attr('y',cy-17)
      .attr('text-anchor','middle').attr('fill',s.barColor)
      .attr('font-size',11).attr('font-weight','600').attr('font-family','IBM Plex Mono');
  }

  // ─────────────────────────────────────────────
  // INIT
  // ─────────────────────────────────────────────
  window.addEventListener('DOMContentLoaded', function() {
    buildSummaryStrip();
    buildMap();
    buildSeminars();
  });

  window.setCurrency      = setCurrency;
  window.switchTab        = switchTab;
  window.switchSeminarTab = switchSeminarTab;
  window.clearRegion      = clearRegion;
  window.selectRegion     = selectRegion;

  // ── Deep Link button ──
  (function(){
    var b=document.getElementById('btn-deeplink');
    if(!b)return;
    b.addEventListener('click',function(){
      navigator.clipboard.writeText(location.href).then(function(){
        b.textContent='Copied!';b.style.color='#00d4ff';b.style.borderColor='rgba(0,212,255,0.4)';
        setTimeout(function(){b.textContent='Link';b.style.color='';b.style.borderColor='';},1500);
      });
    });
  })();
  </script>

</BaseLayout>
