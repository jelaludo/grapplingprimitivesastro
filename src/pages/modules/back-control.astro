</BaseLayout>

<style is:global>
:root {
  --bg:           #050509;
  --surface:      #0E1014;
  --border:       #1C1F26;
  --accent:       #4C8DFF;
  --accent-soft:  #A970FF;
  --cyan:         #00FFFF;
  --cyan-dim:     #00d4ff;
  --green:        #34D399;
  --amber:        #FBBF24;
  --red:          #F87171;
  --text-primary: #E5E7EB;
  --text-muted:   #9CA3AF;
  --text-dim:     #6B7280;
  --font-mono:    'Courier New', Consolas, Monaco, monospace;
  --glow-cyan:    0 0 12px #00FFFF88;
  --glow-blue:    0 0 12px #4C8DFF88;
  --glow-soft:    0 0 8px #A970FF66;
}

/* Hide JP by default */
[lang="ja"] { display: none; }
body.lang-ja [lang="ja"] { display: inline; }
body.lang-ja [lang="en"] { display: none; }

/* Toolbar lang toggle active state */
.lang-label[data-active] { color: #00FFFF; text-shadow: 0 0 12px #00FFFF88; }

/* ─── Acts ─── */
.act {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  border-bottom: 1px solid var(--border);
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}
.act.visible {
  opacity: 1;
  transform: translateY(0);
}
.act-inner {
  max-width: 780px;
  width: 100%;
}
.sim-act .act-inner {
  max-width: 1100px;
}

.act-number {
  display: block;
  font-size: 11px;
  letter-spacing: 0.3em;
  color: var(--text-dim);
  margin-bottom: 4px;
}
.act-title {
  font-size: clamp(1.4rem, 4vw, 2rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 16px;
  text-shadow: var(--glow-blue);
}
.act-lead {
  color: var(--text-muted);
  font-size: var(--text-sm);
  margin-bottom: 32px;
  max-width: 600px;
}

/* ─── Act 0 — Hero ─── */
.hero-title {
  font-size: clamp(1.2rem, 3.5vw, 1.8rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 24px;
}
.hero-title em {
  color: var(--cyan);
  font-style: normal;
  text-shadow: var(--glow-cyan);
}
.key-insight {
  text-align: center;
  font-size: var(--text-base);
  color: var(--amber);
  letter-spacing: 0.05em;
  margin: 24px 0;
  padding: 12px 20px;
  border: 1px solid rgba(251,191,36,0.2);
  border-radius: 4px;
  background: rgba(251,191,36,0.03);
}

/* ─── Act 1 — Equation ─── */
.equation-display {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--cyan-dim);
  text-align: center;
  padding: 12px 16px;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--surface);
  margin-bottom: 24px;
  letter-spacing: 0.04em;
  overflow-x: auto;
  white-space: nowrap;
}

/* ─── Act 2 — Three Cards ─── */
.three-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}
@media (max-width: 700px) {
  .three-cards {
    grid-template-columns: 1fr;
  }
}
.expr-card {
  padding: 20px;
  border-radius: 6px;
  background: var(--surface);
}
.expr-ride {
  border: 2px dashed var(--green);
  animation: ride-pulse 3s ease-in-out infinite;
}
.expr-freeze {
  border: 2px solid var(--amber);
}
.expr-spiral {
  border: 2px dotted #ea580c;
  animation: spiral-oscillate 4s ease-in-out infinite;
}
@keyframes ride-pulse {
  0%, 100% { box-shadow: 0 0 0 rgba(52,211,153,0); }
  50% { box-shadow: 0 0 12px rgba(52,211,153,0.15); }
}
@keyframes spiral-oscillate {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(0.5deg); }
  75% { transform: rotate(-0.5deg); }
}
.expr-header {
  font-size: var(--text-base);
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.expr-quote {
  font-size: var(--text-xs);
  color: var(--text-muted);
  font-style: italic;
  border-left: 2px solid var(--border);
  padding-left: 12px;
  margin: 0 0 16px 0;
  line-height: 1.5;
}
.expr-detail {
  font-size: var(--text-xs);
  color: var(--text-dim);
  margin-bottom: 6px;
}
.expr-detail strong {
  color: var(--text-muted);
}
.expr-breaks {
  color: var(--red);
  opacity: 0.7;
}
.nuance-text {
  font-size: var(--text-xs);
  color: var(--text-dim);
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  line-height: 1.6;
  padding: 16px;
  border-top: 1px solid var(--border);
}

/* ─── Act 3 — Toolbox Overview ─── */
.toolbox-overview {
  margin: 32px 0;
}
.toolbox-intro {
  color: var(--text-muted);
  font-size: var(--text-base);
  line-height: 1.7;
  max-width: 740px;
  margin: 0 auto 28px;
  text-align: center;
}
.toolbox-intro em {
  color: var(--cyan);
  font-style: normal;
  text-shadow: var(--glow-cyan);
}
.toolbox-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
}
@media (max-width: 900px) {
  .toolbox-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (max-width: 560px) {
  .toolbox-grid {
    grid-template-columns: 1fr 1fr;
  }
}
.toolbox-card {
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px;
  background: var(--surface);
  position: relative;
}
.toolbox-card.toolbox-spinal {
  border-color: rgba(251,191,36,0.25);
  background: rgba(251,191,36,0.02);
}
.toolbox-stage {
  font-size: var(--text-base);
  font-weight: bold;
  color: var(--text-primary);
  letter-spacing: 0.05em;
  margin-bottom: 4px;
}
.toolbox-goal {
  font-size: var(--text-sm);
  color: var(--text-dim);
  margin-bottom: 12px;
  line-height: 1.4;
}
.toolbox-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}
.toolbox-tools span {
  font-size: var(--text-sm);
  color: var(--text-muted);
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 3px;
  padding: 3px 8px;
  line-height: 1.4;
}
.toolbox-spinal-tag {
  position: absolute;
  top: -9px;
  right: 10px;
  font-size: 10px;
  letter-spacing: 0.12em;
  color: var(--amber);
  background: var(--surface);
  padding: 2px 8px;
  border: 1px solid rgba(251,191,36,0.3);
  border-radius: 3px;
}

/* ─── Act 3 — Simulation ─── */

/* Strategy Toggle */
.sim-strategy-toggle {
  display: flex;
  gap: 6px;
  justify-content: center;
  padding: 6px 0 2px;
}
.sim-strategy-btn {
  background: none;
  border: 2px dashed var(--border);
  color: var(--text-dim);
  padding: 4px 14px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 11px;
  font-family: var(--font-mono);
  font-weight: bold;
  letter-spacing: 1px;
  transition: all 0.3s;
}
.sim-strategy-btn:hover { color: var(--text-muted); border-color: var(--text-dim); }
.sim-strategy-btn.active[data-strategy="ride"] {
  border: 2px dashed #6abf6a;
  color: var(--text-primary);
}
.sim-strategy-btn.active[data-strategy="freeze"] {
  border: 2px solid #bfa64a;
  color: var(--text-primary);
}
.sim-strategy-btn.active[data-strategy="spiral"] {
  border: 2px dotted #bf7a4a;
  color: var(--text-primary);
}

/* Controls Bar */
.sim-controls-bar {
  display: flex;
  gap: 8px;
  justify-content: center;
  align-items: center;
  padding: 8px 0;
}
.sim-header-btn {
  background: none;
  border: 1px solid #444;
  color: var(--text-muted);
  padding: 6px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-size: 16px;
  font-family: var(--font-mono);
  transition: all 0.3s;
}
.sim-header-btn:hover { border-color: #888; color: #fff; }
.sim-btn-play {
  border: 1px solid #888;
  color: var(--text-primary);
  padding: 6px 16px;
}
.sim-btn-play:hover { border-color: #bbb; color: #fff; }

/* Subtitle */
.sim-subtitle {
  text-align: center;
  padding: 4px 0 10px;
  color: var(--text-dim);
  font-size: 12px;
  font-style: italic;
  letter-spacing: 0.5px;
}

/* Stages Container */
#sim-stages-container {
  display: flex;
  gap: 10px;
  align-items: stretch;
  flex: 1;
  position: relative;
  min-height: 300px;
}

/* Heat Map Overlay */
#sim-heat-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 5;
  border-radius: 6px;
  transition: background 0.4s ease;
  mix-blend-mode: screen;
}

/* Stage Columns */
.sim-stage-column {
  flex: 1;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 12px;
  background: var(--surface);
  display: flex;
  flex-direction: column;
  transition: border-color 0.5s, box-shadow 0.5s;
}
.sim-stage-column.sim-stage-active {
  border-color: #444;
  box-shadow: 0 0 8px rgba(255,255,255,0.03);
}
.sim-stage-name {
  text-align: center;
  font-weight: bold;
  color: var(--text-primary);
  font-size: 13px;
  margin-bottom: 4px;
}
.sim-stage-goal {
  text-align: center;
  font-size: 10px;
  color: var(--text-dim);
  margin-bottom: 14px;
  line-height: 1.3;
}

/* State Labels */
.sim-states-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  margin-bottom: 14px;
}
.sim-state-label {
  padding: 7px 12px;
  border-radius: 4px;
  font-size: 12px;
  width: 88%;
  text-align: center;
  transition: all 0.3s;
}
.sim-state-dim {
  background: #151515;
  border: 1px solid #252525;
  color: #444;
}
.sim-state-active.sim-state-controlled {
  background: #1a2e1a;
  border: 1px solid #4a8a4a;
  color: #6abf6a;
  font-weight: bold;
}
.sim-state-active.sim-state-contested {
  background: #1e1e1e;
  border: 1px solid #666;
  color: #bbb;
  font-weight: bold;
}
.sim-state-active.sim-state-lost {
  background: #2e1a1a;
  border: 1px solid #8a4a4a;
  color: #bf6a6a;
  font-weight: bold;
}
.sim-state-arrow {
  color: var(--border);
  font-size: 9px;
}

/* Tools */
.sim-tools-section {
  border-top: 1px solid var(--border);
  padding-top: 8px;
  margin-top: auto;
}
.sim-tools-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
}
.sim-tool {
  border: 1px solid #282828;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 9px;
  color: #444;
  transition: all 0.3s;
}
.sim-tool-active {
  border-color: #666;
  color: var(--text-primary);
  background: #252525;
  box-shadow: 0 0 4px rgba(255,255,255,0.06);
}

/* Spinal Bridge */
#sim-spinal-bridge {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--surface);
  margin-top: 12px;
}
.sim-bridge-label {
  font-size: 10px;
  font-weight: bold;
  color: var(--text-dim);
  letter-spacing: 1px;
  white-space: nowrap;
}
.sim-bridge-bar-container {
  flex: 1;
  height: 8px;
  background: #1a1a1a;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid #252525;
}
.sim-bridge-bar {
  height: 100%;
  width: 100%;
  border-radius: 3px;
  transition: width 0.3s, background 0.3s;
  background: #6abf6a;
}
.sim-bridge-value {
  font-size: 12px;
  font-weight: bold;
  color: #888;
  min-width: 36px;
  text-align: right;
}

/* Finish Meter */
.sim-finish-column {
  width: 80px;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 12px 8px;
  background: var(--surface);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.sim-finish-label {
  text-align: center;
  font-weight: bold;
  color: #888;
  font-size: 10px;
  letter-spacing: 1px;
  margin-bottom: 10px;
}
.sim-finish-meter-container {
  flex: 1;
  width: 30px;
  background: var(--bg);
  border-radius: 3px;
  position: relative;
  border: 1px solid #252525;
  min-height: 170px;
}
#sim-finish-bar {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to top, #8b2020, #8b7020, #2d7a2d);
  border-radius: 0 0 2px 2px;
  transition: height 0.3s;
}
#sim-finish-threshold {
  position: absolute;
  bottom: 25%;
  width: 120%;
  left: -10%;
  border-top: 1px dashed #555;
  transition: bottom 0.3s;
}
#sim-finish-pct {
  margin-top: 8px;
  font-size: 20px;
  font-weight: bold;
  color: var(--text-primary);
}
.sim-finish-detail {
  font-size: 8px;
  color: var(--text-dim);
  margin-top: 2px;
  text-align: center;
}

/* Terminal Animations */
@keyframes sim-pulse-green {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 20px rgba(106, 191, 106, 0.4); }
}
@keyframes sim-pulse-red {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 20px rgba(191, 106, 106, 0.4); }
}
@keyframes sim-glow-green {
  0%, 100% { text-shadow: 0 0 4px rgba(106, 191, 106, 0.3); }
  50% { text-shadow: 0 0 12px rgba(106, 191, 106, 0.7); }
}
@keyframes sim-glow-red {
  0%, 100% { text-shadow: 0 0 4px rgba(191, 106, 106, 0.3); }
  50% { text-shadow: 0 0 12px rgba(191, 106, 106, 0.7); }
}
.sim-terminal-finish { animation: sim-pulse-green 1s ease-in-out 3; }
.sim-terminal-bail { animation: sim-pulse-red 1s ease-in-out 3; }

.sim-terminal-label {
  display: none;
  font-size: 11px;
  font-weight: bold;
  margin-top: 6px;
  text-align: center;
}
.sim-terminal-label.sim-visible { display: block; }
.sim-terminal-label.sim-submission-label-text {
  color: #6abf6a;
  animation: sim-glow-green 1s ease-in-out infinite;
}
.sim-terminal-label.sim-escaped-label-text {
  color: #bf6a6a;
  animation: sim-glow-red 1s ease-in-out infinite;
}

/* Hover tooltip for small sim elements */
.sim-stage-column {
  position: relative;
}
.sim-hover-tooltip {
  display: none;
  position: fixed;
  z-index: 200;
  background: #1a1d25;
  border: 1px solid #444;
  border-radius: 6px;
  padding: 14px 18px;
  min-width: 200px;
  max-width: 280px;
  pointer-events: none;
  box-shadow: 0 4px 20px rgba(0,0,0,0.6);
}
.sim-hover-tooltip.visible { display: block; }
.sim-hover-tooltip .tt-name {
  font-size: 15px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4px;
}
.sim-hover-tooltip .tt-goal {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 8px;
  line-height: 1.4;
}
.sim-hover-tooltip .tt-state {
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 6px;
}
.sim-hover-tooltip .tt-tools {
  font-size: 12px;
  color: var(--text-dim);
}
.sim-hover-tooltip .tt-tools span {
  display: inline-block;
  background: #252525;
  border: 1px solid #333;
  border-radius: 3px;
  padding: 2px 6px;
  margin: 2px;
  font-size: 11px;
  color: var(--text-muted);
}

/* Auxiliary Footer */
