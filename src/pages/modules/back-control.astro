        <text x="176" y="322" fill="#6B7280" font-family="'Courier New',Consolas,Monaco,monospace" font-size="12">Physical</text>
        <!-- Concept dot: opponent-focused (-0.3 => x=219), physical (-0.7 => y=282) -->
        <a href={`${base}/modules/quadtree#cat=Grappling%20Primitives`} class="qt-dot-link">
