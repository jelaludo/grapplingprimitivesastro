<script>
// ═══ Scroll Reveal + Deep Link Hash Tracking ═══
(function() {
  const acts = document.querySelectorAll('.act');
  let currentAct = null;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        const actId = e.target.id;
        if (actId && actId !== currentAct) {
          currentAct = actId;
          history.replaceState(null, '', location.pathname + location.search + '#' + actId);
        }
      }
    });
  }, { threshold: 0.15 });
  acts.forEach((a) => observer.observe(a));

  // Restore scroll position from hash on load
  const hash = location.hash.replace('#', '');
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth' });
        target.classList.add('visible');
      }, 200);
    }
  }
})();

// ═══ Deep Link Button ═══
(function() {
  const btn = document.getElementById('deeplink-btn');
  if (!btn) return;
  btn.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      btn.textContent = 'Copied!';
      btn.style.color = '#00d4ff';
      btn.style.borderColor = 'rgba(0,212,255,0.4)';
      setTimeout(() => {
        btn.textContent = 'Link';
        btn.style.color = '';
        btn.style.borderColor = '';
      }, 1500);
    });
  });
})();

// ═══ Language Toggle ═══
(function() {
  const btn = document.getElementById('lang-toggle');
  if (!btn) return;
  const labels = btn.querySelectorAll('.lang-label');
  let lang = 'en';
  btn.addEventListener('click', () => {
    lang = lang === 'en' ? 'ja' : 'en';
    document.body.classList.toggle('lang-ja', lang === 'ja');
    labels.forEach((l) => {
      if ((lang === 'en' && l.textContent === 'EN') || (lang === 'ja' && l.textContent === 'JP')) {
        l.setAttribute('data-active', '');
      } else {
        l.removeAttribute('data-active');
      }
    });
  });
})();

// ═══ ACT 3 — Back Attacks Simulation ═══
(function() {

// ===== Strategy Presets =====
const SIM_STRATEGY_PRESETS = {
  ride: {
    label: 'RIDE',
    modifiers: {
      controlled_to_contested_mult: 1.3,
      contested_to_controlled_mult: 1.4,
      lost_to_contested_mult: 1.3,
      contested_to_lost_mult: 0.9,
      cascadeStrengthMult: 0.5,
      controlDecayTicksMult: 0.85,
      spinalBonus: 0.10
    }
  },
  freeze: {
    label: 'FREEZE',
    modifiers: {
      controlled_to_contested_mult: 0.6,
      contested_to_controlled_mult: 0.7,
      lost_to_contested_mult: 0.5,
      contested_to_lost_mult: 1.3,
      cascadeStrengthMult: 2.5,
      controlDecayTicksMult: 1.5,
      spinalBonus: 0.15
    }
  },
  spiral: {
    label: 'SPIRAL',
    modifiers: {
      controlled_to_contested_mult: 0.45,
      contested_to_controlled_mult: 1.1,
      lost_to_contested_mult: 0.85,
      contested_to_lost_mult: 0.7,
      cascadeStrengthMult: 0.3,
      controlDecayTicksMult: 1.2,
      spinalBonus: 0.25
    }
  }
};

// ===== Position Data =====
const simPositions = {
  backAttacks: {
    title: "BJJ Back Attacks",
    subtitle: "V20190507 by Gerald",
    source: "J Danaher",
    stages: [
      {
        name: "Grips",
        goal: "Negate the hands",
        tools: ["Dynamic grips", "Cross-grip", "Always a threat", "Leg to block arm", "Weight on arm", "\"magic grip\""],
        transitions: {
          controlled_to_contested: 0.14,
          contested_to_controlled: 0.28,
          contested_to_lost: 0.08,
          lost_to_contested: 0.20
        },
        cascadesTo: [1, 2]
      },
      {
        name: "Hip Control",
        goal: "Control opponent's hips, don't let him cross your ankle/knee",
        tools: ["Dynamic hooks", "Switch left-right", "Body lock", "\"single back\"", "Leg Turk"],
        transitions: {
          controlled_to_contested: 0.12,
          contested_to_controlled: 0.25,
          contested_to_lost: 0.10,
          lost_to_contested: 0.18
        },
        cascadesTo: [2, 3]
      },
      {
        name: "Shoulder Control",
        goal: "Anchor shoulder line, block upper turn",
        tools: ["Diagonal press", "Crossface", "Underhook control", "Chest-to-back adhesion"],
        transitions: {
          controlled_to_contested: 0.13,
          contested_to_controlled: 0.24,
          contested_to_lost: 0.09,
          lost_to_contested: 0.17
        },
        cascadesTo: [3, 4]
      },
      {
        name: "Head Control",
        goal: "Twist and expose neck",
        tools: ["Use own head", "Hand on head", "Close the circle"],
        transitions: {
          controlled_to_contested: 0.16,
          contested_to_controlled: 0.22,
          contested_to_lost: 0.10,
          lost_to_contested: 0.15
        },
        cascadesTo: [4]
      },
      {
        name: "Strangulation",
        goal: "Carotids best, mandible works",
        tools: ["Attack up-down", "Flat fist", "Switch left-right", "Finger crawl", "Mixed tempo", "Hide the hand", "Below eyes"],
        transitions: {
          controlled_to_contested: 0.10,
          contested_to_controlled: 0.20,
          contested_to_lost: 0.12,
          lost_to_contested: 0.14
        },
        cascadesTo: []
      }
    ],
    auxiliary: {
      name: "Switch to Auxiliary",
      description: "Accept back attack didn't work, gain tempo on next position",
      tools: ["Kimura grip", "Shoulder control", "Lockdown", "Gift Wrap", "Race to base", "Triangle"],
      threshold: 0.10
    },
    cascadeStrength: 0.06,
    finishWeights: {
      controlled: 1.0,
      contested: 0.5,
      lost: 0.15
    },
    controlDecayTicks: 30
  }
};

// ===== Simulation State =====
const simState = {
  stages: [],
  tickCount: 0,
  finishProb: 1.0,
  consecutiveFinishTicks: 0,
  running: false,
  terminated: false,
  intervalId: null,
  strategy: 'ride',
  settings: {
    speed: 3,
    attackerSkill: 6,
    defenderSkill: 9,
    cascadeStrength: 0.06,
    bailThreshold: 0.10
  }
};

// Expose to global for inline onclick handlers
window.simState = simState;

// ===== Strategy Toggle =====
function simSetStrategy(s) {
  simState.strategy = s;
  document.querySelectorAll('.sim-strategy-btn').forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-strategy') === s);
  });
}
window.simSetStrategy = simSetStrategy;

// ===== Decay Color Interpolation =====
function simGetDecayColor(t) {
  t = Math.max(0, Math.min(1, t));
  let r, g, b;
  if (t < 0.5) {
    const s = t * 2;
    r = Math.round(106 + (191 - 106) * s);
    g = Math.round(191 + (154 - 191) * s);
    b = Math.round(106 + (74 - 106) * s);
  } else {
    const s = (t - 0.5) * 2;
    r = Math.round(191 + (191 - 191) * s);
    g = Math.round(154 + (106 - 154) * s);
    b = Math.round(74 + (106 - 74) * s);
  }
  return { r, g, b };
}

function simGetDecayBg(t) {
  const c = simGetDecayColor(t);
  return `rgb(${Math.round(c.r * 0.15)}, ${Math.round(c.g * 0.15)}, ${Math.round(c.b * 0.15)})`;
}

function simGetDecayBorder(t) {
  const c = simGetDecayColor(t);
  return `rgb(${Math.round(c.r * 0.55)}, ${Math.round(c.g * 0.55)}, ${Math.round(c.b * 0.55)})`;
}

function simGetDecayText(t) {
  const c = simGetDecayColor(t);
  return `rgb(${c.r}, ${c.g}, ${c.b})`;
}

// ===== Urgency & Heat Map =====
const simUrgencyState = {
  scores: [0, 0, 0, 0, 0],
  transitionAge: [Infinity, Infinity, Infinity, Infinity, Infinity]
};

function simCalculateUrgency(position, state) {
  const N = position.stages.length;
  for (let i = 0; i < N; i++) {
    let u = 0;
    const s = state.stages[i];

    if (s.current === 'contested') u += 0.4;
    if (s.current === 'lost') u += 0.7;

    if (s.current === 'controlled') {
      const effectiveDecayTicks = (position.controlDecayTicks || 30) * (SIM_STRATEGY_PRESETS[state.strategy].modifiers.controlDecayTicksMult || 1);
      u += Math.min(s.controlledTicks / effectiveDecayTicks, 1) * 0.35;
    }

    for (let j = 0; j < N; j++) {
      if (j === i) continue;
      const up = position.stages[j];
      const upState = state.stages[j].current;
      if ((upState === 'contested' || upState === 'lost') && up.cascadesTo.includes(i)) {
        u += 0.2;
      }
    }

    simUrgencyState.transitionAge[i]++;
    const recency = Math.max(0, 1 - simUrgencyState.transitionAge[i] / 6);
    u += recency * 0.5;

    simUrgencyState.scores[i] = Math.min(u, 1.0);
  }
}

function simUpdateHeatMap(position, state) {
  simCalculateUrgency(position, state);
  const overlay = document.getElementById('sim-heat-overlay');
  if (state.terminated) {
    overlay.style.background = 'none';
    return;
  }

  const centers = [10, 25, 40, 55, 70];
  const gradients = [];

  for (let i = 0; i < 5; i++) {
    const u = simUrgencyState.scores[i];
    if (u < 0.05) continue;

    const r = Math.round(180 + u * 75);
    const g = Math.round(120 - u * 60);
    const b = Math.round(40 - u * 30);
    const alpha = u * 0.12;
    const size = 16 + u * 20;

    gradients.push(
      `radial-gradient(ellipse ${size}% 80% at ${centers[i]}% 50%, rgba(${r},${g},${b},${alpha}) 0%, transparent 100%)`
    );
  }

  overlay.style.background = gradients.length > 0 ? gradients.join(', ') : 'none';
}

// ===== Spinal Control =====
function simGetStateScore(stateStr) {
  if (stateStr === 'controlled') return 1.0;
  if (stateStr === 'contested') return 0.5;
  return 0.15;
}

function simCalculateSpinalControl(state) {
  const hipScore = simGetStateScore(state.stages[1].current);
  const shoulderScore = simGetStateScore(state.stages[2].current);
  return (hipScore * 0.55) + (shoulderScore * 0.45);
}

function simUpdateSpinalBridge(state) {
  const spinal = simCalculateSpinalControl(state);
  const pct = Math.round(spinal * 100);
  const bar = document.getElementById('sim-spinal-bar');
  const val = document.getElementById('sim-spinal-value');

  bar.style.width = pct + '%';
  val.textContent = pct + '%';

  if (spinal >= 0.75) {
    bar.style.background = '#6abf6a';
    val.style.color = '#6abf6a';
  } else if (spinal >= 0.4) {
    bar.style.background = '#bfa64a';
    val.style.color = '#bfa64a';
  } else {
    bar.style.background = '#bf6a6a';
    val.style.color = '#bf6a6a';
  }
}

// ===== Render =====
function simRender(position, state) {
  for (let i = 0; i < position.stages.length; i++) {
    const stageState = state.stages[i];
    const states = ['controlled', 'contested', 'lost'];
    const colEl = document.getElementById(`sim-stage-${i}`);

    if (stageState.activeTools.length > 0 && !state.terminated) {
      colEl.classList.add('sim-stage-active');
    } else {
      colEl.classList.remove('sim-stage-active');
    }

    for (const s of states) {
      const el = document.getElementById(`sim-state-${i}-${s}`);

      if (s === stageState.current) {
        if (s === 'controlled') {
          const effectiveDecayTicks = (position.controlDecayTicks || 12) * (SIM_STRATEGY_PRESETS[state.strategy].modifiers.controlDecayTicksMult || 1);
          const decayT = stageState.controlledTicks / effectiveDecayTicks;
          el.className = 'sim-state-label sim-state-active';
          el.style.background = simGetDecayBg(decayT);
          el.style.borderColor = simGetDecayBorder(decayT);
          el.style.color = simGetDecayText(decayT);
          el.style.fontWeight = 'bold';
        } else {
          el.className = 'sim-state-label sim-state-active sim-state-' + s;
          el.style.background = '';
          el.style.borderColor = '';
          el.style.color = '';
          el.style.fontWeight = '';
        }
      } else {
        el.className = 'sim-state-label sim-state-dim';
        el.style.background = '';
        el.style.borderColor = '';
        el.style.color = '';
        el.style.fontWeight = '';
      }
    }

    // Update tools
    const toolsContainer = document.getElementById(`sim-tools-${i}`);
    const toolEls = toolsContainer.querySelectorAll('.sim-tool');
    toolEls.forEach(el => {
      const isActive = stageState.activeTools.includes(el.textContent);
      el.className = 'sim-tool' + (isActive ? ' sim-tool-active' : '');
    });
  }

  // Heat map overlay
  simUpdateHeatMap(position, state);

  // Spinal bridge
  simUpdateSpinalBridge(state);

  // Finish meter
  const pct = state.finishProb * 100;
  document.getElementById('sim-finish-bar').style.height = pct + '%';
  document.getElementById('sim-finish-pct').textContent = pct.toFixed(0) + '%';

  // Threshold line
  const threshPct = state.settings.bailThreshold * 100;
  document.getElementById('sim-finish-threshold').style.bottom = threshPct + '%';

  // Finish detail
  const counts = { controlled: 0, contested: 0, lost: 0 };
  state.stages.forEach(s => counts[s.current]++);
  const parts = [];
  if (counts.controlled) parts.push(counts.controlled + ' ctrl');
  if (counts.contested) parts.push(counts.contested + ' cont');
  if (counts.lost) parts.push(counts.lost + ' lost');
  document.getElementById('sim-finish-detail').textContent = parts.join(' / ');

  // Stage 6 footer
  const auxEl = document.getElementById('sim-auxiliary-footer');
  auxEl.className = 'sim-auxiliary-footer';
  if (state.terminated && state.finishProb <= state.settings.bailThreshold) {
    auxEl.classList.add('sim-auxiliary-active');
  } else if (state.finishProb <= state.settings.bailThreshold * 1.5) {
    auxEl.classList.add('sim-auxiliary-warning');
  }

  // Reset button
  document.getElementById('sim-btn-reset').style.display = state.terminated ? 'inline-block' : 'none';

  // Terminal visuals
  const meterEl = document.getElementById('sim-finish-bar').parentElement;
  meterEl.classList.remove('sim-terminal-finish', 'sim-terminal-bail');
  document.getElementById('sim-label-finish').classList.remove('sim-visible');
  document.getElementById('sim-label-bail').classList.remove('sim-visible');

  if (state.terminated) {
    if (state.finishProb >= 0.90) {
      meterEl.classList.add('sim-terminal-finish');
      document.getElementById('sim-label-finish').classList.add('sim-visible');
    } else {
      meterEl.classList.add('sim-terminal-bail');
      document.getElementById('sim-label-bail').classList.add('sim-visible');
    }
  }
}

// ===== Core Functions =====
function simCalculateFinishProb(position, state) {
  let prob = 1.0;
  for (const stage of state.stages) {
    if (stage.current === 'controlled') {
      const effectiveDecayTicks = (position.controlDecayTicks || 12) * (SIM_STRATEGY_PRESETS[state.strategy].modifiers.controlDecayTicksMult || 1);
      const decayT = stage.controlledTicks / effectiveDecayTicks;
      prob *= 1.0 - (0.15 * Math.min(decayT, 1));
    } else {
      prob *= position.finishWeights[stage.current];
    }
  }

  // Spinal bonus
  if (state.stages[1].current === 'controlled' && state.stages[2].current === 'controlled') {
    const bonus = SIM_STRATEGY_PRESETS[state.strategy].modifiers.spinalBonus || 0;
    prob = Math.min(1.0, prob + bonus);
  }

  state.finishProb = prob;
  return prob;
}

function simInit(position) {
  simState.stages = position.stages.map(() => ({
    current: 'controlled',
    activeTools: [],
    controlledTicks: 0
  }));
  simState.tickCount = 0;
  simState.finishProb = 1.0;
  simState.consecutiveFinishTicks = 0;
  simState.terminated = false;
  // Reset urgency
  simUrgencyState.scores = new Array(position.stages.length).fill(0);
  simUrgencyState.transitionAge = new Array(position.stages.length).fill(Infinity);
  simCalculateFinishProb(position, simState);
  simRender(position, simState);
}

// ===== Simulation Engine =====
function simGetEffectiveTransitions(position, stageIndex, state) {
  const stage = position.stages[stageIndex];
  const base = { ...stage.transitions };
  const strat = SIM_STRATEGY_PRESETS[state.strategy].modifiers;

  base.controlled_to_contested *= (strat.controlled_to_contested_mult || 1);
  base.contested_to_controlled *= (strat.contested_to_controlled_mult || 1);
  base.contested_to_lost *= (strat.contested_to_lost_mult || 1);
  base.lost_to_contested *= (strat.lost_to_contested_mult || 1);

  const skillMod = (state.settings.attackerSkill - 5) * 0.012;
  const defMod = (state.settings.defenderSkill - 5) * 0.012;

  base.contested_to_controlled = Math.min(0.95, Math.max(0.05, base.contested_to_controlled + skillMod));
  base.lost_to_contested = Math.min(0.95, Math.max(0.05, base.lost_to_contested + skillMod));
  base.controlled_to_contested = Math.min(0.95, Math.max(0.05, base.controlled_to_contested - skillMod));
  base.contested_to_lost = Math.min(0.95, Math.max(0.05, base.contested_to_lost - skillMod));

  base.controlled_to_contested = Math.min(0.95, Math.max(0.05, base.controlled_to_contested + defMod));
  base.contested_to_lost = Math.min(0.95, Math.max(0.05, base.contested_to_lost + defMod));
  base.contested_to_controlled = Math.min(0.95, Math.max(0.05, base.contested_to_controlled - defMod));
  base.lost_to_contested = Math.min(0.95, Math.max(0.05, base.lost_to_contested - defMod));

  let cascadeMod = 0;
  const effectiveCascadeStrength = state.settings.cascadeStrength * (strat.cascadeStrengthMult || 1);
  for (let i = 0; i < position.stages.length; i++) {
    if (i === stageIndex) continue;
    const upstream = position.stages[i];
    const upstreamState = state.stages[i].current;
    if ((upstreamState === 'contested' || upstreamState === 'lost') &&
        upstream.cascadesTo.includes(stageIndex)) {
      cascadeMod += effectiveCascadeStrength;
    }
  }

  const stageState = state.stages[stageIndex];
  if (stageState.current === 'controlled') {
    const decayPressure = Math.min(stageState.controlledTicks * 0.005, 0.15);
    base.controlled_to_contested = Math.min(0.95, base.controlled_to_contested + cascadeMod + decayPressure);
  } else if (stageState.current === 'contested') {
    base.contested_to_lost = Math.min(0.95, base.contested_to_lost + cascadeMod);
  }

  return { transitions: base, cascadeMod };
}

function simRollTransition(position, stageIndex, state) {
  const { transitions, cascadeMod } = simGetEffectiveTransitions(position, stageIndex, state);
  const currentState = state.stages[stageIndex].current;
  const roll = Math.random();
  let newState = currentState;
  let cascadeSource = null;

  if (currentState === 'controlled') {
    if (roll < transitions.controlled_to_contested) newState = 'contested';
  } else if (currentState === 'contested') {
    const pRecover = transitions.contested_to_controlled;
    const pDegrade = Math.min(transitions.contested_to_lost, 1.0 - pRecover);
    if (roll < pRecover) {
      newState = 'controlled';
    } else if (roll < pRecover + pDegrade) {
      newState = 'lost';
    }
  } else if (currentState === 'lost') {
    if (roll < transitions.lost_to_contested) newState = 'contested';
  }

  if (cascadeMod > 0 && (
    (currentState === 'controlled' && newState === 'contested') ||
    (currentState === 'contested' && newState === 'lost')
  )) {
    for (let i = 0; i < position.stages.length; i++) {
      const upstream = position.stages[i];
      const upState = state.stages[i].current;
      if ((upState === 'contested' || upState === 'lost') &&
          upstream.cascadesTo.includes(stageIndex)) {
        cascadeSource = position.stages[i].name;
        break;
      }
    }
  }

  return { previousState: currentState, newState, cascadeSource };
}

function simTick(position, state) {
  if (state.terminated) return;
  state.tickCount++;
  const prevProb = state.finishProb;
  const logEntries = [];

  for (let i = 0; i < position.stages.length; i++) {
    const result = simRollTransition(position, i, state);

    if (result.newState !== result.previousState) {
      state.stages[i].current = result.newState;
      simUrgencyState.transitionAge[i] = 0;

      if (result.newState === 'controlled') {
        state.stages[i].controlledTicks = 0;
      }

      const tools = position.stages[i].tools;
      const toolCount = Math.random() < 0.5 ? 1 : 2;
      const shuffled = [...tools].sort(() => Math.random() - 0.5);
      state.stages[i].activeTools = shuffled.slice(0, Math.min(toolCount, tools.length));

      let entry = `[tick ${state.tickCount}] ${position.stages[i].name}: ${result.previousState} > ${result.newState} (using: ${state.stages[i].activeTools.join(', ')})`;
      if (result.cascadeSource) {
        entry += ` [cascade from ${result.cascadeSource}]`;
      }
      logEntries.push(entry);
    } else {
      if (Math.random() < 0.5) {
        const tools = position.stages[i].tools;
        const toolCount = Math.random() < 0.5 ? 1 : 2;
        const shuffled = [...tools].sort(() => Math.random() - 0.5);
        state.stages[i].activeTools = shuffled.slice(0, Math.min(toolCount, tools.length));
      }
    }

    if (state.stages[i].current === 'controlled') {
      state.stages[i].controlledTicks++;
    }
  }

  simCalculateFinishProb(position, state);

  if (Math.abs(state.finishProb - prevProb) > 0.001) {
    logEntries.push(`[tick ${state.tickCount}] Finish probability: ${(prevProb * 100).toFixed(0)}% > ${(state.finishProb * 100).toFixed(0)}%`);
  }

  if (state.finishProb >= 0.90) {
    state.consecutiveFinishTicks++;
    if (state.consecutiveFinishTicks >= 5) {
      state.terminated = true;
      simStopSimulation();
      logEntries.push(`[tick ${state.tickCount}] SUBMISSION - Submission complete!`);
      simScheduleAutoReset();
    }
  } else {
    state.consecutiveFinishTicks = 0;
  }

  if (!state.terminated && state.finishProb <= state.settings.bailThreshold) {
    state.terminated = true;
    simStopSimulation();
    logEntries.push(`[tick ${state.tickCount}] ESCAPED - Switch to auxiliary (finish prob ${(state.finishProb * 100).toFixed(0)}% below ${(state.settings.bailThreshold * 100).toFixed(0)}%)`);
    simScheduleAutoReset();
  }

  simAppendLog(logEntries);
  simRender(position, state);
}

// ===== Event Log =====
function simAppendLog(entries) {
  const logEl = document.getElementById('sim-event-log');
  for (const entry of entries) {
    const div = document.createElement('div');
    div.className = 'sim-log-entry';
    if (entry.includes('SUBMISSION')) div.classList.add('sim-log-finish');
    else if (entry.includes('ESCAPED')) div.classList.add('sim-log-bail');
    else if (entry.includes('Finish probability:')) div.classList.add('sim-log-prob');
    else if (entry.includes('[cascade from')) div.classList.add('sim-log-cascade');
    div.textContent = entry;
    logEl.insertBefore(div, logEl.firstChild);
  }
}

// ===== Controls =====
function simStartSimulation() {
  if (simState.terminated || simState.running) return;
  simState.running = true;
  const interval = 1000 / simState.settings.speed;
  simState.intervalId = setInterval(() => simTick(simPositions.backAttacks, simState), interval);
  simUpdateControlButtons();
}
window.simStartSimulation = simStartSimulation;

function simStopSimulation() {
  simState.running = false;
  if (simState.intervalId) {
    clearInterval(simState.intervalId);
    simState.intervalId = null;
  }
  simUpdateControlButtons();
}
window.simStopSimulation = simStopSimulation;

function simStepSimulation() {
  if (simState.terminated) return;
  if (simState.running) simStopSimulation();
  simTick(simPositions.backAttacks, simState);
}
window.simStepSimulation = simStepSimulation;

let simAutoResetTimeout = null;

function simScheduleAutoReset() {
  if (simAutoResetTimeout) clearTimeout(simAutoResetTimeout);
  simAutoResetTimeout = setTimeout(() => {
    simResetSimulation();
  }, 3000);
}

function simResetSimulation() {
  if (simAutoResetTimeout) { clearTimeout(simAutoResetTimeout); simAutoResetTimeout = null; }
  simStopSimulation();
  simInit(simPositions.backAttacks);
  document.getElementById('sim-event-log').innerHTML = '';
  simAppendLog(['- New round -']);
  simStartSimulation();
}
window.simResetSimulation = simResetSimulation;

function simUpdateControlButtons() {
  const playBtn = document.getElementById('sim-btn-play');
  playBtn.textContent = simState.running ? '\u23F8' : '\u25B6';
  document.getElementById('sim-btn-reset').style.display = simState.terminated ? 'inline-block' : 'none';
}

// ===== Settings =====
function simToggleSettings() {
  const modal = document.getElementById('sim-settings-modal');
  modal.style.display = modal.style.display === 'flex' ? 'none' : 'flex';
}
window.simToggleSettings = simToggleSettings;

function simUpdateSetting(key, value, displayEl) {
  if (key === 'speed') {
    simState.settings.speed = parseFloat(value);
    displayEl.textContent = value + 'x';
    if (simState.running) {
      clearInterval(simState.intervalId);
      simState.intervalId = setInterval(() => simTick(simPositions.backAttacks, simState), 1000 / simState.settings.speed);
    }
  } else if (key === 'attackerSkill' || key === 'defenderSkill') {
    simState.settings[key] = parseInt(value);
    displayEl.textContent = value;
  } else if (key === 'cascadeStrength') {
    simState.settings.cascadeStrength = parseFloat(value);
    displayEl.textContent = value;
  } else if (key === 'bailThreshold') {
    simState.settings.bailThreshold = parseFloat(value);
    displayEl.textContent = (parseFloat(value) * 100).toFixed(0) + '%';
    simRender(simPositions.backAttacks, simState);
  }
}
window.simUpdateSetting = simUpdateSetting;

// ===== Start simulation when ACT 3 becomes visible =====
const simAct = document.getElementById('act-3');
let simStarted = false;
const simObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting && !simStarted) {
      simStarted = true;
      simInit(simPositions.backAttacks);
      simStartSimulation();
    }
  });
}, { threshold: 0.15 });
simObserver.observe(simAct);

})();

// ═══ Simulation Hover Tooltip ═══
(function() {
  const tooltip = document.getElementById('sim-hover-tooltip');
  if (!tooltip) return;
  const cols = document.querySelectorAll('.sim-stage-column');

  cols.forEach((col, i) => {
    col.addEventListener('mouseenter', (e) => {
      const name = col.querySelector('.sim-stage-name');
      const goal = col.querySelector('.sim-stage-goal');
      const activeState = col.querySelector('.sim-state-active');
      const activeTools = col.querySelectorAll('.sim-tool-active');

      tooltip.querySelector('.tt-name').textContent = name ? name.textContent : '';
      tooltip.querySelector('.tt-goal').innerHTML = goal ? goal.innerHTML.replace(/<br\s*\/?>/g, ' ') : '';

      const stateEl = tooltip.querySelector('.tt-state');
      if (activeState) {
        stateEl.textContent = activeState.textContent;
        if (activeState.classList.contains('sim-state-controlled')) {
          stateEl.style.color = '#6abf6a';
        } else if (activeState.classList.contains('sim-state-contested')) {
          stateEl.style.color = '#bbb';
        } else if (activeState.classList.contains('sim-state-lost')) {
          stateEl.style.color = '#bf6a6a';
        } else {
          stateEl.style.color = activeState.style.color || '#6abf6a';
        }
      }

      const toolsHtml = Array.from(activeTools).map(t => '<span>' + t.textContent + '</span>').join('');
      tooltip.querySelector('.tt-tools').innerHTML = toolsHtml || '<span style="color:#444;">no active tools</span>';

      tooltip.classList.add('visible');
    });

    col.addEventListener('mousemove', (e) => {
      const x = e.clientX + 16;
      const y = e.clientY - 10;
      const maxX = window.innerWidth - 300;
      tooltip.style.left = Math.min(x, maxX) + 'px';
      tooltip.style.top = y + 'px';
    });

    col.addEventListener('mouseleave', () => {
      tooltip.classList.remove('visible');
    });
  });
})();

// ═══ Primitive Card -> QuadTree Modal ═══
(function() {
  const card = document.getElementById('primitive-card-link');
  const modal = document.getElementById('quadtree-modal');
  const goBtn = document.getElementById('qt-modal-go');
  if (!card || !modal || !goBtn) return;

  goBtn.href = '/modules/quadtree#BJJ-261';

  card.addEventListener('click', () => {
    modal.style.display = 'flex';
  });
})();
</script>
