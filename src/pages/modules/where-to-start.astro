---
import BaseLayout from '@/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Where to Start — Grappling Primitives" fullscreen={true}>

<!-- ── Toolbar ──────────────────────────────────────────────────────────────── -->
<div id="toolbar" style="position:fixed;top:0;left:0;right:0;height:36px;z-index:50;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Courier New',Consolas,Monaco,monospace;">
  <a href={`${base}/`} style="font-size:10px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;text-decoration:none;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'">← Home</a>
  <span style="color:#21262d;">|</span>
  <span style="font-size:11px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;">Where to Start</span>
  <div style="flex:1;"></div>
  <button id="deeplink-btn" style="font-family:inherit;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;" onmouseover="this.style.borderColor='rgba(0,212,255,0.4)';this.style.color='#00d4ff'" onmouseout="if(this.textContent==='Link'){this.style.borderColor='#21262d';this.style.color='#6b7280'}">Link</button>
</div>

<!-- ── Scrolling Content ───────────────────────────────────────────────────── -->
<div style="padding-top:36px;">

<!-- ACT 0 — The Question -->
<section id="act-0" class="act" data-act="0">
  <div class="act-inner" style="text-align:center;">
    <h1 class="hero-title">Where to Start?</h1>
    <p class="act-subtitle">Most schools teach offense first. (Armbar First, No Mercy). This model says start with survival.</p>
    <div class="key-insight">The entry point to grappling isn't as much position, as it should be a mindset.</div>
    <p class="act-lead" style="max-width:600px;margin:32px auto;text-align:left;">
      Beginners and coaches alike face this question. Everyone has an opinion. Learn this take-down, here's a sweep. Learn this guard. Start from standing. Here's a great guard.
      Here's an alternative that focuses on creating a foundation of being comfortable in bad positions first. From there you can unlock everything else.
    </p>
  </div>
</section>

<!-- ACT 1 — The Foundation -->
<section id="act-1" class="act" data-act="1">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">01</span>Resilience is the Foundation</h2>
    <p class="act-lead">Two things must come first. Before submissions or even positions. An ability to survive to explore and counter attack.</p>

    <div class="foundation-cards">
      <div class="foundation-card card-escape">
        <div class="card-label">Goal 1</div>
        <h3 class="card-heading" style="color:var(--green);">Escaping Pins</h3>
        <p class="card-body">
          Can you survive being held down? Can you breathe under mount, under side control, under knee-on-belly?
          Until the answer is yes, everything else is built on sand.
        </p>
      </div>
      <div class="foundation-card card-guard">
        <div class="card-label">Goal 2</div>
        <h3 class="card-heading" style="color:var(--cyan);">Retaining Guard</h3>
        <p class="card-body">
          Escaping pins can take a lot of energy. Not getting there in the first place is even better.  Pound of cure vs gram of prevention or something. Can you keep someone from passing your legs? Not even attacking from guard, just keeping it.
          Guard retention is the first layer of defensive comfort.
        </p>
      </div>
    </div>

    <p class="foundation-summary">
      These two skills give you something no technique can: the confidence that bad situations are survivable.
      That conviction is what makes risk-taking psychologically available.  I think it was Danaher who said that confidence should be built on objective skills.
    </p>
  </div>
</section>

<!-- ACT 2 — Confidence Creates Options (CLD Diagram) -->
<section id="act-2" class="act" data-act="2">
  <div class="act-inner" style="max-width:1000px;">
    <h2 class="act-title"><span class="act-number">02</span>Confidence Creates Options</h2>
    <p class="act-lead">With surviving skills, confidence emerges.  You can live to fight another day, you can counter-attack.  I find the explore-exploit algorithm suitable here.</p>

    <!-- CLD: Pure SVG with baked coordinates -->
    <div class="cld-wrap" id="cld-container">
      <svg class="cld-diagram" viewBox="0 0 680 520" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="cld-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </marker>
        </defs>

        <!-- ── Edges (behind nodes) ── -->
        <!-- Escaping Pins → Confidence -->
        <line class="cld-edge" data-edge="escape-confidence" x1="200" y1="396" x2="228" y2="346" stroke="var(--green)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="escape-confidence" x="205" y="372" text-anchor="middle" fill="var(--green)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Retaining Guard → Confidence -->
        <line class="cld-edge" data-edge="guard-confidence" x1="365" y1="396" x2="322" y2="346" stroke="var(--cyan)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="guard-confidence" x="358" y="372" text-anchor="middle" fill="var(--cyan)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Confidence → Creativity (explore) -->
        <line class="cld-edge" data-edge="confidence-creativity" x1="208" y1="310" x2="184" y2="256" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="confidence-creativity" x="188" y="284" text-anchor="middle" fill="var(--accent)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Confidence → Dominant (exploit) -->
        <line class="cld-edge" data-edge="confidence-dominant" x1="352" y1="306" x2="396" y2="256" stroke="var(--amber)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="confidence-dominant" x="382" y="282" text-anchor="middle" fill="var(--amber)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Dominant → Maintain -->
        <line class="cld-edge" data-edge="dominant-maintain" x1="480" y1="178" x2="480" y2="148" stroke="var(--text-dim)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="dominant-maintain" x="494" y="166" text-anchor="start" fill="var(--text-dim)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Maintain → Submissions -->
        <line class="cld-edge" data-edge="maintain-submit" x1="540" y1="110" x2="568" y2="110" stroke="var(--text-dim)" stroke-width="1.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="maintain-submit" x="545" y="100" text-anchor="middle" fill="var(--text-dim)" font-size="13" font-weight="bold" font-family="var(--font-mono)">+</text>

        <!-- Feedback arc: Creativity → Dominant (curved) -->
        <path class="cld-edge cld-edge-feedback" data-edge="creativity-dominant" d="M 186 196 Q 300 80 388 186" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="5 4" opacity="0.5" marker-end="url(#cld-arrow)"/>
        <text class="cld-edge-label" data-edge="creativity-dominant" x="292" y="106" text-anchor="middle" fill="var(--accent)" font-size="11" font-style="italic" opacity="0.7" font-family="var(--font-mono)">+ feedback</text>

        <!-- ── Nodes ── -->
        <!-- Escaping Pins -->
        <g class="cld-node-g" data-node="escape" cursor="pointer">
          <ellipse cx="160" cy="430" rx="110" ry="46" fill="rgba(52,211,153,0.06)" stroke="var(--green)" stroke-width="1.5"/>
          <text x="160" y="416" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="12" font-family="var(--font-mono)">Comfort</text>
          <text x="160" y="434" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="14" font-weight="600" font-family="var(--font-mono)">Escaping Pins</text>
          <text x="160" y="454" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="11" font-family="var(--font-mono)">(Goal 1)</text>
        </g>

        <!-- Retaining Guard -->
        <g class="cld-node-g" data-node="guard" cursor="pointer">
          <ellipse cx="400" cy="430" rx="110" ry="46" fill="rgba(0,255,255,0.04)" stroke="var(--cyan)" stroke-width="1.5"/>
          <text x="400" y="416" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="12" font-family="var(--font-mono)">Comfort</text>
          <text x="400" y="434" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="14" font-weight="600" font-family="var(--font-mono)">Retaining Guard</text>
          <text x="400" y="454" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="11" font-family="var(--font-mono)">(Goal 2)</text>
        </g>

        <!-- Confidence (center, diamond) -->
        <g class="cld-node-g" data-node="confidence" cursor="pointer">
          <polygon points="280,280 380,318 280,356 180,318" fill="rgba(251,191,36,0.08)" stroke="var(--amber)" stroke-width="2"/>
          <text x="280" y="311" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="13" font-family="var(--font-mono)">Confidence /</text>
          <text x="280" y="329" text-anchor="middle" dominant-baseline="central" fill="var(--amber)" font-size="15" font-weight="700" font-family="var(--font-mono)">Taking Risks</text>
        </g>
        <!-- Fork labels, offset from lines, linking to BJJ-265 -->
        <a href="/concepts/BJJ-265-explore-vs-exploit">
          <text x="168" y="280" text-anchor="end" dominant-baseline="central" fill="var(--accent)" font-size="11" font-style="italic" opacity="0.7" font-family="var(--font-mono)">explore</text>
        </a>
        <a href="/concepts/BJJ-265-explore-vs-exploit">
          <text x="396" y="280" text-anchor="start" dominant-baseline="central" fill="var(--amber)" font-size="11" font-style="italic" opacity="0.7" font-family="var(--font-mono)">exploit</text>
        </a>

        <!-- Creativity (upper-left) -->
        <g class="cld-node-g" data-node="creativity" cursor="pointer">
          <ellipse cx="100" cy="220" rx="90" ry="42" fill="rgba(76,141,255,0.06)" stroke="var(--accent)" stroke-width="1.5"/>
          <text x="100" y="212" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="13" font-family="var(--font-mono)">Creativity /</text>
          <text x="100" y="232" text-anchor="middle" dominant-baseline="central" fill="var(--accent)" font-size="14" font-weight="600" font-family="var(--font-mono)">Mindful Practice</text>
        </g>
        <text x="70" y="168" text-anchor="middle" fill="var(--accent)" font-size="11" letter-spacing="0.15em" opacity="0.7" font-family="var(--font-mono)">EXPLORE</text>

        <!-- Dominant Positions (upper-right) -->
        <g class="cld-node-g" data-node="dominant" cursor="pointer">
          <ellipse cx="480" cy="220" rx="100" ry="42" fill="rgba(255,255,255,0.03)" stroke="var(--border)" stroke-width="1"/>
          <text x="480" y="210" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="12" font-family="var(--font-mono)">% Chance of Reaching</text>
          <text x="480" y="230" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="14" font-weight="600" font-family="var(--font-mono)">Dominant Positions</text>
        </g>

        <!-- Maintain -->
        <g class="cld-node-g" data-node="maintain" cursor="pointer">
          <ellipse cx="480" cy="110" rx="80" ry="34" fill="rgba(255,255,255,0.03)" stroke="var(--border)" stroke-width="1"/>
          <text x="480" y="103" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="12" font-family="var(--font-mono)">Maintain</text>
          <text x="480" y="121" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="14" font-weight="600" font-family="var(--font-mono)">Dominant Positions</text>
        </g>

        <!-- Submissions -->
        <g class="cld-node-g" data-node="submit" cursor="pointer">
          <rect x="572" y="86" rx="4" width="96" height="48" fill="rgba(255,255,255,0.03)" stroke="var(--text-dim)" stroke-width="1.5"/>
          <text x="620" y="103" text-anchor="middle" dominant-baseline="central" fill="var(--text-dim)" font-size="12" font-family="var(--font-mono)">Achieve</text>
          <text x="620" y="121" text-anchor="middle" dominant-baseline="central" fill="var(--text-primary)" font-size="14" font-weight="700" font-family="var(--font-mono)">Submissions</text>
        </g>
        <text x="535" y="62" text-anchor="middle" fill="var(--text-dim)" font-size="11" letter-spacing="0.15em" font-family="var(--font-mono)">EXPLOIT: "Your 'A' GAME"</text>
      </svg>
    </div>

    <!-- Annotation panel -->
    <div class="cld-annotation" id="cld-annotation">
      <div class="cld-annotation-title" id="cld-annotation-title"></div>
      <div class="cld-annotation-text" id="cld-annotation-text">Click any node to learn its role in the system.</div>
    </div>
  </div>
</section>

<!-- ACT 3 — The Insight Loop -->
<section id="act-3" class="act" data-act="3">
  <div class="act-inner">
    <h2 class="act-title"><span class="act-number">03</span>Why Exploring and Creativity Matters</h2>
    <p class="act-lead">There's a difference between logging mat time and extracting signal from it.  Just showing up vs active learning.</p>

    <div class="prose-block">
      <p>
        Confidence born from skills unlocks the option to explore. To not stress and tense from every  exchange.  Exploring creates variance in the situations you encounter.
        Variance is the precondition for gaining new insights.
      </p>
      <p>
        The higher your comfort with escapes, the higher your ability to experiment. More novel situations encountered per session.
        More signal per roll. This is one way to have training become generative instead of repetitive.
      </p>
    </div>

    <div class="explore-chips">
      <span class="explore-chip">Trying new techniques</span>
      <span class="explore-chip">Trying new transitions</span>
      <span class="explore-chip">Starting from bad positions voluntarily</span>
      <span class="explore-chip">Relaxing / reducing tension on purpose</span>
	  <span class="explore-chip">Exploring your limits</span>
      <span class="explore-chip">Playing with "invisible jiu-jitsu"</span>
      <span class="explore-chip">Getting creative</span>
    </div>

    <blockquote class="pull-quote">
      It's hard to extract much signal from a roll when you are either 1) trying to completely dominate the other or 2) getting totally smeshed.
    </blockquote>

    <div class="prose-block">
      <p>
        The explore branch feeds back into the exploit chain. Exploration allows your to discover better ways of doing things you already did, and plugging holes in your game.
        The whole system is a positive feedback loop.  Another key element not quite in the graph is that having a deep knowledge of all the escape patterns makes you that much better at shutting them down.
      </p>
    </div>
  </div>
</section>

<!-- ACT 4 — CTA -->
<section id="act-4" class="act" data-act="4">
  <div class="act-inner" style="text-align:center;">
    <h2 class="act-title"><span class="act-number">04</span>Keep Going</h2>
    <p class="act-lead" style="margin:0 auto 32px;">Related modules to explore next.</p>
    <div class="cta-row">
      <a href={`${base}/modules/jibunwotsukure`} class="cta-link">Build Yourself First &rarr;</a>
      <a href={`${base}/modules/ideal-partner`} class="cta-link">Ideal Training Partner &rarr;</a>
      <a href={`${base}/modules/back-control`} class="cta-link">Back Control &rarr;</a>
      <a href={`${base}/modules/quadtree`} class="cta-link">Explore the Map &rarr;</a>
    </div>
  </div>
</section>

</div><!-- end scrolling content -->

</BaseLayout>

<style is:global>
:root {
  --bg:           #050509;
  --surface:      #0E1014;
  --border:       #1C1F26;
  --accent:       #4C8DFF;
  --accent-soft:  #A970FF;
  --cyan:         #00FFFF;
  --cyan-dim:     #00d4ff;
  --green:        #34D399;
  --amber:        #FBBF24;
  --red:          #F87171;
  --text-primary: #E5E7EB;
  --text-muted:   #9CA3AF;
  --text-dim:     #6B7280;
  --font-mono:    'Courier New', Consolas, Monaco, monospace;
  --glow-cyan:    0 0 12px #00FFFF88;
  --glow-blue:    0 0 12px #4C8DFF88;
  --glow-green:   0 0 12px #34D39988;
  --glow-amber:   0 0 12px #FBBF2488;
}

/* Module overrides (base .act-* in global.css) */
.act-subtitle { font-size: var(--text-base); margin-top: 0; margin-bottom: 24px; }

/* ─── Act 0: Hero ─── */
.hero-title {
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: 16px;
  text-shadow: var(--glow-blue);
}
.act-subtitle {
  font-size: var(--text-base);
  color: var(--text-muted);
  margin-bottom: 24px;
}
.key-insight {
  text-align: center;
  font-size: var(--text-base);
  color: var(--amber);
  letter-spacing: 0.05em;
  margin: 24px auto;
  padding: 12px 20px;
  border: 1px solid rgba(251,191,36,0.2);
  border-radius: 4px;
  background: rgba(251,191,36,0.03);
  max-width: 600px;
}

/* ─── Act 1: Foundation Cards ─── */
.foundation-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 32px;
}
@media (max-width: 700px) {
  .foundation-cards {
    grid-template-columns: 1fr;
  }
}
.foundation-card {
  padding: 24px;
  border-radius: 6px;
  background: var(--surface);
}
.card-escape {
  border: 1px solid rgba(52,211,153,0.3);
}
.card-guard {
  border: 1px solid rgba(0,255,255,0.3);
}
.card-label {
  font-size: var(--text-xs);
  color: var(--text-dim);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.card-heading {
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: 12px;
}
.card-body {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
}
.foundation-summary {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
  padding: 16px 20px;
  border-left: 2px solid var(--amber);
  background: rgba(251,191,36,0.03);
  border-radius: 0 4px 4px 0;
}

/* ─── Act 2: CLD Diagram (pure SVG) ─── */
.cld-wrap {
  margin: 32px auto;
  max-width: 860px;
  padding: 24px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: rgba(14,16,20,0.5);
}
.cld-diagram {
  width: 100%;
  height: auto;
  display: block;
}

/* Animated flow on edges */
.cld-edge {
  stroke-dasharray: 6 4;
  animation: cld-flow 1.2s linear infinite;
}
.cld-edge-feedback {
  animation: cld-flow-reverse 2s linear infinite;
}
@keyframes cld-flow {
  to { stroke-dashoffset: -10; }
}
@keyframes cld-flow-reverse {
  to { stroke-dashoffset: 10; }
}

/* Node hover */
.cld-node-g { transition: opacity 0.2s; }
.cld-node-g:hover { opacity: 0.8; }

/* Dimmed state when a node is selected */
.cld-wrap.has-selection .cld-node-g { opacity: 0.15; }
.cld-wrap.has-selection .cld-node-g.active { opacity: 1; }
.cld-wrap.has-selection .cld-node-g.connected { opacity: 0.7; }
.cld-wrap.has-selection .cld-edge { opacity: 0.08; }
.cld-wrap.has-selection .cld-edge.edge-active { opacity: 1; }
.cld-wrap.has-selection .cld-edge-label { opacity: 0.08; }
.cld-wrap.has-selection .cld-edge-label.label-active { opacity: 1; }

/* Annotation */
.cld-annotation {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  min-height: 60px;
  margin-top: 16px;
  max-width: 860px;
  margin-left: auto;
  margin-right: auto;
}
.cld-annotation-title {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--accent);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.cld-annotation-text {
  font-size: var(--text-base);
  color: var(--text-muted);
  line-height: 1.6;
}

/* Mobile: SVG scales naturally via viewBox */
@media (max-width: 600px) {
  .cld-wrap { padding: 12px; }
}

/* ─── Act 3: Prose + Chips ─── */
.prose-block {
  margin-bottom: 28px;
}
.prose-block p {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 16px;
}

.explore-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 32px;
}
.explore-chip {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--accent);
  border: 1px solid rgba(76,141,255,0.25);
  background: rgba(76,141,255,0.05);
  border-radius: 3px;
  padding: 4px 10px;
  letter-spacing: 0.03em;
  transition: all 0.2s;
}
.explore-chip:hover {
  border-color: var(--accent);
  background: rgba(76,141,255,0.1);
  box-shadow: var(--glow-blue);
}

.pull-quote {
  font-size: var(--text-base);
  color: var(--cyan);
  padding: 16px 24px;
  border-left: 3px solid var(--cyan);
  background: rgba(0,255,255,0.03);
  border-radius: 0 4px 4px 0;
  margin-bottom: 32px;
  font-style: italic;
  line-height: 1.6;
}

/* ─── Act 4: CTA ─── */
.cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}
.cta-link {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--cyan-dim);
  text-decoration: none;
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 10px 18px;
  letter-spacing: 0.06em;
  transition: all 0.2s;
}
.cta-link:hover {
  color: var(--cyan);
  border-color: rgba(0,255,255,0.3);
  box-shadow: 0 0 8px rgba(0,255,255,0.1);
}
</style>

<script>
// ═══ Scroll Reveal + Hash Tracking ═══
(function() {
  const acts = document.querySelectorAll('.act');
  let currentAct = null;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        const actId = e.target.id;
        if (actId && actId !== currentAct) {
          currentAct = actId;
          history.replaceState(null, '', location.pathname + location.search + '#' + actId);
        }
      }
    });
  }, { threshold: 0.15 });
  acts.forEach((a) => observer.observe(a));

  // Restore scroll position from hash on load
  const hash = location.hash.replace('#', '');
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth' });
        target.classList.add('visible');
      }, 200);
    }
  }
})();

// ═══ Deep Link Button ═══
(function() {
  const btn = document.getElementById('deeplink-btn');
  if (!btn) return;
  btn.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      btn.textContent = 'Copied!';
      btn.style.color = '#00d4ff';
      btn.style.borderColor = 'rgba(0,212,255,0.4)';
      setTimeout(() => {
        btn.textContent = 'Link';
        btn.style.color = '';
        btn.style.borderColor = '';
      }, 1500);
    });
  });
})();

// ═══ CLD: Pure SVG Node Interaction ═══
(function() {
  const container = document.getElementById('cld-container');
  if (!container) return;
  const nodes = container.querySelectorAll('.cld-node-g');
  const edges = container.querySelectorAll('.cld-edge');
  const edgeLabels = container.querySelectorAll('.cld-edge-label');
  const titleEl = document.getElementById('cld-annotation-title');
  const textEl = document.getElementById('cld-annotation-text');

  const annotations = {
    escape: {
      title: 'Escaping Pins',
      text: "Goal 1. Survive being held. Breathe under pressure. This is the last line of defense but arguably the most important. If they can never finish you, you'll have infinite opportunities to retaliate."
    },
    guard: {
      title: 'Retaining Guard',
      text: 'Goal 2. Keep them from passing. More energy efficient than letting them settle. The first layer of comfort.'
    },
    confidence: {
      title: 'Confidence / Taking Risks',
      text: "The unlock. When you know you can survive, you stop fearing failure. That's when real learning begins."
    },
    dominant: {
      title: 'Reach Dominant Positions',
      text: 'With confidence built on real escape-artist skills, your success rate reaching dominant positions will improve. Partly because of techniques, partly because you know how to escape and therefore how to not let THEM escape. And partly because your body is starting to adapt.'
    },
    maintain: {
      title: 'Maintain Dominant Positions',
      text: 'Holding the position or improving it without regressing. Pressure, weight distribution, anticipating their escapes, manipulating levers, seeing the options.'
    },
    submit: {
      title: 'Achieve Submissions',
      text: 'The downstream result. Submissions happen when everything upstream is solid. I recommend practicing finishing mechanics as a separate skill. (see End Game)'
    },
    creativity: {
      title: 'Creativity / Mindful Practice',
      text: 'The explore side. Trying new things, starting from bad positions, reducing tension, playing with invisible jiu-jitsu. This is mostly where insights come from.'
    }
  };

  const neighbors = {
    escape:     ['confidence'],
    guard:      ['confidence'],
    confidence: ['escape', 'guard', 'dominant', 'creativity'],
    dominant:   ['confidence', 'maintain', 'creativity'],
    maintain:   ['dominant', 'submit'],
    submit:     ['maintain'],
    creativity: ['confidence', 'dominant']
  };

  function edgeTouches(edgeId, nodeId) {
    return edgeId.split('-').indexOf(nodeId) !== -1;
  }

  let active = null;

  nodes.forEach(function(n) {
    n.addEventListener('click', function() {
      const id = n.getAttribute('data-node');
      if (active === id) {
        active = null;
        container.classList.remove('has-selection');
        nodes.forEach(function(x) { x.classList.remove('active', 'connected'); });
        edges.forEach(function(e) { e.classList.remove('edge-active'); });
        edgeLabels.forEach(function(t) { t.classList.remove('label-active'); });
        titleEl.textContent = '';
        textEl.textContent = 'Click any node to learn its role in the system.';
        return;
      }
      active = id;
      container.classList.add('has-selection');
      const nb = neighbors[id] || [];

      nodes.forEach(function(x) {
        const xid = x.getAttribute('data-node');
        x.classList.remove('active', 'connected');
        if (xid === id) x.classList.add('active');
        else if (nb.indexOf(xid) !== -1) x.classList.add('connected');
      });

      edges.forEach(function(e) {
        e.classList.toggle('edge-active', edgeTouches(e.getAttribute('data-edge'), id));
      });
      edgeLabels.forEach(function(t) {
        t.classList.toggle('label-active', edgeTouches(t.getAttribute('data-edge'), id));
      });

      const ann = annotations[id];
      if (ann) { titleEl.textContent = ann.title; textEl.textContent = ann.text; }
    });
  });
})();
</script>
