---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Quote data ──
const quoteEntries = await getCollection('horseshoe-quotes');
const alphaEntry = quoteEntries.find(e => e.data.side === 'alpha')!;
const buffoonEntry = quoteEntries.find(e => e.data.side === 'buffoon')!;
const alphaQuotes = (alphaEntry.body ?? '').split('\n').filter(l => l.trim().length > 0);
const buffoonQuotes = (buffoonEntry.body ?? '').split('\n').filter(l => l.trim().length > 0);

// ── Essay ──
const essayEntry = await getEntry('Articles', 'signal-noise-horseshoe');
const { Content: EssayContent } = await essayEntry!.render();
---

<BaseLayout title="Signal / Noise — Grappling Primitives">
  <div class="hs-page">

    <header class="hs-header">
      <p class="hs-eyebrow">Grappling Primitives</p>
      <h1 class="hs-title">Signal / Noise</h1>
      <p class="hs-sub">overdoing jokes and badassery</p>
    </header>

    <button id="deeplink-btn" class="hs-deeplink">Link</button>

    <div class="hs-stage">

      <!-- center panel -->
      <div class="hs-center" style="position:relative;">
        <!-- quote overlay inside the horseshoe -->
        <div id="zone-inner" class="hs-inner-quotes"></div>
        <svg viewBox="0 0 500 420" class="hs-svg">
          <defs>
            <linearGradient id="hs-grad" x1="0" y1="1" x2="0" y2="0">
              <stop offset="0%"   stop-color="#b71c1c"/>
              <stop offset="25%"  stop-color="#d32f2f"/>
              <stop offset="40%"  stop-color="#ef6c00"/>
              <stop offset="55%"  stop-color="#f9a825"/>
              <stop offset="70%"  stop-color="#66bb6a"/>
              <stop offset="85%"  stop-color="#43a047"/>
              <stop offset="100%" stop-color="#2e7d32"/>
            </linearGradient>
          </defs>
          <!-- horseshoe arc: center (250,210), radius 210, stroke 20 -->
          <path d="M 100,340 A 210,210 0 0,1 40,210 A 210,210 0 0,1 100,80 A 210,210 0 0,1 400,80 A 210,210 0 0,1 460,210 A 210,210 0 0,1 400,340" stroke="url(#hs-grad)" stroke-width="20" fill="none" stroke-linecap="round"/>
          <!-- neighbor line -->
          <line x1="100" y1="365" x2="400" y2="365" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
          <!-- labels -->
          <text x="70"  y="395" text-anchor="middle" font-size="14" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.45)">alpha bro</text>
          <text x="430" y="395" text-anchor="middle" font-size="14" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.45)">buffoon</text>
          <text x="250" y="388" text-anchor="middle" font-size="12" font-family="'Courier New',Consolas,monospace" fill="rgba(229,231,235,0.22)">extremes are neighbors</text>
          <!-- dot -->
          <circle id="hs-dot" cx="250" cy="70" r="8" fill="#050509" stroke="#2e7d32" stroke-width="2.5"/>
        </svg>

        <div class="hs-slider-row">
          <input type="range" id="hs-slider" min="0" max="100" value="50" step="1" aria-label="Signal-noise spectrum position">
          <div class="hs-slider-labels">
            <span>alpha extreme</span>
            <span>craft center</span>
            <span>buffoon extreme</span>
          </div>
        </div>

        <div class="hs-signal-row">
          <span class="hs-signal-label">signal</span>
          <div class="hs-signal-track">
            <div class="hs-signal-fill" id="hs-bar"></div>
          </div>
          <span class="hs-signal-pct" id="hs-pct">95%</span>
        </div>

      </div>

    </div>

    <details class="tldr">
      <summary class="tldr__toggle">short essay on the 'grappling horseshoe zeitgeist'</summary>
      <div class="tldr__body article-prose">
        <EssayContent />
      </div>
    </details>

  </div>
</BaseLayout>

<script define:vars={{ alphaQuotes, buffoonQuotes }}>
(function () {
  'use strict';

  const ZONES = [
    { max: 15,  label: 'Alpha extreme \u2014 performance crowding signal', color: '#c62828',
      desc: 'Every roll is a proving ground. Training partners are prey. The mat serves the persona, not the other way around.' },
    { max: 35,  label: 'Alpha register \u2014 signal dominant',            color: '#ef6c00',
      desc: 'Real-politik edge that checks complacency. The tough register in service of the craft \u2014 not the craft in service of the idiom.' },
    { max: 65,  label: 'Craft center',                                     color: '#2e7d32',
      desc: 'The thing being studied is the point. Humor, edge, intensity \u2014 held in reserve, deployed with intent. Idiom serves the work.' },
    { max: 85,  label: 'Levity register \u2014 signal dominant',           color: '#ef6c00',
      desc: 'Humor makes the room easier to be in. Self-deprecating acknowledgment of the absurdity. Signal intact \u2014 the joke is not the session.' },
    { max: 100, label: 'Buffoon extreme \u2014 performance crowding signal', color: '#c62828',
      desc: 'Every position is a bit. Every tap is a performance. The mat is a stage. Two people rolling are the audience. Signal gone.' },
  ];

  const sl  = document.getElementById('hs-slider');
  const dot = document.getElementById('hs-dot');
  const bar = document.getElementById('hs-bar');
  const pct = document.getElementById('hs-pct');
  const zI  = document.getElementById('zone-inner');

  var CRAFT_Q = [
    'Turn the resistance up but controlled',
    "Don't take it too seriously, relax",
    'Be aware of how you got tapped',
    'Give them challenges, not injuries',
    'Focus and feel what\'s going on',
    'Breathe, you learn motor skills better when calm',
    'If you don\'t know what to do, don\'t explode',
  ];

  var aUsed = [], bUsed = [], cUsed = [];

  function pick(arr, used) {
    if (used.length >= arr.length) used.length = 0;
    var rem = arr.filter(function (q) { return used.indexOf(q) < 0; });
    var q = rem[Math.floor(Math.random() * rem.length)];
    used.push(q);
    return q;
  }

  // ── Quote display: one at a time, triggered by movement ──
  var activeKill = null;

  function clearQuote() {
    if (activeKill) { activeKill(); activeKill = null; }
  }

  function showQuote(text, cls) {
    clearQuote();

    var el = document.createElement('div');
    el.className = 'hs-q-item hs-q-item--' + cls;
    el.textContent = '\u201C' + text + '\u201D';
    el.style.opacity = '0';
    zI.appendChild(el);

    var killed = false;
    activeKill = function () { killed = true; el.remove(); };

    var FI = 350, STAY = 2200, FO = 700, total = FI + STAY + FO;
    var t0 = null;

    (function frame(ts) {
      if (killed) return;
      if (!t0) t0 = ts;
      var e = ts - t0;
      var op;
      if      (e < FI)        op = e / FI;
      else if (e < FI + STAY) op = 1;
      else if (e < total)     op = 1 - (e - FI - STAY) / FO;
      else { el.remove(); activeKill = null; return; }
      el.style.opacity = op.toFixed(3);
      requestAnimationFrame(frame);
    })(performance.now());
  }

  function quoteForValue(v) {
    if (v <= 25)                return { text: pick(alphaQuotes, aUsed),   cls: 'alpha' };
    if (v >= 75)                return { text: pick(buffoonQuotes, bUsed), cls: 'buffoon' };
    if (v >= 36 && v <= 64)     return { text: pick(CRAFT_Q, cUsed),      cls: 'craft' };
    return null; // transition zones: no quote
  }

  // ── Render (no quote logic, just visuals) ──
  function render(v) {
    var t = v / 100;
    var a = (120 + t * 300) * Math.PI / 180;
    dot.setAttribute('cx', (250 + 210 * Math.cos(a)).toFixed(2));
    dot.setAttribute('cy', (210 + 210 * Math.sin(a)).toFixed(2));

    var z = ZONES.find(function (x) { return v <= x.max; }) || ZONES[4];
    dot.setAttribute('stroke', z.color);

    var sig = Math.round(20 + 75 * (1 - Math.pow(2 * v / 100 - 1, 2)));
    bar.style.width      = sig + '%';
    bar.style.background = z.color;
    pct.textContent      = sig + '%';

    sl.style.setProperty('--thumb-color', z.color);
  }

  // ── Autoplay mode ──
  var autoMode = true;
  var idleTimeout = null;
  var autoTimeout = null;
  var autoTargets = [];
  var autoIdx = 0;

  // pre-build a tour: a sequence of interesting positions
  function buildTour() {
    var pts = [];
    // visit a few zones in a natural-feeling order
    var stops = [50, 20, 5, 40, 80, 95, 55, 10, 70, 45];
    for (var i = 0; i < stops.length; i++) pts.push(stops[i]);
    return pts;
  }
  autoTargets = buildTour();

  function autoStep() {
    if (!autoMode) return;

    var target = autoTargets[autoIdx % autoTargets.length];
    autoIdx++;
    var current = +sl.value;
    var dir = target > current ? 1 : -1;
    var steps = Math.abs(target - current);
    var stepNum = 0;

    function tick() {
      if (!autoMode) return;
      if (stepNum >= steps) {
        // arrived: show a quote, then wait 2s before next move
        var q = quoteForValue(target);
        if (q) showQuote(q.text, q.cls);
        autoTimeout = setTimeout(autoStep, 2000);
        return;
      }
      stepNum++;
      var v = current + dir * stepNum;
      v = Math.max(0, Math.min(100, v));
      sl.value = v;
      render(v);
      // move at ~20 units/sec (50ms per step)
      autoTimeout = setTimeout(tick, 50);
    }
    tick();
  }

  function startAutoplay() {
    autoMode = true;
    autoStep();
  }

  function stopAutoplay() {
    autoMode = false;
    if (autoTimeout) { clearTimeout(autoTimeout); autoTimeout = null; }
  }

  function resetIdleTimer() {
    if (idleTimeout) clearTimeout(idleTimeout);
    idleTimeout = setTimeout(startAutoplay, 10000);
  }

  // ── Manual mode: zone change = new quote ──
  var lastZone = null;

  function zoneFor(v) {
    if (v <= 25)            return 'alpha';
    if (v >= 75)            return 'buffoon';
    if (v >= 36 && v <= 64) return 'craft';
    return 'transition';
  }

  sl.addEventListener('input', function (e) {
    stopAutoplay();
    var v = +e.target.value;
    render(v);

    var zone = zoneFor(v);
    if (zone !== lastZone) {
      lastZone = zone;
      var q = quoteForValue(v);
      if (q) showQuote(q.text, q.cls);
      else clearQuote();
    }

    resetIdleTimer();
  });

  // init
  render(50);
  startAutoplay();

  var dlBtn = document.getElementById('deeplink-btn');
  if (dlBtn) {
    dlBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(window.location.href).then(function () {
        dlBtn.textContent = 'Copied!';
        setTimeout(function () { dlBtn.textContent = 'Link'; }, 1500);
      });
    });
  }
})();
</script>

<style is:global>
  .hs-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 16px 64px;
  }

  .hs-header {
    text-align: center;
    margin-bottom: 48px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hs-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .hs-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    margin-bottom: 14px;
    text-shadow: 0 0 12px #2e7d3266;
  }

  .hs-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  .hs-deeplink {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 60;
    font-family: 'Courier New', Consolas, Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 3px;
    cursor: pointer;
    border: 1px solid #21262d;
    background: transparent;
    color: #6b7280;
    transition: all 0.15s;
  }
  .hs-deeplink:hover {
    border-color: rgba(0,212,255,0.4);
    color: #00d4ff;
  }

  /* ── main layout ── */
  .hs-stage {
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── quote overlay (centered inside horseshoe) ── */
  .hs-inner-quotes {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hs-q-item {
    font-size: var(--text-xs);
    line-height: 1.6;
    font-style: italic;
    opacity: 0;
    pointer-events: none;
    text-align: center;
    max-width: 180px;
    padding: 4px 8px;
    word-wrap: break-word;
  }

  .hs-q-item--alpha   { color: #d32f2f; }
  .hs-q-item--buffoon { color: #ef6c00; }
  .hs-q-item--craft   { color: #43a047; }

  /* ── SVG panel ── */
  .hs-svg { width: 100%; display: block; }

  /* ── slider ── */
  .hs-slider-row {
    padding: 0 2rem;
    margin: 4px 0 12px;
  }

  .hs-slider-row input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, #b71c1c 0%, #c62828 10%, #ef6c00 25%, #f9a825 35%, #66bb6a 42%, #2e7d32 50%, #66bb6a 58%, #f9a825 65%, #ef6c00 75%, #c62828 90%, #b71c1c 100%);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    opacity: 0.7;
  }

  .hs-slider-row input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #050509;
    border: 2.5px solid var(--thumb-color, #2e7d32);
    cursor: grab;
    transition: border-color 0.15s;
  }

  .hs-slider-row input[type=range]:active::-webkit-slider-thumb { cursor: grabbing; }

  .hs-slider-row input[type=range]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #050509;
    border: 2.5px solid var(--thumb-color, #2e7d32);
    cursor: grab;
  }

  .hs-slider-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: var(--text-sm);
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  /* ── signal bar ── */
  .hs-signal-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 1rem;
    margin-bottom: 16px;
  }

  .hs-signal-label {
    font-size: var(--text-sm);
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-width: 36px;
  }

  .hs-signal-track {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }

  .hs-signal-fill {
    height: 100%;
    width: 95%;
    background: #2e7d32;
    border-radius: 2px;
    transition: width 0.15s ease, background 0.15s ease;
  }

  .hs-signal-pct {
    font-size: var(--text-base);
    color: var(--text-muted);
    min-width: 30px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }


  /* ── tolkien footer ── */
  .hs-tolkien {
    margin-top: 52px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }

  .hs-tolkien blockquote {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 8px;
  }

  .hs-tolkien cite {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  /* ── responsive ── */
  @media (max-width: 600px) {
    .hs-header { margin-bottom: 32px; }
  }
</style>
