---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allConcepts = await getCollection('concepts');
const concept = allConcepts.find(c => c.data.id === 'BJJ-260');
const cardBody = (concept.body ?? '').replace(/\n---\nCategory:.*$/s, '').trim();
---

<BaseLayout title="Build Yourself — Grappling Primitives" fullscreen={true}>

<!-- ── Toolbar ──────────────────────────────────────────────────────────────── -->
<div id="toolbar" style="position:fixed;top:0;left:0;right:0;height:36px;z-index:50;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Courier New',Consolas,Monaco,monospace;overflow-x:auto;-webkit-overflow-scrolling:touch;flex-wrap:nowrap;">
  <a href={`${base}/`} style="font-size:10px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;text-decoration:none;white-space:nowrap;flex-shrink:0;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'">&larr; Home</a>
  <span style="color:#21262d;flex-shrink:0;">|</span>
  <a href="#" id="title-link" style="font-size:11px;letter-spacing:0.2em;color:#6b7280;text-transform:uppercase;white-space:nowrap;flex-shrink:0;text-decoration:none;cursor:pointer;" onmouseover="this.style.color='#00d4ff'" onmouseout="this.style.color='#6b7280'" title="Click for about info">BUILD YOURSELF</a>
  <div style="flex:1;min-width:4px;flex-shrink:1;"></div>
  <button id="autoplay-btn" style="font-family:inherit;font-size:13px;padding:2px 8px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;white-space:nowrap;flex-shrink:0;line-height:1;" aria-label="Pause auto-advance"><span class="play-icon">⏸</span></button>
  <span style="color:#21262d;flex-shrink:0;">|</span>
  <button id="btn-deeplink" style="font-family:inherit;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;padding:3px 9px;border-radius:3px;cursor:pointer;border:1px solid #21262d;background:transparent;color:#6b7280;transition:all 0.15s;white-space:nowrap;flex-shrink:0;">Link</button>
</div>
<!-- Hidden scenario select (disabled for now) -->
<select id="scenario-select" style="display:none;">
  <option value="standing">Standing</option>
</select>

<!-- ── Header ──────────────────────────────────────────────────────────────── -->
<div id="header" style="position:fixed;top:36px;left:0;right:0;z-index:40;padding:6px 16px 0;border-bottom:1px solid #21262d;background:rgba(5,5,9,0.97);backdrop-filter:blur(8px);font-family:'Courier New',Consolas,Monaco,monospace;text-align:center;">
  <div style="display:flex;justify-content:center;align-items:baseline;gap:12px;">
    <a href="#" id="header-title-link" style="text-decoration:none;cursor:pointer;" title="Click for about info">
      <span style="font-size:16px;color:#00d4ff;letter-spacing:0.05em;" lang="ja">自分を作れ</span>
      <span style="font-size:13px;color:#c9d1d9;letter-spacing:0.12em;margin-left:4px;">Build Yourself</span>
    </a>
  </div>
  <div style="font-size:clamp(10px,1.5vw,13px);color:#6b7280;letter-spacing:0.06em;margin-top:1px;">Self-organization as the primary variable, four lenses, one body</div>
  <!-- Slider row -->
  <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
    <span style="font-size:8px;letter-spacing:0.14em;color:#6b7280;text-transform:uppercase;flex-shrink:0;">Unbuilt</span>
    <input type="range" id="slider" min="0" max="1" step="0.001" value="0" style="flex:1;height:4px;cursor:pointer;accent-color:#00d4ff;" aria-label="Build progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="1" />
    <span style="font-size:8px;letter-spacing:0.14em;color:#6b7280;text-transform:uppercase;flex-shrink:0;">Built</span>
  </div>
  <!-- Stage label -->
  <div id="slider-label" style="font-size:clamp(11px,1.6vw,14px);color:#6b7280;text-align:center;margin:2px 0 1px;letter-spacing:0.08em;min-height:16px;"></div>
  <!-- Step buttons -->
  <div id="steps" style="display:flex;justify-content:center;gap:4px;flex-wrap:wrap;padding-bottom:5px;"></div>
</div>

<!-- ── App area (4 canvas panels) ──────────────────────────────────────────── -->
<div id="app-wrap" style="position:fixed;top:150px;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#050509;">
<div id="app" style="display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:2px;background:#21262d;font-family:'Courier New',Consolas,Monaco,monospace;border-radius:6px;overflow:hidden;width:min(1000px, calc(100vh - 160px), 100vw);aspect-ratio:1/1;">
  <div class="panel-wrap" style="position:relative;overflow:hidden;background:#0a0e14;">
    <canvas id="canvas-tension" aria-label="Tension Economy heatmap panel"></canvas>
    <span id="sr-tension" class="sr-only" role="status" aria-live="polite"></span>
  </div>
  <div class="panel-wrap" style="position:relative;overflow:hidden;background:#0a0e14;">
    <canvas id="canvas-connections" aria-label="Internal Connections panel"></canvas>
    <span id="sr-connections" class="sr-only" role="status" aria-live="polite"></span>
  </div>
  <div class="panel-wrap" style="position:relative;overflow:hidden;background:#0a0e14;">
    <canvas id="canvas-force" aria-label="Force Flow panel"></canvas>
    <span id="sr-force" class="sr-only" role="status" aria-live="polite"></span>
  </div>
  <div class="panel-wrap" style="position:relative;overflow:hidden;background:#0a0e14;">
    <canvas id="canvas-stacking" aria-label="Stacking Alignment panel"></canvas>
    <span id="sr-stacking" class="sr-only" role="status" aria-live="polite"></span>
  </div>
</div>
</div>

<!-- ── Tooltip ─────────────────────────────────────────────────────────────── -->
<div id="tooltip" style="position:fixed;z-index:100;max-width:240px;padding:10px 12px;border-radius:4px;background:rgba(5,5,9,0.95);border:1px solid #21262d;color:#c9d1d9;font-family:'Courier New',Consolas,Monaco,monospace;font-size:10px;line-height:1.6;pointer-events:none;opacity:0;transition:opacity 0.15s;" aria-hidden="true"></div>

<!-- ── Card modal (Quadtree-style) ──────────────────────────────────────────── -->
<div id="about-modal" class="hidden" style="position:fixed;inset:0;z-index:200;align-items:center;justify-content:center;padding:16px;background:rgba(0,0,0,0.80);backdrop-filter:blur(4px);" role="dialog" aria-label="About Build Yourself">
  <div style="width:100%;max-width:min(640px,98vw);max-height:88vh;display:flex;flex-direction:column;font-family:'Courier New',Consolas,Monaco,monospace;background:#000d18;border:1px solid #848a9488;box-shadow:0 0 40px rgba(0,0,0,0.8);">
    <div style="display:flex;align-items:start;justify-content:space-between;gap:12px;padding:20px;border-bottom:1px solid rgba(255,255,255,0.08);">
      <div>
        <div style="font-size:14px;font-weight:700;color:#c9d1d9;margin-bottom:4px;">{concept.data.concept}</div>
        <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#848a94;">Grappling Primitives</div>
      </div>
      <button id="modal-close" style="font-family:inherit;font-size:18px;background:none;border:none;color:#6b7280;cursor:pointer;padding:4px 8px;flex-shrink:0;line-height:1;" aria-label="Close">&times;</button>
    </div>
    <div style="flex:1;overflow-y:auto;padding:20px;font-size:13px;color:#8b949e;line-height:1.7;white-space:pre-wrap;">{cardBody}</div>
  </div>
</div>

<style>
  /* When embedded in an iframe, hide toolbar and compact header */
  .is-embedded #toolbar { display: none !important; }
  .is-embedded #about-modal { display: none !important; }
  .is-embedded #header { top: 0 !important; padding: 4px 12px 0 !important; }
  .is-embedded #app-wrap { top: 120px !important; }
  .is-embedded .step-btn { font-size: 11px !important; padding: 4px 12px !important; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  .panel-wrap canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #toolbar::-webkit-scrollbar { display: none; }
  #toolbar { -ms-overflow-style: none; scrollbar-width: none; }
  #header::-webkit-scrollbar { display: none; }
  #header { -ms-overflow-style: none; scrollbar-width: none; }

  #tooltip.visible { opacity: 1; }

  #autoplay-btn:hover,
  #btn-deeplink:hover { border-color: #00d4ff; color: #00d4ff; }

  .panel-wrap { border-radius: 4px; aspect-ratio: 1/1; }

  @media (max-width: 700px) {
    #steps { flex-wrap: wrap; }
  }
</style>

<style is:global>
  .step-btn {
    font-family: 'Courier New', Consolas, Monaco, monospace;
    font-size: clamp(9px, 1.4vw, 12px);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
    cursor: pointer;
    border: 1px solid #21262d;
    background: transparent;
    color: #6b7280;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .step-btn:hover { border-color: #888; color: #ccc; }
  .step-btn.lit { box-shadow: 0 0 6px rgba(0,0,0,0.3); }
  .step-btn.active { box-shadow: 0 0 8px rgba(255,255,255,0.2); }
</style>

<script is:inline>
// Detect if we're inside an iframe (embedded in jibunwotsukure)
if (window.self !== window.top) {
  document.body.classList.add('is-embedded');
}
</script>

<script>
(function(){
// ============================================================
// 1. Math utils
// ============================================================
function lerp(a, b, t) { return a + (b - a) * t; }
function clamp(v, min, max) {
  if (min === undefined) { min = 0; max = 1; }
  return Math.max(min, Math.min(max, v));
}
function easeInOut(t) { return t * t * (3 - 2 * t); }
function dist(a, b) {
  var dx = b.x - a.x, dy = b.y - a.y;
  return Math.sqrt(dx * dx + dy * dy);
}
function lerpPos(a, b, t) { return { x: lerp(a.x, b.x, t), y: lerp(a.y, b.y, t) }; }

// ============================================================
// 2. Color constants + helpers
// ============================================================
var COLORS = {
  bg: '#050509',
  panel: '#0a0e14',
  panelBorder: '#21262d',
  bone: '#c8d6e5',
  boneDim: '#576574',
  node: '#c9d1d9',
  text: '#c9d1d9',
  textDim: '#6b7280',
  label: '#00d4ff',
  heatHot: [255, 60, 40],
  heatWarm: [255, 165, 0],
  heatCool: [40, 120, 200],
  connectionGlow: '#00cec9',
  connectionDim: '#2d3436',
  forceArrow: '#fdcb6e',
  forceBlocked: '#d63031',
  forceFlowing: '#00b894',
  plumbLine: '#6b7280',
  landmarkAligned: '#55efc4',
  landmarkOff: '#e17055',
  accent: '#e056fd',
  sliderTrack: '#2d3436',
  sliderThumb: '#00d4ff',
};

function heatColor(t) {
  var hot = COLORS.heatHot, cool = COLORS.heatCool;
  var r = Math.round(cool[0] + (hot[0] - cool[0]) * t);
  var g = Math.round(cool[1] + (hot[1] - cool[1]) * t);
  var b = Math.round(cool[2] + (hot[2] - cool[2]) * t);
  return 'rgb(' + r + ',' + g + ',' + b + ')';
}

function heatColorAlpha(t, alpha) {
  var hot = COLORS.heatHot, cool = COLORS.heatCool;
  var r = Math.round(cool[0] + (hot[0] - cool[0]) * t);
  var g = Math.round(cool[1] + (hot[1] - cool[1]) * t);
  var b = Math.round(cool[2] + (hot[2] - cool[2]) * t);
  return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
}

// ============================================================
// 3. Drawing helpers
// ============================================================
function clearPanel(ctx, w, h) {
  ctx.fillStyle = COLORS.panel;
  ctx.fillRect(0, 0, w, h);
}

function drawLine(ctx, a, b, color, width) {
  ctx.beginPath();
  ctx.moveTo(a.x, a.y);
  ctx.lineTo(b.x, b.y);
  ctx.strokeStyle = color;
  ctx.lineWidth = width || 2;
  ctx.stroke();
}

function drawCircle(ctx, pos, radius, color) {
  ctx.beginPath();
  ctx.arc(pos.x, pos.y, radius, 0, Math.PI * 2);
  ctx.fillStyle = color;
  ctx.fill();
}

function drawGlow(ctx, pos, radius, color, alpha) {
  if (alpha === undefined) alpha = 0.5;
  var grad = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, radius);
  grad.addColorStop(0, color.replace(')', ',' + alpha + ')').replace('rgb', 'rgba'));
  grad.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.beginPath();
  ctx.arc(pos.x, pos.y, radius, 0, Math.PI * 2);
  ctx.fillStyle = grad;
  ctx.fill();
}

function drawArrow(ctx, from, to, color, width, headSize) {
  width = width || 2;
  headSize = headSize || 8;
  var angle = Math.atan2(to.y - from.y, to.x - from.x);
  ctx.beginPath();
  ctx.moveTo(from.x, from.y);
  ctx.lineTo(to.x, to.y);
  ctx.strokeStyle = color;
  ctx.lineWidth = width;
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(to.x, to.y);
  ctx.lineTo(to.x - headSize * Math.cos(angle - Math.PI / 6), to.y - headSize * Math.sin(angle - Math.PI / 6));
  ctx.lineTo(to.x - headSize * Math.cos(angle + Math.PI / 6), to.y - headSize * Math.sin(angle + Math.PI / 6));
  ctx.closePath();
  ctx.fillStyle = color;
  ctx.fill();
}

function drawLabel(ctx, text, x, y, fontSize, color) {
  ctx.font = (fontSize || 14) + "px 'Courier New', Consolas, monospace";
  ctx.fillStyle = color || COLORS.text;
  ctx.textAlign = 'center';
  ctx.fillText(text, x, y);
}

// pos: 'tl' | 'tr' | 'bl' | 'br' — which quadrant the panel occupies
function drawPanelTitle(ctx, title, subtitle, w, h, pos) {
  var pad = 12;
  // English — outer diagonal corner, large
  ctx.font = "bold 18px 'Courier New', Consolas, monospace";
  ctx.fillStyle = COLORS.label;
  if (pos === 'tl') { ctx.textAlign = 'left';  ctx.fillText(title, pad, 26); }
  else if (pos === 'tr') { ctx.textAlign = 'right'; ctx.fillText(title, w - pad, 26); }
  else if (pos === 'bl') { ctx.textAlign = 'left';  ctx.fillText(title, pad, h - pad); }
  else if (pos === 'br') { ctx.textAlign = 'right'; ctx.fillText(title, w - pad, h - pad); }
  // Japanese — inner corner (toward center), large
  if (subtitle) {
    ctx.font = "bold 20px sans-serif";
    ctx.fillStyle = COLORS.textDim;
    if (pos === 'tl') { ctx.textAlign = 'right'; ctx.fillText(subtitle, w - pad, h - pad); }
    else if (pos === 'tr') { ctx.textAlign = 'left';  ctx.fillText(subtitle, pad, h - pad); }
    else if (pos === 'bl') { ctx.textAlign = 'right'; ctx.fillText(subtitle, w - pad, 26); }
    else if (pos === 'br') { ctx.textAlign = 'left';  ctx.fillText(subtitle, pad, 26); }
  }
}

function drawDashedLine(ctx, a, b, color, width, dash) {
  ctx.beginPath();
  ctx.setLineDash(dash || [4, 4]);
  ctx.moveTo(a.x, a.y);
  ctx.lineTo(b.x, b.y);
  ctx.strokeStyle = color;
  ctx.lineWidth = width || 1;
  ctx.stroke();
  ctx.setLineDash([]);
}

// ============================================================
// 4. Mannequin topology
// ============================================================
var NODES = [
  'head', 'neck',
  'shoulderL', 'shoulderR', 'shoulderMid',
  'elbowL', 'elbowR',
  'handL', 'handR',
  'spine', 'core',
  'hipL', 'hipR', 'hipMid',
  'kneeL', 'kneeR',
  'ankleL', 'ankleR', 'ankleMid',
];

var BONES = [
  ['head', 'neck'],
  ['neck', 'shoulderL'], ['neck', 'shoulderR'],
  ['shoulderL', 'elbowL'], ['shoulderR', 'elbowR'],
  ['elbowL', 'handL'], ['elbowR', 'handR'],
  ['neck', 'spine'], ['spine', 'core'],
  ['core', 'hipL'], ['core', 'hipR'],
  ['hipL', 'kneeL'], ['hipR', 'kneeR'],
  ['kneeL', 'ankleL'], ['kneeR', 'ankleR'],
];

var MIDPOINTS = {
  shoulderMid: ['shoulderL', 'shoulderR'],
  hipMid: ['hipL', 'hipR'],
  ankleMid: ['ankleL', 'ankleR'],
};

var REGIONS = {
  head: ['head'],
  neck: ['neck'],
  shoulderR: ['shoulderR'],
  shoulderL: ['shoulderL'],
  armR: ['elbowR', 'handR'],
  armL: ['elbowL', 'handL'],
  upperBack: ['spine'],
  core: ['core'],
  hipR: ['hipR'],
  hipL: ['hipL'],
  legR: ['kneeR', 'ankleR'],
  legL: ['kneeL', 'ankleL'],
};

var CONNECTION_PAIRS = [
  { from: 'shoulderL', to: 'hipR', label: 'L shoulder→R hip' },
  { from: 'shoulderR', to: 'hipL', label: 'R shoulder→L hip' },
  { from: 'elbowL', to: 'kneeL', label: 'L elbow→L knee' },
  { from: 'elbowR', to: 'kneeR', label: 'R elbow→R knee' },
  { from: 'handL', to: 'handR', label: 'hand↔hand' },
  { from: 'shoulderL', to: 'hipL', label: 'L column' },
  { from: 'shoulderR', to: 'hipR', label: 'R column' },
];

var SPINE_PATH = ['head', 'neck', 'spine', 'core'];
var ARCH_PATH = ['ankleL', 'kneeL', 'hipL', 'hipR', 'kneeR', 'ankleR'];
var FORCE_PATH = ['shoulderR', 'neck', 'spine', 'core', 'hipR', 'kneeR', 'ankleR'];
var LANDMARKS = ['head', 'shoulderMid', 'hipMid', 'ankleMid'];

function scalePositions(positions, w, h) {
  var margin = { top: 60, bottom: 20, left: 40, right: 40 };
  var drawW = w - margin.left - margin.right;
  var drawH = h - margin.top - margin.bottom;
  var scaled = {};
  for (var key in positions) {
    scaled[key] = {
      x: margin.left + positions[key].x * drawW,
      y: margin.top + positions[key].y * drawH,
    };
  }
  for (var mid in MIDPOINTS) {
    var pair = MIDPOINTS[mid];
    if (scaled[pair[0]] && scaled[pair[1]]) {
      scaled[mid] = {
        x: (scaled[pair[0]].x + scaled[pair[1]].x) / 2,
        y: (scaled[pair[0]].y + scaled[pair[1]].y) / 2,
      };
    }
  }
  return scaled;
}

function drawMannequin(ctx, positions, opts) {
  opts = opts || {};
  var boneColor = opts.boneColor || COLORS.boneDim;
  var nodeColor = opts.nodeColor || COLORS.node;
  var boneWidth = opts.boneWidth || 2;
  var nodeRadius = opts.nodeRadius || 3;
  var showNodes = opts.showNodes !== false;
  var midpointKeys = Object.keys(MIDPOINTS);

  for (var i = 0; i < BONES.length; i++) {
    var a = BONES[i][0], b = BONES[i][1];
    if (positions[a] && positions[b]) drawLine(ctx, positions[a], positions[b], boneColor, boneWidth);
  }
  if (showNodes) {
    for (var j = 0; j < NODES.length; j++) {
      if (positions[NODES[j]] && midpointKeys.indexOf(NODES[j]) === -1) {
        drawCircle(ctx, positions[NODES[j]], nodeRadius, nodeColor);
      }
    }
  }
}

// ============================================================
// 5. State interpolation
// ============================================================
function computeState(scenario, t) {
  t = clamp(t, 0, 1);
  var kfs = scenario.keyframes;
  var lo = kfs[0], hi = kfs[kfs.length - 1];
  for (var i = 0; i < kfs.length - 1; i++) {
    if (t >= kfs[i].t && t <= kfs[i + 1].t) {
      lo = kfs[i]; hi = kfs[i + 1]; break;
    }
  }
  var segLen = hi.t - lo.t;
  var lt = segLen === 0 ? 0 : (t - lo.t) / segLen;

  return {
    t: t,
    label: lt < 0.5 ? lo.label : hi.label,
    description: lt < 0.5 ? lo.description : hi.description,
    positions: lerpPositions(lo.positions, hi.positions, lt),
    tension: lerpObject(lo.tension, hi.tension, lt),
    connections: lerpObject(lo.connections, hi.connections, lt),
    forceEfficiency: lerp(lo.forceEfficiency, hi.forceEfficiency, lt),
    forceAccumulation: lerpObject(lo.forceAccumulation, hi.forceAccumulation, lt),
  };
}

function lerpPositions(a, b, t) {
  var result = {};
  for (var key in a) result[key] = lerpPos(a[key], b[key], t);
  return result;
}

function lerpObject(a, b, t) {
  var result = {}, keys = {}, k;
  for (k in a) keys[k] = true;
  for (k in b) keys[k] = true;
  for (k in keys) result[k] = lerp(a[k] || 0, b[k] || 0, t);
  return result;
}

// ============================================================
// 6. Scenario data
// ============================================================
var standing = {
  name: 'Standing', nameJP: '立位',
  keyframes: [
    {
      t: 0.0, label: 'Unorganized', description: 'Mess, unaligned, unable to absorb or generate force',
