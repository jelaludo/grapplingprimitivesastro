// ============================================================
// 7. Panel renderers
// ============================================================

// --- Panel 1: Tension Economy Heatmap ---
var REGION_RADIUS = { head:22, neck:16, shoulderR:28, shoulderL:28, armR:20, armL:20, upperBack:24, core:30, hipR:26, hipL:26, legR:22, legL:22 };

function renderTensionHeatmap(ctx, state, w, h) {
  clearPanel(ctx, w, h);
  drawPanelTitle(ctx, 'Tension Economy', '無駄を省く', w, h, 'tl');
  var positions = scalePositions(state.positions, w, h);

  for (var region in REGIONS) {
    var tension = state.tension[region] || 0;
    var radius = REGION_RADIUS[region] || 20;
    var nodeNames = REGIONS[region];
    for (var n = 0; n < nodeNames.length; n++) {
      var pos = positions[nodeNames[n]];
      if (!pos) continue;
      var r = radius + tension * 15;
      var grad = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, r);
      grad.addColorStop(0, heatColorAlpha(tension, 0.5 + tension * 0.3));
      grad.addColorStop(0.6, heatColorAlpha(tension, 0.2 * tension));
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.beginPath();
      ctx.arc(pos.x, pos.y, r, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();
    }
  }
  drawMannequin(ctx, positions, { boneColor: COLORS.bone + '90', nodeRadius: 2.5 });
}

// --- Panel 2: Internal Connection Lines ---
// Scale factor: 1.0 at 400px panel width, smaller on narrow panels
function panelScale(w) { return Math.min(w / 400, 1); }

function renderConnectionLines(ctx, state, w, h, time) {
  clearPanel(ctx, w, h);
  drawPanelTitle(ctx, 'Internal Connections', '體の統一', w, h, 'tr');
  var positions = scalePositions(state.positions, w, h);
  var sc = panelScale(w);

  drawMannequin(ctx, positions, { boneColor: COLORS.boneDim + '60', nodeColor: COLORS.node + '40', nodeRadius: 2 * sc });

  var corePos = positions.core;
  if (!corePos) return;

  // Arch
  var archStrength = state.connections['arch'] || 0;
  if (archStrength > 0.02) drawArch(ctx, positions, archStrength, time, sc);

  // Spine
  var spineStrength = state.connections['spine'] || 0;
  if (spineStrength > 0.02) drawSpine(ctx, positions, spineStrength, time, sc);

  // Pairwise connections
  for (var p = 0; p < CONNECTION_PAIRS.length; p++) {
    var pair = CONNECTION_PAIRS[p];
    var fromPos = positions[pair.from];
    var toPos = positions[pair.to];
    if (!fromPos || !toPos) continue;
    var key = pair.from + '-' + pair.to;
    var strength = state.connections[key] || 0;
    if (strength < 0.02) continue;

    var cpx = corePos.x + (fromPos.x + toPos.x - 2 * corePos.x) * 0.3;
    var cpy = corePos.y + (fromPos.y + toPos.y - 2 * corePos.y) * 0.3;
    var pulse = strength > 0.5 ? 1 + 0.15 * Math.sin(time * 3 + strength * 10) : 1;
    var alpha = strength * 0.8 * pulse;
    var width = (1 + strength * 3) * sc;

    if (strength > 0.3) {
      ctx.beginPath();
      ctx.moveTo(fromPos.x, fromPos.y);
      ctx.quadraticCurveTo(cpx, cpy, toPos.x, toPos.y);
      ctx.strokeStyle = COLORS.connectionGlow + Math.round(alpha * 0.3 * 255).toString(16).padStart(2, '0');
      ctx.lineWidth = width + 4 * sc;
      ctx.stroke();
    }

    ctx.beginPath();
    ctx.moveTo(fromPos.x, fromPos.y);
    ctx.quadraticCurveTo(cpx, cpy, toPos.x, toPos.y);
    ctx.strokeStyle = COLORS.connectionGlow + Math.round(alpha * 255).toString(16).padStart(2, '0');
    ctx.lineWidth = width;
    ctx.stroke();

    var dotR = (3 + strength * 2) * sc;
    var dotAlpha = Math.round(strength * 200).toString(16).padStart(2, '0');
    ctx.beginPath();
    ctx.arc(fromPos.x, fromPos.y, dotR, 0, Math.PI * 2);
    ctx.fillStyle = COLORS.connectionGlow + dotAlpha;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(toPos.x, toPos.y, dotR, 0, Math.PI * 2);
    ctx.fillStyle = COLORS.connectionGlow + dotAlpha;
    ctx.fill();
  }
}

function drawSmoothCurve(ctx, pts) {
  if (pts.length < 2) return;
  ctx.moveTo(pts[0].x, pts[0].y);
  if (pts.length === 2) { ctx.lineTo(pts[1].x, pts[1].y); return; }
  var mid01x = (pts[0].x + pts[1].x) / 2;
  var mid01y = (pts[0].y + pts[1].y) / 2;
  ctx.quadraticCurveTo(pts[0].x, pts[0].y, mid01x, mid01y);
  for (var i = 1; i < pts.length - 1; i++) {
    var midx = (pts[i].x + pts[i + 1].x) / 2;
    var midy = (pts[i].y + pts[i + 1].y) / 2;
    ctx.quadraticCurveTo(pts[i].x, pts[i].y, midx, midy);
  }
  ctx.lineTo(pts[pts.length - 1].x, pts[pts.length - 1].y);
}

function drawSpine(ctx, positions, strength, time, sc) {
  sc = sc || 1;
  var pts = SPINE_PATH.map(function(name) { return positions[name]; }).filter(Boolean);
  if (pts.length < 2) return;
  var pulse = strength > 0.5 ? 1 + 0.1 * Math.sin(time * 2) : 1;
  var alpha = strength * 0.85 * pulse;
  var width = (1.5 + strength * 3) * sc;
  var color = '#fdcb6e';

  if (strength > 0.3) {
    ctx.beginPath();
    drawSmoothCurve(ctx, pts);
    ctx.strokeStyle = color + Math.round(alpha * 0.25 * 255).toString(16).padStart(2, '0');
    ctx.lineWidth = width + 6 * sc;
    ctx.lineCap = 'round';
    ctx.stroke();
  }

  ctx.beginPath();
  drawSmoothCurve(ctx, pts);
  ctx.strokeStyle = color + Math.round(alpha * 255).toString(16).padStart(2, '0');
  ctx.lineWidth = width;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  ctx.stroke();

  var dotAlpha = Math.round(strength * 220).toString(16).padStart(2, '0');
  for (var j = 0; j < pts.length; j++) {
    ctx.beginPath();
    ctx.arc(pts[j].x, pts[j].y, (3 + strength * 2) * sc, 0, Math.PI * 2);
    ctx.fillStyle = color + dotAlpha;
    ctx.fill();
  }

  if (strength > 0.4) {
    var midPt = pts[Math.floor(pts.length / 2)];
    ctx.font = Math.round(13 * sc) + "px 'Courier New', Consolas, monospace";
    ctx.fillStyle = color + Math.round(alpha * 200).toString(16).padStart(2, '0');
    ctx.textAlign = 'center';
    ctx.fillText('spine', midPt.x + 24 * sc, midPt.y);
  }
}

function drawArch(ctx, positions, strength, time, sc) {
  sc = sc || 1;
  var pts = ARCH_PATH.map(function(name) { return positions[name]; }).filter(Boolean);
  if (pts.length < 4) return;
  var pulse = strength > 0.5 ? 1 + 0.1 * Math.sin(time * 2.5) : 1;
  var alpha = strength * 0.85 * pulse;
  var width = (1.5 + strength * 3) * sc;

  var archPts = pts.map(function(p, i) {
    if (i === 2 || i === 3) return { x: p.x, y: p.y - strength * 12 * sc };
    return p;
  });

  if (strength > 0.3) {
    ctx.beginPath();
    drawSmoothCurve(ctx, archPts);
    ctx.strokeStyle = '#e056fd' + Math.round(alpha * 0.25 * 255).toString(16).padStart(2, '0');
    ctx.lineWidth = width + 6 * sc;
    ctx.stroke();
  }

  ctx.beginPath();
  drawSmoothCurve(ctx, archPts);
  ctx.strokeStyle = '#e056fd' + Math.round(alpha * 255).toString(16).padStart(2, '0');
  ctx.lineWidth = width;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  ctx.stroke();

  var dotAlpha = Math.round(strength * 220).toString(16).padStart(2, '0');
  for (var j = 0; j < pts.length; j++) {
    ctx.beginPath();
    ctx.arc(pts[j].x, pts[j].y, (3 + strength * 2.5) * sc, 0, Math.PI * 2);
    ctx.fillStyle = '#e056fd' + dotAlpha;
    ctx.fill();
  }

  if (strength > 0.4) {
    var midX = (archPts[2].x + archPts[3].x) / 2;
    var midY = (archPts[2].y + archPts[3].y) / 2 - 14 * sc;
    ctx.font = Math.round(13 * sc) + "px 'Courier New', Consolas, monospace";
    ctx.fillStyle = '#e056fd' + Math.round(alpha * 200).toString(16).padStart(2, '0');
    ctx.textAlign = 'center';
    ctx.fillText('arch', midX, midY);
  }
}

// --- Panel 3: Force Flow ---
function renderForceFlow(ctx, state, w, h, time) {
  clearPanel(ctx, w, h);
  drawPanelTitle(ctx, 'Ground Path / Force Flow', '地面への道', w, h, 'bl');
  var positions = scalePositions(state.positions, w, h);

  drawMannequin(ctx, positions, { boneColor: COLORS.boneDim + '50', nodeColor: COLORS.node + '30', nodeRadius: 2 });

  var efficiency = state.forceEfficiency;
  var accum = state.forceAccumulation;
  var shoulderR = positions.shoulderR;
  if (!shoulderR) return;

  var pushStart = { x: shoulderR.x + 50, y: shoulderR.y - 10 };
  drawArrow(ctx, pushStart, shoulderR, COLORS.forceArrow, 2.5, 10);

  for (var i = 0; i < FORCE_PATH.length - 1; i++) {
    var fromName = FORCE_PATH[i];
    var toName = FORCE_PATH[i + 1];
    var fromPos = positions[fromName];
    var toPos = positions[toName];
    if (!fromPos || !toPos) continue;

    var fromAccum = accum[fromName] || 0;
    var toAccum = accum[toName] || 0;
    var segFlow = (fromAccum + toAccum) / 2;

    var flowColor = segFlow > 0.1
      ? lerpColor(COLORS.forceBlocked, COLORS.forceFlowing, efficiency)
      : COLORS.boneDim + '40';

    var dashOffset = time * 60 * efficiency;
    ctx.beginPath();
    ctx.setLineDash([6, 4]);
    ctx.lineDashOffset = -dashOffset;
    ctx.moveTo(fromPos.x, fromPos.y);
    ctx.lineTo(toPos.x, toPos.y);
    ctx.strokeStyle = flowColor;
    ctx.lineWidth = 1.5 + segFlow * 2.5;
    ctx.stroke();
    ctx.setLineDash([]);

    if (fromAccum > 0.2) {
      var blocked = fromAccum * (1 - efficiency);
      if (blocked > 0.1) {
        var grad = ctx.createRadialGradient(fromPos.x, fromPos.y, 0, fromPos.x, fromPos.y, 12 + blocked * 15);
        grad.addColorStop(0, 'rgba(214,48,49,' + (blocked * 0.5) + ')');
        grad.addColorStop(1, 'rgba(214,48,49,0)');
        ctx.beginPath();
        ctx.arc(fromPos.x, fromPos.y, 12 + blocked * 15, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }
    }
  }

  var lastNode = FORCE_PATH[FORCE_PATH.length - 1];
  var lastPos = positions[lastNode];
  if (lastPos) {
    var groundFlow = accum[lastNode] || 0;
    if (groundFlow > 0.1) {
      var groundPt = { x: lastPos.x, y: lastPos.y + 20 };
      drawArrow(ctx, lastPos, groundPt, COLORS.forceFlowing + Math.round(groundFlow * 200).toString(16).padStart(2, '0'), 2, 8);
      ctx.beginPath();
      ctx.moveTo(lastPos.x - 20, groundPt.y + 4);
      ctx.lineTo(lastPos.x + 20, groundPt.y + 4);
      ctx.strokeStyle = COLORS.forceFlowing + '60';
      ctx.lineWidth = 2;
      ctx.stroke();
    }
  }
}

function lerpColor(hexA, hexB, t) {
  var a = hexToRgb(hexA), b = hexToRgb(hexB);
  return 'rgb(' + Math.round(lerp(a[0], b[0], t)) + ',' + Math.round(lerp(a[1], b[1], t)) + ',' + Math.round(lerp(a[2], b[2], t)) + ')';
}

function hexToRgb(hex) {
  hex = hex.replace('#', '');
  return [parseInt(hex.substring(0,2),16), parseInt(hex.substring(2,4),16), parseInt(hex.substring(4,6),16)];
}

// --- Panel 4: Stacking Alignment ---
var LANDMARK_LABELS = ['Ear', 'Shoulder', 'Hip', 'Ankle'];

function renderStacking(ctx, state, w, h) {
  clearPanel(ctx, w, h);
  drawPanelTitle(ctx, 'Stacking', '部位の整列', w, h, 'br');
  var positions = scalePositions(state.positions, w, h);

  var ankleMid = positions.ankleMid;
  if (!ankleMid) return;

  drawDashedLine(ctx, { x: ankleMid.x, y: 55 }, { x: ankleMid.x, y: h - 10 }, COLORS.plumbLine, 1, [6, 4]);

  var landmarkPositions = LANDMARKS.map(function(name) { return positions[name]; });

  for (var i = 0; i < landmarkPositions.length; i++) {
    var pos = landmarkPositions[i];
    if (!pos) continue;
    var deviation = Math.abs(pos.x - ankleMid.x);
    var maxDeviation = w * 0.15;
    var normalizedDev = Math.min(deviation / maxDeviation, 1);

    var r = Math.round(lerp(85, 225, normalizedDev));
    var g = Math.round(lerp(239, 112, normalizedDev));
    var b = Math.round(lerp(196, 85, normalizedDev));
    var color = 'rgb(' + r + ',' + g + ',' + b + ')';

    if (normalizedDev > 0.05) {
      drawLine(ctx, pos, { x: ankleMid.x, y: pos.y }, color + '60', 1);
    }
    drawCircle(ctx, pos, 6 + normalizedDev * 4, color);
    drawLabel(ctx, LANDMARK_LABELS[i], pos.x + (pos.x > w / 2 ? 30 : -30), pos.y + 4, Math.max(14, Math.round(14 * sc)), COLORS.textDim);
  }

  var totalDev = 0;
  for (var j = 0; j < landmarkPositions.length; j++) {
    if (landmarkPositions[j]) totalDev += Math.abs(landmarkPositions[j].x - ankleMid.x);
  }
  var maxTotal = w * 0.15 * 4;
  var alignScore = Math.round((1 - Math.min(totalDev / maxTotal, 1)) * 100);
  drawLabel(ctx, alignScore + '%', w / 2, h - 8, 12, COLORS.textDim);
}

// ============================================================
// 8. Main bootstrap
// ============================================================
var scenario = standing;

var slider = document.getElementById('slider');
var sliderLabel = document.getElementById('slider-label');
var stepsContainer = document.getElementById('steps');
var scenarioSelect = document.getElementById('scenario-select');
var autoplayBtn = document.getElementById('autoplay-btn');
var playIcon = autoplayBtn.querySelector('.play-icon');
var tooltipEl = document.getElementById('tooltip');
var canvases = [
  document.getElementById('canvas-tension'),
  document.getElementById('canvas-connections'),
  document.getElementById('canvas-force'),
  document.getElementById('canvas-stacking'),
];
var ctxs = canvases.map(function(c) { return c.getContext('2d'); });

var srPanels = {
  tension: document.getElementById('sr-tension'),
  connections: document.getElementById('sr-connections'),
  force: document.getElementById('sr-force'),
  stacking: document.getElementById('sr-stacking'),
};

var panels = [
  { render: renderTensionHeatmap, usesTime: false },
  { render: renderConnectionLines, usesTime: true },
  { render: renderForceFlow, usesTime: true },
  { render: renderStacking, usesTime: false },
];

// --- Sizing ---
function resize() {
  canvases.forEach(function(canvas, i) {
    var rect = canvas.parentElement.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctxs[i].setTransform(dpr, 0, 0, dpr, 0, 0);
    canvas.logicalWidth = rect.width;
    canvas.logicalHeight = rect.height;
  });
}

// --- Step buttons ---
var STEP_COLORS = ['#e53935','#ef6a5a','#fb8c00','#fdd835','#66bb6a','#a5d6a7'];
var stepBtns = [];

function buildSteps() {
  stepsContainer.innerHTML = '';
  stepBtns = [];
  for (var i = 0; i < scenario.keyframes.length; i++) {
    var kf = scenario.keyframes[i];
    (function(kf) {
      var btn = document.createElement('button');
      btn.className = 'step-btn';
      btn.textContent = kf.label;
      btn.title = kf.description;
      btn.setAttribute('aria-label', kf.label + ': ' + kf.description);
      btn.addEventListener('click', function() {
        setAutoplayState(false);
        animateSliderTo(kf.t);
      });
      stepsContainer.appendChild(btn);
      stepBtns.push(btn);
    })(kf);
  }
}

// --- Scenario selector ---
scenarioSelect.addEventListener('change', function() {
  var key = scenarioSelect.value;
  if (scenarios[key]) {
    scenario = scenarios[key];
    slider.value = 0;
    setAutoplayState(false);
    buildSteps();
  }
});

// --- Smooth slider animation ---
var animTarget = null;
var animStart = null;
var animFrom = null;
var ANIM_DURATION = 600;

function animateSliderTo(target) {
  animTarget = target;
  animStart = performance.now();
  animFrom = parseFloat(slider.value);
}

function updateAnimatedSlider(now) {
  if (animTarget === null) return;
  var elapsed = now - animStart;
  var progress = Math.min(elapsed / ANIM_DURATION, 1);
  slider.value = lerp(animFrom, animTarget, easeInOut(progress));
  if (progress >= 1) animTarget = null;
}

// --- Auto-play ---
var autoplayActive = true;
var userPaused = false;
var AUTOPLAY_SPEED = 0.08;
var LOOP_PAUSE_MS = 3000;
var lastAutoplayTime = 0;
var loopPauseUntil = 0;
var autoplayValue = 0;

function setAutoplayState(playing) {
  if (autoplayActive === playing) return;
  autoplayActive = playing;
  autoplayBtn.classList.toggle('playing', playing);
  playIcon.textContent = playing ? '⏸' : '▶';
  autoplayBtn.setAttribute('aria-label', playing ? 'Pause auto-advance' : 'Play auto-advance');
  if (playing) {
    lastAutoplayTime = performance.now();
    autoplayValue = parseFloat(slider.value);
  }
}

autoplayBtn.addEventListener('click', function() {
  userPaused = autoplayActive;
  loopPauseUntil = 0;
  if (!autoplayActive && parseFloat(slider.value) >= 1) slider.value = 0;
  setAutoplayState(!autoplayActive);
});

slider.addEventListener('input', function() {
  userPaused = true;
  loopPauseUntil = 0;
  setAutoplayState(false);
  animTarget = null;
});

function updateAutoplay(now) {
  if (loopPauseUntil > 0) {
    if (now >= loopPauseUntil) {
      loopPauseUntil = 0;
      autoplayValue = 0;
      slider.value = 0;
      lastAutoplayTime = now;
      setAutoplayState(true);
    }
    return;
  }
  if (!autoplayActive) return;
  if (lastAutoplayTime === 0) lastAutoplayTime = now;
  var dt = Math.min((now - lastAutoplayTime) / 1000, 0.1);
  lastAutoplayTime = now;
  autoplayValue += AUTOPLAY_SPEED * dt;
  if (autoplayValue >= 1) {
    autoplayValue = 1;
    slider.value = 1;
    setAutoplayState(false);
    if (!userPaused) loopPauseUntil = now + LOOP_PAUSE_MS;
    return;
  }
  slider.value = autoplayValue;
}

// --- Tooltips ---
var PANEL_TOOLTIPS = [
  { title: 'Tension Economy 無駄を省く', body: 'Heat shows parasitic (wasted) tension. Cool blue = efficient. Hot red = energy leak. As you self-organize, tension migrates from extremities into the core.' },
  { title: 'Internal Connections 體の統一', body: 'Cyan arcs show kinetic chains linking distant body parts through the core. The purple arch connects feet through hips. Stronger connections = unified structure.' },
  { title: 'Ground Path / Force Flow 地面への道', body: 'Animated dashes show how an external push at the shoulder travels to the ground. Red pooling = force is stuck. Green flow = force reaches the earth.' },
  { title: 'Stacking 部位の整列', body: 'Dots show four landmarks (ear, shoulder, hip, ankle) relative to a plumb line. Green = aligned over ankles. Orange = off-axis. Percentage shows overall alignment.' },
];

var activeTooltipIndex = -1;

function showTooltip(x, y, index) {
  if (activeTooltipIndex !== index) {
    activeTooltipIndex = index;
    var content = PANEL_TOOLTIPS[index];
    tooltipEl.textContent = '';
    var strong = document.createElement('strong');
    strong.textContent = content.title;
    tooltipEl.appendChild(strong);
    tooltipEl.appendChild(document.createElement('br'));
    tooltipEl.appendChild(document.createTextNode(content.body));
    tooltipEl.classList.add('visible');
    tooltipEl.setAttribute('aria-hidden', 'false');
  }
  var pad = 12;
  var left = x + pad;
  var top = y + pad;
  if (left + 240 > window.innerWidth) left = x - 240 - pad;
  if (top + 160 > window.innerHeight) top = y - 160 - pad;
  tooltipEl.style.left = left + 'px';
  tooltipEl.style.top = top + 'px';
}

function hideTooltip() {
  activeTooltipIndex = -1;
  tooltipEl.classList.remove('visible');
  tooltipEl.setAttribute('aria-hidden', 'true');
}

canvases.forEach(function(canvas, i) {
  canvas.addEventListener('pointerenter', function(e) { showTooltip(e.clientX, e.clientY, i); });
  canvas.addEventListener('pointermove', function(e) { showTooltip(e.clientX, e.clientY, i); });
  canvas.addEventListener('pointerleave', hideTooltip);
});

// --- Accessibility: screen reader descriptions ---
var lastSrLabel = '';

function updateScreenReaderDescriptions(state) {
  if (state.label === lastSrLabel) return;
  lastSrLabel = state.label;

  var topTension = Object.entries(state.tension)
    .sort(function(a, b) { return b[1] - a[1]; })
    .slice(0, 2)
    .map(function(e) { return e[0] + ' ' + Math.round(e[1] * 100) + '%'; })
    .join(', ');
  srPanels.tension.textContent = state.label + ': highest tension in ' + topTension;

  var activeConns = Object.entries(state.connections)
    .filter(function(e) { return e[1] > 0.3; })
    .map(function(e) { return e[0]; })
    .join(', ');
  srPanels.connections.textContent = state.label + ': active connections: ' + (activeConns || 'none');
  srPanels.force.textContent = state.label + ': force efficiency ' + Math.round(state.forceEfficiency * 100) + '%';
  srPanels.stacking.textContent = state.label + ': ' + state.description;
}

// --- Keyboard support ---
document.addEventListener('keydown', function(e) {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
  if (!aboutModal.classList.contains('hidden')) return;

  if (e.key === ' ' || e.key === 'Spacebar') {
    e.preventDefault();
    setAutoplayState(!autoplayActive);
  } else if (e.key === 'ArrowRight') {
    e.preventDefault();
    setAutoplayState(false);
    slider.value = clamp(parseFloat(slider.value) + 0.02, 0, 1);
  } else if (e.key === 'ArrowLeft') {
    e.preventDefault();
    setAutoplayState(false);
    slider.value = clamp(parseFloat(slider.value) - 0.02, 0, 1);
  } else if (e.key >= '1' && e.key <= '9') {
    var idx = parseInt(e.key) - 1;
    if (idx < scenario.keyframes.length) {
      setAutoplayState(false);
      animateSliderTo(scenario.keyframes[idx].t);
    }
  }
});

// --- Deep link ---
var deeplinkBtn = document.getElementById('btn-deeplink');
deeplinkBtn.addEventListener('click', function() {
  var url = window.location.origin + window.location.pathname;
  navigator.clipboard.writeText(url).then(function() {
    deeplinkBtn.textContent = 'Copied!';
    deeplinkBtn.style.color = '#00d4ff';
    deeplinkBtn.style.borderColor = '#00d4ff';
    setTimeout(function() {
      deeplinkBtn.textContent = 'Link';
      deeplinkBtn.style.color = '';
      deeplinkBtn.style.borderColor = '';
    }, 1500);
  });
});

// --- About modal ---
var titleLink = document.getElementById('title-link');
var headerTitleLink = document.getElementById('header-title-link');
var aboutModal = document.getElementById('about-modal');
var modalClose = document.getElementById('modal-close');

function openAboutModal(e) {
  e.preventDefault();
  aboutModal.classList.remove('hidden');
  aboutModal.style.display = 'flex';
  modalClose.focus();
}

function closeAboutModal() {
  aboutModal.classList.add('hidden');
  aboutModal.style.display = 'none';
}

titleLink.addEventListener('click', openAboutModal);
headerTitleLink.addEventListener('click', openAboutModal);
modalClose.addEventListener('click', closeAboutModal);
aboutModal.addEventListener('click', function(e) { if (e.target === aboutModal) closeAboutModal(); });

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && !aboutModal.classList.contains('hidden')) {
    closeAboutModal();
  }
});

// --- Render loop ---
var startTime = performance.now();
var lastT = -1;
var lastLabelText = '';
var _lastState = null;

function render(now) {
  var time = (now - startTime) / 1000;

  updateAnimatedSlider(now);
  updateAutoplay(now);

  var t = parseFloat(slider.value);
  var tChanged = t !== lastT;
  lastT = t;

  var state = tChanged ? computeState(scenario, t) : _lastState;
  _lastState = state;

  if (tChanged) {
    slider.setAttribute('aria-valuenow', t.toFixed(2));
    var labelText = state.label + ' — ' + state.description;
    if (labelText !== lastLabelText) {
      lastLabelText = labelText;
      sliderLabel.textContent = labelText;
    }

    for (var i = 0; i < stepBtns.length; i++) {
      var kfT = scenario.keyframes[i].t;
      var passed = t >= kfT - 0.01;
      var current = Math.abs(t - kfT) < 0.01;
      var lit = passed || current;
      var c = STEP_COLORS[i] || STEP_COLORS[STEP_COLORS.length - 1];
      stepBtns[i].classList.toggle('lit', lit);
      stepBtns[i].classList.toggle('active', current);
      stepBtns[i].style.borderColor = lit ? c : '';
      stepBtns[i].style.color = lit ? c : '';
      stepBtns[i].style.background = lit ? c + '18' : '';
      stepBtns[i].setAttribute('aria-pressed', lit);
    }

    updateScreenReaderDescriptions(state);
  }

  for (var j = 0; j < panels.length; j++) {
    var w = canvases[j].logicalWidth;
    var h = canvases[j].logicalHeight;
    if (panels[j].usesTime || tChanged) {
      if (panels[j].usesTime) {
        panels[j].render(ctxs[j], state, w, h, time);
      } else {
        panels[j].render(ctxs[j], state, w, h);
      }
    }
  }

  requestAnimationFrame(render);
}

// --- Init ---
window.addEventListener('resize', resize);
resize();
buildSteps();
requestAnimationFrame(render);

})();
</script>

</BaseLayout>
