---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ModuleCard from '@/components/ui/ModuleCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allConcepts = await getCollection('concepts');
const allCategories = await getCollection('categories');
const conceptCount = allConcepts.length;
const categoryCount = allCategories.length;

const thumbBase = `${base}/images/thumbs`;

const coreSections = [
  {
    id: 'core',
    label: '',
    featured: true,
    modules: [
      {
        title: 'Ideal Training Partner',
        description: 'An interactive essay on training intensity, mismatch danger, and ego drift. With watercolor illustrations.',
        href: `${base}/modules/ideal-partner`,
        status: 'live' as const,
        tag: 'INTERACTIVE ESSAY',
        thumb: `${thumbBase}/ideal-partner.webp`,
      },
      {
        title: 'QuadTree Map',
        description: `${conceptCount} concepts across ${categoryCount} categories. THE MAT · THE MIND · THE DOJO · THE PATH. Click to zoom into any category.`,
        href: `${base}/modules/quadtree`,
        status: 'live' as const,
        tag: 'CONCEPT MAP',
        thumb: `${thumbBase}/quadtree.webp`,
      },
      {
        title: 'Build Yourself First',
        description: '自分を作れ — Tsukuri is upstream of everything. An interactive essay on building your game before breaking theirs.',
        href: `${base}/modules/jibunwotsukure`,
        status: 'live' as const,
        tag: 'INTERACTIVE ESSAY',
        thumb: `${thumbBase}/build-yourself.webp`,
      },
    ],
  },
];

const purgatorySections = [
  {
    id: 'learn',
    label: 'LEARN',
    modules: [
      {
        title: 'Articles',
        description: 'Long-form writings on grappling concepts, heuristics, training philosophy, and more. Sourced from the Obsidian vault.',
        href: `${base}/modules/articles`,
        status: 'live' as const,
        tag: 'ARTICLES',
        thumb: `${thumbBase}/articles.webp`,
      },
    ],
  },
  {
    id: 'tools',
    label: 'TOOLS',
    modules: [
      {
        title: 'Skill Assessment',
        description: 'Rate your confidence across 15 grappling areas — short (30q) or full (173q). Results as a bar chart.',
        href: `${base}/modules/skill-check`,
        status: 'live' as const,
        tag: 'TOOLS',
        thumb: `${thumbBase}/skill-check.webp`,
      },
      {
        title: 'Weight Classes',
        description: 'Find your division across IBJJF (Gi & No-Gi), ADCC, and WNO. Includes kg/lbs conversion and gi size calculator.',
        href: `${base}/modules/weight-class`,
        status: 'live' as const,
        tag: 'TOOLS',
        thumb: `${thumbBase}/weight-class.webp`,
      },
      {
        title: 'BJJ Pricing',
        description: 'Monthly memberships and seminar fees worldwide — interactive maps, box plots, and currency conversion across US, UK, EU, Brazil, and Japan.',
        href: `${base}/modules/pricing`,
        status: 'live' as const,
        tag: 'DATA',
        thumb: `${thumbBase}/pricing.webp`,
      },
    ],
  },
  {
    id: 'play',
    label: 'PLAY',
    modules: [
      {
        title: 'Games Hub',
        description: 'Mini-games: memory match, centroid estimation, and more.',
        href: `${base}/modules/games`,
        status: 'live' as const,
        tag: 'GAMES',
        thumb: `${thumbBase}/games.webp`,
      },
    ],
  },
  {
    id: 'explore',
    label: 'EXPLORE',
    modules: [
      {
        title: 'Training Partners',
        description: 'Map the 10 archetypal training partners — from The Mentor to The Liability. Self-assess and find your closest match.',
        href: `${base}/modules/training-partner`,
        status: 'live' as const,
        tag: 'TOOLS',
        thumb: `${thumbBase}/training-partner.webp`,
      },
      {
        title: 'Flash Cards',
        description: `Study and review all ${conceptCount} concepts with Anki-style flash cards. Filter by category, flip, stage for later.`,
        href: `${base}/modules/cards`,
        status: 'wip' as const,
        tag: 'STUDY',
        thumb: `${thumbBase}/cards.webp`,
      },
    ],
  },
  {
    id: 'coming-soon',
    label: 'COMING SOON',
    modules: [
      {
        title: 'GIF Training',
        description: '10+ years of technique GIFs as dynamic visual reminders.',
        href: `${base}/modules/gif-training`,
        status: 'soon' as const,
        tag: 'MEDIA',
      },
      {
        title: 'Breathing Cycles',
        description: 'Guided breathing exercises for pre/post training recovery.',
        href: `${base}/modules/breathing`,
        status: 'soon' as const,
        tag: 'TOOLS',
      },
    ],
  },
];
---

<BaseLayout title="Grappling Primitives">
  <div class="max-w-5xl mx-auto px-4 py-12">

    <!-- Header -->
    <div class="mb-16 fade-up max-w-2xl">
      {import.meta.env.DEV && (
        <div class="text-[9px] tracking-[3px] text-yellow-500 bg-yellow-500/10 border border-yellow-500/30 px-3 py-1 mb-4 font-mono uppercase inline-block">
          DEV MODE
        </div>
      )}
      <h1 class="text-3xl font-bold tracking-tight text-text-primary mb-4 glow-blue">
        Grappling <span id="cycling-word" style="position:relative;display:inline;">Primitives</span><span id="cursor-blink" style="color:#00ff41;font-weight:400;animation:blink-cursor 0.8s step-end infinite;">|</span>
      </h1>
      <p class="text-sm text-text-muted leading-relaxed mb-4 italic">If you could tell your white belt self three things...</p>
      <ol class="text-sm text-text-muted leading-relaxed list-decimal list-inside space-y-2 mb-4">
        <li><span class="text-accent font-semibold">"Build Yourself"</span> is upstream of everything, paramount. It comes before focus on Kuzushi of the other in so many ways.</li>
        <li><span class="text-accent font-semibold">"Be the training partner you wish you had"</span>. Not all training is equal, great training partners are rare. Being a good training partner is itself a trainable skill.</li>
        <li><span class="text-accent font-semibold">"Concepts &gt; Techniques"</span>. Engrave concepts into your brain, rather than just collecting techniques.</li>
      </ol>
      <p class="text-sm text-text-muted leading-relaxed mb-4">
        I am organizing decades of notes, including <span class="text-accent font-semibold">{conceptCount}</span> concepts organized in <span class="text-accent font-semibold">{categoryCount}</span> categories in a <a href={`${base}/modules/quadtree`} class="text-accent underline hover:text-cyan transition-colors">quad tree map</a>, and interactive essays that represent how I would typically introduce these concepts live to new students. Although so much of what we do is highly kinetic and has a "it-has-to-be-felt" quality that is difficult to convey digitally. Doesn't mean we cannot try.
      </p>
      <p class="text-sm text-text-muted leading-relaxed">
        Start by reading the essays, <a href={`${base}/modules/jibunwotsukure`} class="text-accent underline hover:text-cyan transition-colors">Build Yourself First</a> and <a href={`${base}/modules/ideal-partner`} class="text-accent underline hover:text-cyan transition-colors">Ideal Training Partner</a>, or take this <a href={`${base}/modules/skill-check`} class="text-accent underline hover:text-cyan transition-colors">self-assessment</a>, then explore the <a href={`${base}/modules/quadtree`} class="text-accent underline hover:text-cyan transition-colors">map</a>.
      </p>
    </div>

    <!-- WIP badge -->
    <div class="flex items-center gap-3 mb-6">
      <span class="text-[10px] tracking-[3px] text-[#00ff41] uppercase font-mono flex-shrink-0" style="text-shadow:0 0 12px rgba(0,255,65,0.4);">Work-in-Progress</span>
      <div class="flex-1 h-px bg-[#00ff41]/20" />
    </div>

    <!-- Core modules -->
    {coreSections.map((section) => (
      <section class="mb-16">
        {section.label && (
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] tracking-[4px] text-text-dim uppercase font-mono flex-shrink-0">{section.label}</span>
            <div class="flex-1 h-px bg-border" />
          </div>
        )}
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {section.modules.map((m) => (
            <ModuleCard {...m} featured={section.featured || false} />
          ))}
        </div>
      </section>
    ))}

    <!-- Purgatory: dev-only modules -->
    {import.meta.env.DEV && (
      <div class="mt-20 pt-8 border-t border-yellow-500/20">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-[10px] tracking-[3px] text-yellow-500/70 uppercase font-mono flex-shrink-0">
            PURGATORY — dev only
          </span>
          <div class="flex-1 h-px bg-yellow-500/20" />
        </div>

        {purgatorySections.map((section) => (
          <section class="mb-10 opacity-70">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[10px] tracking-[4px] text-text-dim uppercase font-mono flex-shrink-0">{section.label}</span>
              <div class="flex-1 h-px bg-border" />
            </div>
            <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
              {section.modules.map((m) => (
                <ModuleCard {...m} />
              ))}
            </div>
          </section>
        ))}
      </div>
    )}

  </div>

  <!-- Retro Terminal Overlay -->
  <div id="retro-terminal" style="position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.88);display:flex;align-items:center;justify-content:center;cursor:pointer;font-family:'Courier New',Consolas,Monaco,monospace;transition:opacity 0.6s ease;">
    <div style="width:min(600px,90vw);text-align:left;padding:2rem;">
      <div id="rt-prompt" style="color:#fff;font-size:clamp(12px,2.5vw,16px);white-space:nowrap;margin-bottom:0.5em;">root@grapplingprimitives:~$</div>
      <div id="rt-en" style="color:#00ff41;font-size:clamp(14px,3vw,18px);line-height:1.5;min-height:1.6em;"></div>
      <div id="rt-jp" style="color:#00ff41;font-size:clamp(13px,2.5vw,16px);line-height:1.5;min-height:1.6em;opacity:0.8;margin-top:0.25em;"></div>
      <div id="rt-cursor" style="color:#00ff41;display:inline-block;font-size:clamp(14px,3vw,18px);">|</div>
      <div style="position:fixed;bottom:1.2rem;right:1.5rem;font-size:clamp(9px,1.6vw,11px);letter-spacing:0.18em;color:rgba(255,255,255,0.35);font-style:italic;">click anywhere to continue</div>
    </div>
  </div>

  <style>
    @keyframes rt-blink { 0%,100%{opacity:1} 50%{opacity:0} }
    #rt-cursor { animation: rt-blink 1s step-end infinite; }
    #retro-terminal.rt-gone { opacity:0; pointer-events:none; }
  </style>

  <script>
    (function () {
      const overlay = document.getElementById('retro-terminal');
      if (!overlay) return;
      if (sessionStorage.getItem('gp-splash-dismissed')) { overlay.style.display = 'none'; return; }

      const messages = [
        { en: "All models are wrong, some are useful", jp: "すべてのモデルは間違っているが、いくつかは役に立つ" },
        { en: "Build Yourself", jp: "自分を作れ" },
        { en: "Speak Friend, and Enter", jp: "唱えよ、友、そして入れ" },
        { en: "Flow, Pressure, Finish", jp: "流れ、圧、極め" },
        { en: "Keep Training", jp: "練習を続けろ" },
        { en: "Don't Quit", jp: "諦めるな" },
        { en: "Mindful Practice", jp: "意識しながら練習" },
        { en: "Switch your brain on", jp: "脳をオンにしろ" },
        { en: "Think. Practice. Repeat", jp: "思考。練習。反復。" },
        { en: "Theory is nothing without mat time", jp: "マット時間なければ理論だけは役に立たない" },
        { en: "Read less, roll more", jp: "見学よりも、動こう" },
        { en: "Daily beats Perfect", jp: "完璧より毎日" },
        { en: "Mat Time > Screen Time", jp: "マット時間 > スクリーン時間" },
        { en: "Keep Showing up", jp: "現れ続けろ" },
        { en: "Don't let thinking replace doing", jp: "考えることで行動を置き換えるな" },
        { en: "Breathe, feel, adjust", jp: "呼吸、感覚、調整" },
        { en: "Build those neuromuscular pathways", jp: "神経筋経路を構築せよ" },
        { en: "Etch Grappling Grooves in your brain", jp: "脳にグラップリングの溝を刻め" },
        { en: "Proof of Work on the mats", jp: "マット上でも作業証明" },
        { en: "Take care of your training partners", jp: "練習相手を大切に" },
        { en: "Tsukuri precedes Kuzushi", jp: "崩しより作り" }
      ];

      const elEn = document.getElementById('rt-en');
      const elJp = document.getElementById('rt-jp');
      const TYPING_SPEED = 40;
      const DISPLAY_TIME = 2000;
      let msgIdx = 0;

      function typeMessage() {
        const msg = messages[msgIdx];
        const full = msg.en;
        let i = 0;
        elEn.textContent = '';
        elJp.textContent = '';

        function tick() {
          if (i < full.length) {
            elEn.textContent = full.slice(0, i + 1);
            i++;
            setTimeout(tick, TYPING_SPEED);
          } else {
            // English done, show Japanese immediately below
            elJp.textContent = msg.jp;
            // Wait, then cycle
            setTimeout(() => {
              msgIdx = (msgIdx + 1) % messages.length;
              typeMessage();
            }, DISPLAY_TIME);
          }
        }
        tick();
      }

      typeMessage();

      function dismiss() {
        overlay.classList.add('rt-gone');
        sessionStorage.setItem('gp-splash-dismissed', '1');
        setTimeout(() => { overlay.style.display = 'none'; }, 650);
      }

      overlay.addEventListener('click', dismiss);
      ['keydown', 'scroll', 'wheel'].forEach(evt =>
        window.addEventListener(evt, dismiss, { once: true })
      );
    })();
  </script>

  <!-- Cycling word animation -->
  <style>
    @keyframes blink-cursor { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  </style>
  <script>
    (function() {
      const el = document.getElementById('cycling-word');
      const cursor = document.getElementById('cursor-blink');
      if (!el) return;

      const words = ['Primitives', 'Building Blocks', 'Fundamentals', 'Basic Components'];
      let current = 0;
      let phase = 'idle'; // idle, erasing, pausing, typing
      let charIndex = 0;
      let timer = null;

      function startCycle() {
        // Wait 4s on initial word, then start erasing
        setTimeout(() => {
          phase = 'erasing';
          charIndex = el.textContent.length;
          tick();
        }, 4000);
      }

      function tick() {
        if (phase === 'erasing') {
          charIndex--;
          el.textContent = words[current].substring(0, charIndex);
          if (charIndex <= 0) {
            phase = 'pausing';
            current = (current + 1) % words.length;
            charIndex = 0;
            setTimeout(tick, 300);
          } else {
            timer = setTimeout(tick, 40 + Math.random() * 30);
          }
        } else if (phase === 'pausing') {
          phase = 'typing';
          tick();
        } else if (phase === 'typing') {
          charIndex++;
          el.textContent = words[current].substring(0, charIndex);
          if (charIndex >= words[current].length) {
            phase = 'idle';
            // Wait 3-5s then erase again
            setTimeout(() => {
              phase = 'erasing';
              charIndex = el.textContent.length;
              tick();
            }, 3000 + Math.random() * 2000);
          } else {
            timer = setTimeout(tick, 60 + Math.random() * 50);
          }
        }
      }

      startCycle();
    })();
  </script>

</BaseLayout>
