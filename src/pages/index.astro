---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ModuleCard from '@/components/ui/ModuleCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const modules = [
  {
    title: 'Concept Matrix',
    description: 'All grappling concepts mapped on a 2×2 grid (Self↔Opponent × Mental↔Physical). Hover, click into categories, zoom.',
    href: `${base}/modules/matrix`,
    status: 'live' as const,
    tag: 'INTERACTIVE',
  },
  {
    title: 'QuadTree Map',
    description: '4-quadrant treemap: THE MAT · THE MIND · THE DOJO · THE PATH. Category boxes sized by concept count — click to zoom into any category.',
    href: `${base}/modules/quadtree`,
    status: 'live' as const,
    tag: 'INTERACTIVE',
  },
  {
    title: 'Centroid Game',
    description: 'Estimate the center of mass of a dot cluster. 10 rounds, Chebyshev scoring, timer penalty — lowest score wins.',
    href: `${base}/modules/centroid`,
    status: 'live' as const,
    tag: 'GAMES',
  },
  {
    title: 'Memory Game',
    description: 'Match technique card pairs from the JJJ image set. 8 pairs, 4×4 grid — study the layout, then find all matches.',
    href: `${base}/modules/memory`,
    status: 'live' as const,
    tag: 'GAMES',
  },
  {
    title: 'Flash Cards',
    description: 'Study and review all 277 concepts with Anki-style flash cards. Filter by category, flip, stage for later.',
    href: `${base}/modules/cards`,
    status: 'wip' as const,
    tag: 'STUDY',
  },
  {
    title: 'Skill Assessment',
    description: 'Test your knowledge of grappling concepts with a self-assessment quiz.',
    href: `${base}/modules/skill-check`,
    status: 'soon' as const,
    tag: 'TOOLS',
  },
  {
    title: 'Games Hub',
    description: 'Gamified drills: memory match, centroid estimation, pressure scenarios.',
    href: `${base}/modules/games`,
    status: 'soon' as const,
    tag: 'GAMES',
  },
  {
    title: 'Visual Notes',
    description: 'Hand-drawn diagrams and sketches collected over years of training.',
    href: `${base}/modules/visual-notes`,
    status: 'live' as const,
    tag: 'MEDIA',
  },
  {
    title: 'GIF Training',
    description: '10+ years of technique GIFs as dynamic visual reminders.',
    href: `${base}/modules/gif-training`,
    status: 'soon' as const,
    tag: 'MEDIA',
  },
  {
    title: 'Belt Dropout',
    description: 'Visualize belt progression and dropout statistics in BJJ.',
    href: `${base}/modules/belt-dropout`,
    status: 'live' as const,
    tag: 'DATA',
  },
  {
    title: 'Pressure Game',
    description: 'Steer a ball across a tilting platform toward pressure zones. Timer expires → d20 roll → BJJ technique scenario.',
    href: `${base}/modules/pressure-game`,
    status: 'live' as const,
    tag: 'GAMES',
  },
  {
    title: 'Breathing Cycles',
    description: 'Guided breathing exercises for pre/post training recovery.',
    href: `${base}/modules/breathing`,
    status: 'soon' as const,
    tag: 'TOOLS',
  },
];
---

<BaseLayout title="Grappling Primitives">
  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Header -->
    <div class="mb-12 fade-up">
      <p class="text-[9px] tracking-[4px] text-accent uppercase mb-3">v2.0 — Astro Build</p>
      <h1 class="text-3xl font-bold tracking-tight text-text-primary mb-3 glow-blue">
        Grappling Primitives
      </h1>
      <p class="text-sm text-text-muted max-w-xl leading-relaxed">
        An interactive atlas of grappling concepts — structured, visual, and searchable.
        277 concepts across 23 categories, mapped on a shared framework.
      </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-px bg-border mb-12 fade-up">
      {[
        { n: '277', label: 'Concepts' },
        { n: '23',  label: 'Categories' },
        { n: '2×2', label: 'Framework' },
      ].map(({ n, label }) => (
        <div class="bg-surface px-4 py-3 text-center">
          <div class="text-xl font-bold text-accent">{n}</div>
          <div class="text-[9px] tracking-[2px] text-text-dim uppercase mt-0.5">{label}</div>
        </div>
      ))}
    </div>

    <!-- Module grid -->
    <div class="mb-4">
      <p class="text-[9px] tracking-[3px] text-text-dim uppercase mb-4">Modules</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {modules.map((m) => (
          <ModuleCard {...m} />
        ))}
      </div>
    </div>

  </div>

  <!-- WIP Splash Overlay -->
  <div id="wip-splash" style="position:fixed;inset:0;z-index:9999;background:rgba(5,5,9,0.97);display:flex;align-items:center;justify-content:center;cursor:pointer;font-family:'Courier New',Consolas,Monaco,monospace;transition:opacity 0.6s ease;">
    <div style="text-align:left;padding:2rem;max-width:90vw;">
      <div style="color:#00ff41;font-size:clamp(10px,2vw,13px);letter-spacing:0.18em;line-height:2.2;opacity:0.45;">&gt; GRAPPLING PRIMITIVES — v2.0</div>
      <div style="color:#00ff41;font-size:clamp(10px,2vw,13px);letter-spacing:0.18em;line-height:2.2;opacity:0.45;">&gt; STATUS ─────────────────────────────</div>
      <div style="color:#00ff41;font-size:clamp(28px,7vw,72px);font-weight:700;letter-spacing:0.06em;margin:0.15em 0 0;text-shadow:0 0 24px rgba(0,255,65,0.55),0 0 60px rgba(0,255,65,0.18);">WORK IN PROGRESS</div>
      <div style="color:#00ff41;font-size:clamp(14px,3.5vw,32px);letter-spacing:0.22em;opacity:0.85;margin-bottom:0.1em;">by @Jelaludo</div>
      <div style="color:#00ff41;font-size:clamp(10px,2vw,13px);letter-spacing:0.18em;line-height:2.2;opacity:0.45;">&gt; ─────────────────────────────────────</div>
      <div style="color:#00ff41;font-size:clamp(9px,1.8vw,12px);letter-spacing:0.22em;opacity:0.4;margin-top:1.2em;">[ CLICK ANYWHERE TO ENTER ]<span id="wip-cursor">█</span></div>
    </div>
  </div>

  <style>
    @keyframes wip-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    #wip-cursor { display:inline-block; margin-left:4px; animation: wip-blink 1s step-end infinite; }
    #wip-splash.wip-gone { opacity: 0; pointer-events: none; }
  </style>

  <script>
    (function () {
      const splash = document.getElementById('wip-splash');
      if (!splash) return;
      if (sessionStorage.getItem('gp-wip-dismissed')) { splash.style.display = 'none'; return; }
      splash.addEventListener('click', () => {
        splash.classList.add('wip-gone');
        sessionStorage.setItem('gp-wip-dismissed', '1');
        setTimeout(() => { splash.style.display = 'none'; }, 650);
      });
    })();
  </script>

</BaseLayout>
