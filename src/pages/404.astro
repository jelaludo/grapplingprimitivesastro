---
import BaseLayout from '@/layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="404 — Not Found">
  <div class="max-w-xl mx-auto px-4 py-24 text-center fade-up">
    <p class="text-[10px] tracking-[4px] text-text-dim uppercase mb-6">ERROR 404</p>
    <h1 class="text-4xl font-bold text-text-primary mb-4 glow-blue" style="font-family:'DS-Digital',monospace;">
      404
    </h1>
    <p class="text-sm text-text-muted mb-8 leading-relaxed">
      Position not found. Time to re-guard.
    </p>
    <a href={`${base}/`} class="inline-block text-[10px] tracking-[3px] uppercase border border-accent text-accent px-6 py-2 hover:bg-accent/10 transition-colors">
      Back to Home
    </a>
  </div>
</BaseLayout>
