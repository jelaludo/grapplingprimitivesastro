---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  fullscreen?: boolean; // hides header/footer for immersive viz pages
}

const {
  title = 'Grappling Primitives',
  description = 'An interactive atlas of grappling concepts.',
  fullscreen = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <Fragment set:html={`<style>
      @font-face { font-family:'DS-Digital'; src:url('${base}/fonts/DS_Digital/DS-DIGI.TTF')  format('truetype'); font-weight:400; font-style:normal; }
      @font-face { font-family:'DS-Digital'; src:url('${base}/fonts/DS_Digital/DS-DIGIB.TTF') format('truetype'); font-weight:700; font-style:normal; }
      @font-face { font-family:'DS-Digital'; src:url('${base}/fonts/DS_Digital/DS-DIGII.TTF') format('truetype'); font-weight:400; font-style:italic; }
      @font-face { font-family:'DS-Digital'; src:url('${base}/fonts/DS_Digital/DS-DIGIT.TTF') format('truetype'); font-weight:300; font-style:normal; }
    </style>`} />
  </head>

  <body class="bg-bg text-text-primary font-mono min-h-screen flex flex-col">

    {!fullscreen && (
      <header class="fixed top-0 left-0 right-0 z-50 h-10 border-b border-border bg-bg/95 backdrop-blur-sm flex items-center px-4 gap-4">
        <a href={`${base}/`} class="text-[10px] tracking-[3px] text-text-muted uppercase hover:text-accent transition-colors">
          GRAPPLING PRIMITIVES
        </a>
        <span class="text-border">|</span>
        <nav class="flex items-center gap-4 text-[10px] tracking-[2px] text-text-dim uppercase">
          <a href={`${base}/modules/matrix`}   class="hover:text-accent transition-colors">Matrix</a>
          <a href={`${base}/modules/quadtree`} class="hover:text-accent transition-colors">QuadTree</a>
          <a href={`${base}/modules/articles`}  class="hover:text-accent transition-colors">Articles</a>
          <a href={`${base}/modules/cards`}    class="hover:text-accent transition-colors">Cards</a>
          <a href={`${base}/modules/games`}    class="hover:text-accent transition-colors">Games</a>
        </nav>
      </header>
    )}

    <main class={fullscreen ? 'flex-1' : 'flex-1 pt-10'}>
      <slot />
    </main>

    {!fullscreen && (
      <footer class="border-t border-border py-3 px-4 text-[9px] tracking-[2px] text-text-dim uppercase text-center">
        Grappling Primitives — grapplingprimitives.com
      </footer>
    )}

    {import.meta.env.DEV && <script is:inline src={`${base}/js/kanri-dev.js`}></script>}
  </body>
</html>
