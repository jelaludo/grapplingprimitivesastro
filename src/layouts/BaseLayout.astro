---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  fullscreen?: boolean; // hides header/footer for immersive viz pages
}

const {
  title = 'Grappling Primitives',
  description = 'An interactive atlas of grappling concepts.',
  fullscreen = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-bg text-text-primary font-mono min-h-screen flex flex-col">

    {!fullscreen && (
      <header class="fixed top-0 left-0 right-0 z-50 h-10 border-b border-border bg-bg/95 backdrop-blur-sm flex items-center px-4 gap-4">
        <a href="/" class="text-[10px] tracking-[3px] text-text-muted uppercase hover:text-accent transition-colors">
          GRAPPLING PRIMITIVES
        </a>
        <span class="text-border">|</span>
        <nav class="flex items-center gap-4 text-[10px] tracking-[2px] text-text-dim uppercase">
          <a href="/modules/matrix"  class="hover:text-accent transition-colors">Matrix</a>
          <a href="/modules/cards"   class="hover:text-accent transition-colors">Cards</a>
          <a href="/modules/games"   class="hover:text-accent transition-colors">Games</a>
        </nav>
      </header>
    )}

    <main class={fullscreen ? 'flex-1' : 'flex-1 pt-10'}>
      <slot />
    </main>

    {!fullscreen && (
      <footer class="border-t border-border py-3 px-4 text-[9px] tracking-[2px] text-text-dim uppercase text-center">
        Grappling Primitives — grapplingprimitives.com
      </footer>
    )}

  </body>
</html>
